# ===========================================
# UNDERWINGS DOCKERIZED ENVIRONMENT
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DOMAIN CONFIGURATION
# ===========================================
SITE_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
ADMIN_URL=https://admin.yourdomain.com
STUDIO_URL=https://studio.yourdomain.com

# ===========================================
# POSTGRES DATABASE
# ===========================================
POSTGRES_PASSWORD=your-super-secret-db-password-min-32-chars
POSTGRES_USER=postgres
POSTGRES_DB=underwings
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===========================================
# JWT / AUTH
# ===========================================
JWT_SECRET=your-super-secret-jwt-token-min-32-characters-long
ANON_KEY=your-anon-key-will-be-generated
SERVICE_ROLE_KEY=your-service-role-key-will-be-generated

# ===========================================
# SUPABASE CONFIG
# ===========================================
SUPABASE_PUBLIC_URL=https://api.yourdomain.com
SUPABASE_ANON_KEY=${ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}

# ===========================================
# SMTP / EMAIL
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Underwings Technologies

# ===========================================
# STUDIO ADMIN
# ===========================================
STUDIO_USERNAME=admin
STUDIO_PASSWORD=your-studio-password

# ===========================================
# DASHBOARD ADMIN
# ===========================================
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-admin-password

# ===========================================
# SECURITY
# ===========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900
