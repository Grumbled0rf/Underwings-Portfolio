---
// ===========================================
// BASE LAYOUT
// Underwings Technologies
// ===========================================

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = "Underwings – Cybersecurity Solutions & Software Sales",
  description = "Underwings provides comprehensive cybersecurity services including VAPT, ISO 27001 implementation, security awareness training, and enterprise security software sales.",
  ogImage = "/images/og-image.png",
  canonical = Astro.url.href
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://underwings.org";
---

<!DOCTYPE html>
<html lang="en" data-wf-page="6920627afaad5c7afb54bfa8" data-wf-site="69206277faad5c7afb54beff">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="twitter:title" content={title}>
  <meta property="twitter:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content={`${siteUrl}${ogImage}`}>
  <meta property="og:locale" content="en_AE">
  <meta content="summary_large_image" name="twitter:card">
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Underwings Technologies">
  <meta name="geo.region" content="AE">
  <meta name="geo.placename" content="Dubai, UAE">
  <link rel="canonical" href={canonical}>
  <meta name="keywords" content="cybersecurity UAE, VAPT services Dubai, ISO 27001 implementation, security software sales, penetration testing UAE, cybersecurity training">

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Underwings Technologies",
    "url": siteUrl,
    "logo": `${siteUrl}/images/logowhiteUW.png`,
    "description": "Enterprise cybersecurity solutions provider offering security software sales, VAPT services, ISO 27001 implementation, and security awareness training.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AE",
      "addressRegion": "Dubai"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+971-547078203",
      "email": "contact@underwings.org",
      "contactType": "sales"
    }
  })}></script>

  <!-- Styles -->
  <link href="/css/normalize.css" rel="stylesheet" type="text/css">
  <link href="/css/webflow.css" rel="stylesheet" type="text/css">
  <link href="/css/underwings-org.webflow.css" rel="stylesheet" type="text/css">

  <style is:global>
    /* Navigation Dropdown Styles */
    .nav-dropdown {
      position: relative;
      display: inline-block;
    }
    .nav-dropdown-content {
      display: none;
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(23, 23, 23, 0.98);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      padding: 0.5rem 0;
      min-width: 180px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.5);
      z-index: 1000;
      backdrop-filter: blur(10px);
    }
    .nav-dropdown:hover .nav-dropdown-content {
      display: block;
    }
    .nav-dropdown-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      color: #fff;
      text-decoration: none;
      font-size: 0.875rem;
      transition: background 0.2s;
    }
    .nav-dropdown-item:hover {
      background: rgba(255,255,255,0.05);
    }
    .coming-soon-badge {
      font-size: 0.65rem;
      padding: 0.2rem 0.5rem;
      background: linear-gradient(135deg, #24d758, #27dab4);
      color: #000;
      border-radius: 4px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    /* Partners Section Styles */
    .partners-section {
      animation: fadeInUp 0.8s ease-out forwards;
      animation-delay: 0.5s;
    }
    .partners-section a {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .partners-section a img {
      max-width: 120px;
      object-fit: contain;
    }
    @keyframes fadeInUp {
      from { opacity: 0; filter: blur(3px); transform: translateY(20px); }
      to { opacity: 1; filter: blur(0); transform: translateY(0); }
    }
    @media (max-width: 768px) {
      .partners-section a img {
        height: 24px !important;
      }
    }
  </style>

  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin="anonymous">
  <script src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.26/webfont.js" type="text/javascript"></script>
  <script type="text/javascript">
    WebFont.load({ google: { families: ["Droid Sans:400,700", "Geist:300,400,500,600,700", "Geist Mono:300,400,500,600,700"] } });
  </script>
  <script type="text/javascript">
    !function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);
  </script>
  <link href="/images/favicon.png" rel="shortcut icon" type="image/x-icon">
  <link href="/images/webclip.png" rel="apple-touch-icon">
</head>
<body class="body">
  <div class="gsap-code-embed w-embed w-script">
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const scrambleElements = document.querySelectorAll('[data-name="scramble"]');
        scrambleElements.forEach(el => {
          const originalText = el.textContent;
          let scrambleTL = gsap.timeline({ paused: true });
          let isPlaying = false;
          scrambleTL.to(el, {
            duration: 0.8,
            scrambleText: {
              text: "{original}",
              chars: "+?84564XERSHKZN",
              speed: 0.5
            }
          });
          el.addEventListener('mouseenter', function() {
            if (!isPlaying) {
              isPlaying = true;
              scrambleTL.restart();
            }
          });
          scrambleTL.eventCallback("onComplete", () => {
            isPlaying = false;
          });
        });
      });
    </script>
  </div>

  <div data-wf--noise--variant="base" class="noise-wrapper">
    <div data-w-id="71d94dcc-6696-ef8a-8008-1058c6cb48e2" class="noise"></div>
  </div>

  <slot />

  <!-- Scripts -->
  <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=69206277faad5c7afb54beff" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script src="/js/webflow.js" type="text/javascript"></script>
  <script src="https://cdn.prod.website-files.com/gsap/3.14.2/gsap.min.js" type="text/javascript"></script>
  <script src="https://cdn.prod.website-files.com/gsap/3.14.2/ScrambleTextPlugin.min.js" type="text/javascript"></script>
  <script type="text/javascript">gsap.registerPlugin(ScrambleTextPlugin);</script>
</body>
</html>
