---
// ===========================================
// BASE LAYOUT
// Underwings Technologies
// ===========================================

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  keywords?: string;
  wfPage?: string;
  schema?: object | object[] | null;
  bodyClass?: string;
}

const {
  title = "Underwings – Cybersecurity Solutions & Software Sales",
  description = "Underwings provides comprehensive cybersecurity services including VAPT, ISO 27001 implementation, security awareness training, and enterprise security software sales.",
  ogImage = "/images/og-image.png",
  canonical = Astro.url.href,
  keywords = "cybersecurity UAE, VAPT services Dubai, ISO 27001 implementation, security software sales, penetration testing UAE, cybersecurity training",
  wfPage = "6920627afaad5c7afb54bfa8",
  schema,
  bodyClass = "body",
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://underwings.org";

// Schema logic: null = no schema, undefined = default Organization, custom = render custom
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Underwings Technologies",
  "url": siteUrl,
  "logo": `${siteUrl}/images/logowhiteUW.png`,
  "description": "Enterprise cybersecurity solutions provider offering security software sales, VAPT services, ISO 27001 implementation, and security awareness training.",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "AE",
    "addressRegion": "Dubai"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+971-547078203",
    "email": "contact@underwings.org",
    "contactType": "sales"
  }
};

const schemaToRender = schema === null ? null : schema !== undefined ? schema : defaultSchema;
const schemaArray = schemaToRender === null ? [] : Array.isArray(schemaToRender) ? schemaToRender : [schemaToRender];
---

<!DOCTYPE html>
<html lang="en" data-wf-page={wfPage} data-wf-site="69206277faad5c7afb54beff">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="twitter:title" content={title}>
  <meta property="twitter:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content={`${siteUrl}${ogImage}`}>
  <meta property="og:locale" content="en_AE">
  <meta content="summary_large_image" name="twitter:card">
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Underwings Technologies">
  <meta name="geo.region" content="AE">
  <meta name="geo.placename" content="Dubai, UAE">
  <link rel="canonical" href={canonical}>
  <meta name="keywords" content={keywords}>

  <!-- Structured Data -->
  {schemaArray.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)}></script>
  ))}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Underwings Blog" href="/rss.xml">

  <!-- DNS Prefetch -->
  <link rel="dns-prefetch" href="//d3e54v103j8qbb.cloudfront.net">
  <link rel="dns-prefetch" href="//cdn.prod.website-files.com">
  <link rel="dns-prefetch" href="//js-eu1.hs-scripts.com">
  <link rel="preconnect" href="https://d3e54v103j8qbb.cloudfront.net" crossorigin>
  <link rel="preconnect" href="https://cdn.prod.website-files.com" crossorigin>

  <!-- Font Preloads -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-400.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-600.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-mono-400.woff2" crossorigin>

  <!-- Styles -->
  <link href="/css/normalize.css" rel="stylesheet" type="text/css">
  <link href="/css/webflow.css" rel="stylesheet" type="text/css">
  <link href="/css/underwings-org.webflow.css" rel="stylesheet" type="text/css">

  <style is:global>
    /* Smooth Scroll */
    html {
      scroll-behavior: smooth;
    }

    /* Global Readability */
    body {
      font-size: 1.0625rem;
      line-height: 1.5;
    }
    .text {
      font-size: 1.0625rem;
      line-height: 1.6;
    }
    .text-medium {
      font-size: 1.1rem;
      line-height: 1.65;
    }
    .text-small {
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .heading-small {
      font-size: 1.85rem;
      line-height: 1.15;
    }
    .color-grey, .text-medium.color-grey {
      color: rgba(255, 255, 255, 0.55);
    }

    /* Skip to Content */
    .skip-to-content {
      position: absolute;
      top: -100%;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9999;
      padding: 0.75rem 1.5rem;
      background: #24d758;
      color: #000;
      font-weight: 600;
      font-size: 0.875rem;
      border-radius: 0 0 8px 8px;
      text-decoration: none;
      transition: top 0.2s;
    }
    .skip-to-content:focus {
      top: 0;
    }
    /* Navigation Dropdown Styles */
    .nav-dropdown {
      position: relative;
      display: inline-block;
    }
    .nav-chevron {
      display: inline-block;
      margin-left: 3px;
      vertical-align: middle;
      transition: transform 0.25s ease;
    }
    .nav-dropdown:hover .nav-chevron {
      transform: rotate(180deg);
    }

    /* Mega dropdown */
    .nav-mega-content {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      background: rgba(20, 20, 20, 0.98);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 0.5rem;
      min-width: 300px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.5);
      z-index: 1000;
      backdrop-filter: blur(12px);
    }
    .nav-dropdown:hover .nav-mega-content {
      display: block;
    }
    .nav-mega-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.75rem 0.85rem;
      color: #fff;
      text-decoration: none;
      border-radius: 8px;
      transition: background 0.2s ease;
    }
    .nav-mega-item:hover {
      background: rgba(255,255,255,0.05);
    }
    .nav-mega-icon {
      color: #24d758;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .nav-mega-title {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      color: #fff;
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .nav-mega-desc {
      display: block;
      font-size: 0.725rem;
      color: rgba(255,255,255,0.4);
      line-height: 1.35;
    }
    .nav-mega-item:hover .nav-mega-title {
      color: #24d758;
    }

    /* Mobile mega dropdown — show as flat list */
    @media screen and (max-width: 991px) {
      .nav-dropdown {
        display: block;
      }
      .nav-dropdown > .nav-link {
        pointer-events: none;
      }
      .nav-chevron {
        display: none;
      }
      .nav-mega-content {
        display: block;
        position: static;
        transform: none;
        background: transparent;
        border: none;
        border-radius: 0;
        padding: 0 0 0 0.5rem;
        min-width: auto;
        box-shadow: none;
        backdrop-filter: none;
      }
      .nav-mega-item {
        padding: 0.5rem 0.5rem;
        border-radius: 6px;
      }
      .nav-mega-icon {
        display: none;
      }
      .nav-mega-desc {
        display: none;
      }
      .nav-mega-title {
        font-size: 0.8rem;
        font-weight: 500;
      }
    }

    .coming-soon-badge {
      font-size: 0.65rem;
      padding: 0.2rem 0.5rem;
      background: linear-gradient(135deg, #24d758, #27dab4);
      color: #000;
      border-radius: 4px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    /* Partners Section Styles */
    .partners-section {
      animation: fadeInUp 0.8s ease-out forwards;
      animation-delay: 0.5s;
    }
    .partners-section a {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .partners-section a img {
      max-width: 120px;
      object-fit: contain;
    }
    @keyframes fadeInUp {
      from { opacity: 0; filter: blur(3px); transform: translateY(20px); }
      to { opacity: 1; filter: blur(0); transform: translateY(0); }
    }
    @media (max-width: 768px) {
      .partners-section a img {
        height: 24px !important;
      }
    }
  </style>

  <style is:inline>
    @font-face { font-family: 'Geist'; font-weight: 300; font-style: normal; font-display: swap; src: url('/fonts/geist-300.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/geist-400.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 500; font-style: normal; font-display: swap; src: url('/fonts/geist-500.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 600; font-style: normal; font-display: swap; src: url('/fonts/geist-600.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 700; font-style: normal; font-display: swap; src: url('/fonts/geist-700.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 300; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-300.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-400.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 500; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-500.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 600; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-600.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 700; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-700.woff2') format('woff2'); }
    @font-face { font-family: 'Droid Sans'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/droid-sans-400.woff2') format('woff2'); }
    @font-face { font-family: 'Droid Sans'; font-weight: 700; font-style: normal; font-display: swap; src: url('/fonts/droid-sans-700.woff2') format('woff2'); }
  </style>
  <script type="text/javascript">
    !function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);
  </script>
  <link href="/images/favicon.png" rel="shortcut icon" type="image/x-icon">
  <link href="/images/webclip.png" rel="apple-touch-icon">

  <slot name="head" />
  <!-- Start of HubSpot Embed Code -->
  <script type="text/javascript" id="hs-script-loader" async defer src="//js-eu1.hs-scripts.com/147940148.js"></script>
  <!-- End of HubSpot Embed Code -->
</head>
<body class={bodyClass}>
  <slot />

  <!-- Scripts -->
  <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=69206277faad5c7afb54beff" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous" defer></script>
  <script src="/js/webflow.js" type="text/javascript" defer></script>
  <script src="https://cdn.prod.website-files.com/gsap/3.14.2/gsap.min.js" type="text/javascript" integrity="sha384-sG0Hv1tP1lZCk9KQmrIbY/XNwi+OY84GQqhMscbnsoBFqAz8KNCil1kvfL3Hbbk2" crossorigin="anonymous" defer></script>
  <script src="https://cdn.prod.website-files.com/gsap/3.14.2/ScrambleTextPlugin.min.js" type="text/javascript" integrity="sha384-WLYL9YzLSUMXVSCeTvIeNU1RjveFpJK9drY7FtmMDfLeYdVjyx2/JoVDt/ujHexr" crossorigin="anonymous" defer></script>
  <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function() {
      gsap.registerPlugin(ScrambleTextPlugin);
      const scrambleElements = document.querySelectorAll('[data-name="scramble"]');
      scrambleElements.forEach(el => {
        const originalText = el.textContent;
        let scrambleTL = gsap.timeline({ paused: true });
        let isPlaying = false;
        scrambleTL.to(el, {
          duration: 0.8,
          scrambleText: {
            text: "{original}",
            chars: "+?84564XERSHKZN",
            speed: 0.5
          }
        });
        el.addEventListener('mouseenter', function() {
          if (!isPlaying) {
            isPlaying = true;
            scrambleTL.restart();
          }
        });
        scrambleTL.eventCallback("onComplete", () => {
          isPlaying = false;
        });
      });
    });
  </script>
</body>
</html>
