  <div id="uw-fab-backdrop"></div>

  <script is:inline nonce={nonce}>
  (function() {
    var fabToggle = document.getElementById('uw-fab-toggle');
    var fabOptions = document.getElementById('uw-fab-options');
    var fabBackdrop = document.getElementById('uw-fab-backdrop');
    var fabIconChat = document.getElementById('uw-fab-icon-chat');
    var fabIconClose = document.getElementById('uw-fab-icon-close');
    var fabAiBtn = document.getElementById('uw-fab-ai');
    var fabItems = fabOptions.querySelectorAll('.uw-fab-option');

    var panel = document.getElementById('uw-chat-panel');
    var closeBtn = document.getElementById('uw-chat-close');
    var form = document.getElementById('uw-chat-form');
    var input = document.getElementById('uw-chat-input');
    var messagesEl = document.getElementById('uw-chat-messages');
    var suggestions = document.getElementById('uw-chat-suggestions');
    var messages = [];
    var isFabOpen = false;
    var isChatOpen = false;
    var isSending = false;

    // --- FAB menu ---
    function openFab() {
      isFabOpen = true;
      fabOptions.style.display = 'flex';
      fabBackdrop.style.display = 'block';
      fabToggle.setAttribute('aria-expanded', 'true');
      fabIconChat.style.display = 'none';
      fabIconClose.style.display = 'block';
      // Stagger animate options
      fabItems.forEach(function(item, i) {
        setTimeout(function() { item.classList.add('is-visible'); }, i * 80);
      });
    }

    function closeFab() {
      isFabOpen = false;
      fabToggle.setAttribute('aria-expanded', 'false');
      fabBackdrop.style.display = 'none';
      if (!isChatOpen) {
        fabIconChat.style.display = 'block';
        fabIconClose.style.display = 'none';
      }
      // Reverse animate
      for (var i = fabItems.length - 1; i >= 0; i--) {
        fabItems[i].classList.remove('is-visible');
      }
      setTimeout(function() {
        if (!isFabOpen) fabOptions.style.display = 'none';
      }, 250);
    }

    function toggleFab() {
      if (isChatOpen) {
        closeChatPanel();
      } else if (isFabOpen) {
        closeFab();
      } else {
        openFab();
      }
    }

    fabToggle.addEventListener('click', toggleFab);
    fabBackdrop.addEventListener('click', closeFab);

    // --- AI Chat panel ---
    function openChatPanel() {
      isChatOpen = true;
      closeFab();
      panel.style.display = 'flex';
      fabIconChat.style.display = 'none';
      fabIconClose.style.display = 'block';
      fabToggle.setAttribute('aria-expanded', 'true');
      input.focus();
    }

    function closeChatPanel() {
      isChatOpen = false;
      panel.style.display = 'none';
      fabIconChat.style.display = 'block';
      fabIconClose.style.display = 'none';
      fabToggle.setAttribute('aria-expanded', 'false');
    }

    fabAiBtn.addEventListener('click', openChatPanel);
    closeBtn.addEventListener('click', closeChatPanel);

    // Keyboard navigation for FAB menu
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (isChatOpen) closeChatPanel();
        else if (isFabOpen) closeFab();
      }
      // Arrow key navigation within FAB options
      if (isFabOpen && !isChatOpen && (e.key === 'ArrowUp' || e.key === 'ArrowDown')) {
        e.preventDefault();
        var items = Array.from(fabOptions.querySelectorAll('[role="menuitem"]'));
        var current = items.indexOf(document.activeElement);
        var next = e.key === 'ArrowDown' ? (current + 1) % items.length : (current - 1 + items.length) % items.length;
        items[next].focus();
      }
    });

    // Simple markdown: bold, links, lists, line breaks
    function renderMarkdown(text) {
      return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
        .replace(/\n- /g, '\n• ')
        .replace(/\n/g, '<br>');
    }

    function addMessage(role, content) {
      var div = document.createElement('div');
      div.className = 'uw-msg ' + (role === 'user' ? 'uw-msg-user' : 'uw-msg-ai');
      div.innerHTML = role === 'user' ? content.replace(/</g, '&lt;').replace(/>/g, '&gt;') : renderMarkdown(content);
      messagesEl.appendChild(div);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return div;
    }

    function hideSuggestions() {
      if (suggestions) suggestions.style.display = 'none';
    }

    function showTyping() {
      var div = document.createElement('div');
      div.className = 'uw-msg-typing';
      div.id = 'uw-typing';
      div.innerHTML = '<div class="uw-typing-dots"><span></span><span></span><span></span></div>';
      messagesEl.appendChild(div);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function removeTyping() {
      var el = document.getElementById('uw-typing');
      if (el) el.remove();
    }

    function sendMessage(text) {
      if (!text || isSending) return;
      isSending = true;
      hideSuggestions();

      addMessage('user', text);
      messages.push({ role: 'user', content: text });
      input.value = '';
      input.disabled = true;
      document.getElementById('uw-chat-send').disabled = true;
      showTyping();

      fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: messages })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        removeTyping();
        var reply = data.reply || 'Sorry, something went wrong. Reach us at **contact@underwings.org**.';
        addMessage('assistant', reply);
        messages.push({ role: 'assistant', content: reply });
      })
      .catch(function() {
        removeTyping();
        addMessage('assistant', 'Sorry, I\'m having trouble connecting. Please try again or reach us at **contact@underwings.org**.');
      })
      .finally(function() {
        isSending = false;
        input.disabled = false;
        document.getElementById('uw-chat-send').disabled = false;
        input.focus();
      });
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      sendMessage(input.value.trim());
    });

    // Suggestion buttons
    if (suggestions) {
      suggestions.addEventListener('click', function(e) {
        var btn = e.target.closest('.uw-suggestion');
        if (btn) sendMessage(btn.getAttribute('data-msg'));
      });
    }
  })();
  </script>

