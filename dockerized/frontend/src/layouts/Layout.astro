---
// ===========================================
// BASE LAYOUT
// Underwings Cybersecurity Solutions
// ===========================================

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  keywords?: string;
  wfPage?: string;
  schema?: object | object[] | null;
  bodyClass?: string;
}

const {
  title = "Underwings – Cybersecurity Solutions & Software Sales",
  description = "Underwings is a cybersecurity startup providing VAPT, ISO 27001 implementation, security awareness training, and security software sales in India & UAE.",
  ogImage = "/images/og-image.png",
  canonical = Astro.url.href,
  keywords = "cybersecurity UAE, VAPT services Dubai, ISO 27001 implementation, security software sales, penetration testing UAE, cybersecurity training",
  wfPage = "6920627afaad5c7afb54bfa8",
  schema,
  bodyClass = "body",
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://underwings.org";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "";
const nonce = Astro.locals.nonce || "";

// Schema logic: null = no schema, undefined = default Organization, custom = render custom
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Underwings Cybersecurity Solutions",
  "url": siteUrl,
  "logo": `${siteUrl}/images/logowhiteUW.png`,
  "description": "Cybersecurity startup offering security software sales, VAPT services, ISO 27001 implementation, and security awareness training in India & UAE.",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "AE",
    "addressRegion": "Dubai"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+971-547078203",
    "email": "contact@underwings.org",
    "contactType": "sales"
  }
};

const schemaToRender = schema === null ? null : schema !== undefined ? schema : defaultSchema;
const schemaArray = schemaToRender === null ? [] : Array.isArray(schemaToRender) ? schemaToRender : [schemaToRender];
---

<!DOCTYPE html>
<html lang="en" data-wf-page={wfPage} data-wf-site="69206277faad5c7afb54beff">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="twitter:title" content={title}>
  <meta property="twitter:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content={`${siteUrl}${ogImage}`}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_AE">

  <!-- hreflang: en ↔ ar cross-linking -->
  <link rel="alternate" hreflang="en" href={siteUrl}>
  <link rel="alternate" hreflang="ar" href={`${siteUrl}/ar`}>
  <link rel="alternate" hreflang="x-default" href={siteUrl}>
  <meta content="summary_large_image" name="twitter:card">
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Underwings Cybersecurity Solutions">
  <meta name="geo.region" content="AE">
  <meta name="geo.placename" content="Dubai, UAE">
  <link rel="canonical" href={canonical}>
  <meta name="keywords" content={keywords}>

  <!-- Structured Data -->
  {schemaArray.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)}></script>
  ))}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Underwings Blog" href="/rss.xml">

  <!-- Calendly -->
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">

  <!-- DNS Prefetch -->
  <link rel="dns-prefetch" href="//assets.calendly.com">
  <link rel="dns-prefetch" href="//d3e54v103j8qbb.cloudfront.net">
  <link rel="dns-prefetch" href="//cdn.prod.website-files.com">
  <link rel="dns-prefetch" href="//js-eu1.hs-scripts.com">
  <link rel="preconnect" href="https://d3e54v103j8qbb.cloudfront.net" crossorigin>
  <link rel="preconnect" href="https://cdn.prod.website-files.com" crossorigin>

  <!-- Font Preloads -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-400.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-600.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-mono-400.woff2" crossorigin>

  <!-- Styles -->
  <link href="/css/normalize.css" rel="stylesheet" type="text/css">
  <link href="/css/webflow.css" rel="stylesheet" type="text/css">
  <link href="/css/underwings-org.webflow.css" rel="stylesheet" type="text/css">

  <style is:global>
    /* Smooth Scroll */
    html {
      scroll-behavior: smooth;
    }

    /* Header secondary button — match .button size */
    .header-btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1.25rem;
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 0.5rem;
      color: #fff;
      font-size: 0.875rem;
      font-weight: 500;
      font-family: inherit;
      text-decoration: none;
      white-space: nowrap;
      transition: border-color 0.25s ease, background 0.25s ease, color 0.25s ease;
    }
    .header-btn-secondary:hover {
      border-color: #24d758;
      color: #24d758;
      background: rgba(36,215,88,0.05);
    }

    /* Calendly mobile nav link */
    .header-calendly-btn-mobile {
      display: none;
    }
    @media (max-width: 991px) {
      .header-btn-secondary { display: none; }
      .header-calendly-btn-mobile {
        display: block;
      }
    }

    /* Global Readability */
    body {
      font-size: 1.0625rem;
      line-height: 1.5;
    }
    .text {
      font-size: 1.0625rem;
      line-height: 1.6;
    }
    .text-medium {
      font-size: 1.1rem;
      line-height: 1.65;
    }
    .text-small {
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .heading-small {
      font-size: 1.85rem;
      line-height: 1.15;
    }
    .color-grey, .text-medium.color-grey {
      color: rgba(255, 255, 255, 0.7);
    }

    /* Skip to Content */
    .skip-to-content {
      position: absolute;
      top: -100%;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9999;
      padding: 0.75rem 1.5rem;
      background: #24d758;
      color: #000;
      font-weight: 600;
      font-size: 0.875rem;
      border-radius: 0 0 8px 8px;
      text-decoration: none;
      transition: top 0.2s;
    }
    .skip-to-content:focus {
      top: 0;
    }
    /* Navigation Dropdown Styles */
    .nav-dropdown {
      position: relative;
      display: inline-block;
    }
    .nav-chevron {
      display: inline-block;
      margin-left: 3px;
      vertical-align: middle;
      transition: transform 0.25s ease;
    }
    .nav-dropdown:hover .nav-chevron,
    .nav-dropdown:focus-within .nav-chevron {
      transform: rotate(180deg);
    }

    /* Mega dropdown */
    .nav-mega-content {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      background: rgba(20, 20, 20, 0.98);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 0.5rem;
      min-width: 300px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.5);
      z-index: 1000;
      backdrop-filter: blur(12px);
    }
    /* Invisible bridge to cover the gap between trigger and dropdown */
    .nav-mega-content::before {
      content: '';
      position: absolute;
      top: -0.5rem;
      left: 0;
      right: 0;
      height: 0.5rem;
    }
    .nav-dropdown:hover .nav-mega-content,
    .nav-dropdown:focus-within .nav-mega-content {
      display: block;
    }
    .nav-mega-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.75rem 0.85rem;
      color: #fff;
      text-decoration: none;
      border-radius: 8px;
      transition: background 0.2s ease;
    }
    .nav-mega-item:hover {
      background: rgba(255,255,255,0.05);
    }
    .nav-mega-icon {
      color: #24d758;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .nav-mega-title {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      color: #fff;
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .nav-mega-desc {
      display: block;
      font-size: 0.725rem;
      color: rgba(255,255,255,0.65);
      line-height: 1.35;
    }
    .nav-mega-item:hover .nav-mega-title {
      color: #24d758;
    }

    /* Mobile mega dropdown — show as flat list */
    @media screen and (max-width: 991px) {
      .nav-dropdown {
        display: block;
      }
      .nav-dropdown > .nav-link {
        pointer-events: none;
      }
      .nav-chevron {
        display: none;
      }
      .nav-mega-content {
        display: block;
        position: static;
        transform: none;
        background: transparent;
        border: none;
        border-radius: 0;
        padding: 0 0 0 0.5rem;
        min-width: auto;
        box-shadow: none;
        backdrop-filter: none;
      }
      .nav-mega-item {
        padding: 0.5rem 0.5rem;
        border-radius: 6px;
      }
      .nav-mega-icon {
        display: none;
      }
      .nav-mega-desc {
        display: none;
      }
      .nav-mega-title {
        font-size: 0.8rem;
        font-weight: 500;
      }
    }

    .coming-soon-badge {
      font-size: 0.65rem;
      padding: 0.2rem 0.5rem;
      background: linear-gradient(135deg, #24d758, #27dab4);
      color: #000;
      border-radius: 4px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    /* Partners Section Styles */
    .partners-section {
      animation: fadeInUp 0.8s ease-out forwards;
      animation-delay: 0.5s;
    }
    .partners-section a {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .partners-section a img {
      max-width: 120px;
      object-fit: contain;
    }
    @keyframes fadeInUp {
      from { opacity: 0; filter: blur(3px); transform: translateY(20px); }
      to { opacity: 1; filter: blur(0); transform: translateY(0); }
    }
    @media (max-width: 768px) {
      .partners-section a img {
        height: 24px !important;
      }
    }

    /* Compact section spacing for service pages */
    .svc-compact .section {
      padding-top: 4.5rem;
      padding-bottom: 4.5rem;
    }
    .svc-compact .hero-section {
      padding-top: 7.5rem;
      padding-bottom: 4.5rem;
    }
    @media screen and (min-width: 1280px) {
      .svc-compact .section {
        padding-top: 5.5rem;
        padding-bottom: 5.5rem;
      }
      .svc-compact .hero-section {
        padding-top: 9rem;
        padding-bottom: 5.5rem;
      }
    }

    /* Lead Magnet Component */
    .lead-magnet {
      display: flex;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 2rem 2.5rem;
      border: 1px solid rgba(36,215,88,0.2);
      border-radius: 14px;
      background: rgba(36,215,88,0.04);
      max-width: 900px;
      margin: 0 auto;
    }
    .lead-magnet-icon {
      color: #24d758;
      flex-shrink: 0;
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(36,215,88,0.1);
      border: 1px solid rgba(36,215,88,0.25);
      border-radius: 12px;
    }
    .lead-magnet-content { flex: 1; min-width: 0; }
    .lead-magnet-title {
      font-size: 1.15rem;
      font-weight: 600;
      color: #fff;
      margin-bottom: 0.4rem;
    }
    .lead-magnet-desc {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.6;
      margin-bottom: 0;
    }
    .lead-magnet-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 0.75rem;
    }
    .lead-magnet-tags span {
      font-size: 0.65rem;
      padding: 0.2rem 0.5rem;
      background: rgba(36,215,88,0.1);
      border: 1px solid rgba(36,215,88,0.25);
      border-radius: 4px;
      color: #24d758;
      font-weight: 500;
      letter-spacing: 0.2px;
    }
    .lead-magnet-form {
      flex-shrink: 0;
      width: 240px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .lead-magnet-input {
      width: 100%;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px 8px 0 0;
      padding: 0.7rem 0.85rem;
      color: #fff;
      font-size: 0.825rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .lead-magnet-input::placeholder { color: rgba(255,255,255,0.3); }
    .lead-magnet-input:focus { border-color: rgba(36,215,88,0.5); }
    .lead-magnet-btn {
      width: 100%;
      background: #24d758;
      border: none;
      border-radius: 0 0 8px 8px;
      padding: 0.65rem;
      color: #000;
      font-size: 0.85rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.2s;
    }
    .lead-magnet-btn:hover { background: #1db84a; }
    .lead-magnet-btn:disabled { opacity: 0.7; cursor: not-allowed; }
    .lm-msg {
      font-size: 0.75rem;
      margin-top: 0.4rem;
      line-height: 1.4;
    }
    .lm-success { color: #24d758; }
    .lm-error { color: #ff4444; }
    .lm-privacy {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.3);
      margin: 0.3rem 0 0;
      text-align: center;
    }
    @media (max-width: 768px) {
      .lead-magnet {
        flex-direction: column;
        padding: 1.5rem;
        text-align: center;
      }
      .lead-magnet-icon { margin: 0 auto; }
      .lead-magnet-tags { justify-content: center; }
      .lead-magnet-form { width: 100%; }
    }

    /* ARIA Invalid State */
    [aria-invalid="true"] {
      border-color: #ff4444 !important;
      box-shadow: 0 0 0 1px rgba(255,68,68,0.3);
    }

    /* Focus Visible Styles */
    :focus-visible {
      outline: 2px solid #24d758;
      outline-offset: 2px;
    }
    .nav-link:focus-visible,
    .nav-mega-item:focus-visible {
      outline: 2px solid #24d758;
      outline-offset: 2px;
      border-radius: 4px;
    }
    .button-hidden:focus-visible {
      outline: 2px solid #24d758;
      outline-offset: 4px;
      border-radius: 4px;
    }

    /* Reduced Motion */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>

  <style is:inline>
    @font-face { font-family: 'Geist'; font-weight: 300; font-style: normal; font-display: swap; src: url('/fonts/geist-300.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/geist-400.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 500; font-style: normal; font-display: swap; src: url('/fonts/geist-500.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 600; font-style: normal; font-display: swap; src: url('/fonts/geist-600.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 700; font-style: normal; font-display: swap; src: url('/fonts/geist-700.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 300; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-300.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-400.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 500; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-500.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 600; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-600.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 700; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-700.woff2') format('woff2'); }
    @font-face { font-family: 'Droid Sans'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/droid-sans-400.woff2') format('woff2'); }
    @font-face { font-family: 'Droid Sans'; font-weight: 700; font-style: normal; font-display: swap; src: url('/fonts/droid-sans-700.woff2') format('woff2'); }
  </style>
  <script is:inline nonce={nonce} src="/js/wf-init.js"></script>
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">
  <link rel="manifest" href="/site.webmanifest">

  <slot name="head" />

  <!-- Cloudflare Turnstile CAPTCHA (only loads if site key is set) -->
  {turnstileSiteKey && (
    <script is:inline nonce={nonce} src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}
  <script is:inline nonce={nonce} define:vars={{ turnstileSiteKey }}>
    window.__TURNSTILE_SITE_KEY = turnstileSiteKey;
  </script>
</head>
<body class={bodyClass}>
  <slot />

  <!-- Scripts -->
  <script is:inline nonce={nonce} src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=69206277faad5c7afb54beff" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous" defer></script>
  <script is:inline nonce={nonce} src="/js/webflow.js" type="text/javascript" defer></script>
  <script is:inline nonce={nonce} src="https://cdn.prod.website-files.com/gsap/3.14.2/gsap.min.js" type="text/javascript" integrity="sha384-sG0Hv1tP1lZCk9KQmrIbY/XNwi+OY84GQqhMscbnsoBFqAz8KNCil1kvfL3Hbbk2" crossorigin="anonymous" defer></script>
  <script is:inline nonce={nonce} src="https://cdn.prod.website-files.com/gsap/3.14.2/ScrambleTextPlugin.min.js" type="text/javascript" integrity="sha384-WLYL9YzLSUMXVSCeTvIeNU1RjveFpJK9drY7FtmMDfLeYdVjyx2/JoVDt/ujHexr" crossorigin="anonymous" defer></script>
  <script is:inline nonce={nonce} src="/js/scramble-init.js" defer></script>
  <script is:inline nonce={nonce} src="https://assets.calendly.com/assets/external/widget.js"></script>
  <script is:inline nonce={nonce}>
  document.addEventListener('click', function(e) {
    var trigger = e.target.closest('[data-calendly-open]');
    if (!trigger) return;
    e.preventDefault();
    if (typeof Calendly !== 'undefined') {
      Calendly.initPopupWidget({ url: 'https://calendly.com/manoj-underwings/30min' });
    }
  });
  </script>

  <!-- Unified Chat FAB -->
  <div id="uw-chat-widget">
    <!-- Main FAB toggle -->
    <button id="uw-fab-toggle" aria-label="Contact us" aria-expanded="false">
      <svg id="uw-fab-icon-chat" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <svg id="uw-fab-icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" style="display:none;"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>

    <!-- FAB options (WhatsApp + AI Chat) -->
    <div id="uw-fab-options" role="menu" aria-label="Contact options" style="display:none;">
      <a id="uw-fab-whatsapp" href="https://wa.me/971547078203?text=Hi%20Underwings%2C%20I%27d%20like%20to%20know%20more%20about%20your%20cybersecurity%20services." target="_blank" rel="noopener noreferrer" class="uw-fab-option" role="menuitem" aria-label="Chat on WhatsApp">
        <span class="uw-fab-label">WhatsApp</span>
        <span class="uw-fab-option-icon uw-fab-wa">
