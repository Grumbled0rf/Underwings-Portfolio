  <script is:inline nonce={nonce}>
  (function() {
    var consent = localStorage.getItem('uw-cookie-consent');
    if (consent === 'accepted') {
      loadHubSpot();
    } else if (consent !== 'declined') {
      document.getElementById('uw-cookie-banner').style.display = 'block';
    }

    document.getElementById('uw-cookie-accept').addEventListener('click', function() {
      localStorage.setItem('uw-cookie-consent', 'accepted');
      document.getElementById('uw-cookie-banner').style.display = 'none';
      loadHubSpot();
    });

    document.getElementById('uw-cookie-decline').addEventListener('click', function() {
      localStorage.setItem('uw-cookie-consent', 'declined');
      document.getElementById('uw-cookie-banner').style.display = 'none';
    });

    function loadHubSpot() {
      if (document.getElementById('hs-script-loader')) return;
      var s = document.createElement('script');
      s.id = 'hs-script-loader';
      s.src = '//js-eu1.hs-scripts.com/147940148.js';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }
  })();
  </script>

  <!-- Lead Magnet Forms -->
  <script is:inline nonce={nonce}>
  (function() {
    document.querySelectorAll('.lead-magnet-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var inputEl = form.querySelector('.lead-magnet-input');
        var email = inputEl.value.trim();
        if (!email) { inputEl.setAttribute('aria-invalid', 'true'); return; }
        inputEl.setAttribute('aria-invalid', 'false');
        var leadType = form.getAttribute('data-lead');
        var btn = form.querySelector('.lead-magnet-btn');
        var textEl = btn.querySelector('.lm-btn-text');
        var loadEl = btn.querySelector('.lm-btn-loading');
        textEl.style.display = 'none';
        loadEl.style.display = 'inline-flex';
        btn.disabled = true;
        var successEl = form.querySelector('.lm-success');
        var errorEl = form.querySelector('.lm-error');
        successEl.style.display = 'none';
        errorEl.style.display = 'none';
        fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, lead_magnet: leadType })
        })
        .then(function(res) {
          if (res.ok) {
            successEl.style.display = 'block';
            inputEl.value = '';
            inputEl.setAttribute('aria-invalid', 'false');
          } else { throw new Error('Failed'); }
        })
        .catch(function() {
          errorEl.style.display = 'block';
          inputEl.setAttribute('aria-invalid', 'true');
        })
        .finally(function() {
          textEl.style.display = '';
          loadEl.style.display = 'none';
          btn.disabled = false;
        });
      });
    });
  })();
  </script>

  <!-- Exit-Intent Popup -->
  <div id="uw-exit-popup" role="dialog" aria-label="Before you go" style="display:none;">
    <div id="uw-exit-backdrop-overlay"></div>
    <div id="uw-exit-card">
      <button id="uw-exit-close" aria-label="Close popup">&times;</button>
      <div id="uw-exit-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
      </div>
      <h3 id="uw-exit-title">Before you go</h3>
      <p id="uw-exit-desc">Get our free <strong>Security Assessment Checklist</strong> — 30 items your organization should review today.</p>
      <form id="uw-exit-form">
        <div id="uw-exit-input-row">
          <input type="email" id="uw-exit-email" placeholder="your@email.com" required aria-label="Email for checklist">
          <button type="submit" id="uw-exit-btn">
            <span class="uw-exit-btn-text">Get Free Checklist</span>
            <span class="uw-exit-btn-loading" style="display:none;">Sending...</span>
          </button>
        </div>
        <p id="uw-exit-success" class="lm-msg lm-success" style="display:none;">Check your inbox! The checklist is on its way.</p>
        <p id="uw-exit-error" class="lm-msg lm-error" style="display:none;">Something went wrong. Try again or email contact@underwings.org</p>
      </form>
      <p id="uw-exit-privacy">No spam. Unsubscribe anytime.</p>
    </div>
  </div>

  <style is:inline>
    #uw-exit-popup {
      position: fixed; inset: 0; z-index: 10001;
      display: flex; align-items: center; justify-content: center;
      padding: 1.5rem;
      animation: uwExitFadeIn 0.25s ease-out;
    }
    @keyframes uwExitFadeIn { from { opacity: 0; } to { opacity: 1; } }
    #uw-exit-backdrop-overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    }
    #uw-exit-card {
      position: relative;
      background: #111; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px; padding: 2.5rem;
      max-width: 440px; width: 100%;
      box-shadow: 0 20px 60px rgba(0,0,0,0.6);
      text-align: center;
      animation: uwExitSlideUp 0.3s ease-out;
    }
    @keyframes uwExitSlideUp {
      from { opacity: 0; transform: translateY(20px) scale(0.97); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    #uw-exit-close {
      position: absolute; top: 1rem; right: 1rem;
      background: none; border: none; color: rgba(255,255,255,0.4);
      font-size: 1.5rem; cursor: pointer; line-height: 1; padding: 0.25rem;
    }
    #uw-exit-close:hover { color: #fff; }
    #uw-exit-icon {
      width: 56px; height: 56px; border-radius: 14px;
      background: rgba(36,215,88,0.1); border: 1px solid rgba(36,215,88,0.25);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.25rem; color: #24d758;
    }
    #uw-exit-title {
      font-size: 1.35rem; font-weight: 700; color: #fff;
      margin: 0 0 0.6rem; font-family: 'Geist', sans-serif;
    }
    #uw-exit-desc {
      font-size: 0.9rem; color: rgba(255,255,255,0.6);
      line-height: 1.6; margin: 0 0 1.5rem;
    }
    #uw-exit-desc strong { color: #24d758; }
    #uw-exit-input-row {
      display: flex; gap: 0;
    }
    #uw-exit-email {
      flex: 1; padding: 0.75rem 1rem;
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px 0 0 8px; color: #fff; font-size: 0.875rem;
      font-family: inherit; outline: none; box-sizing: border-box;
    }
    #uw-exit-email::placeholder { color: rgba(255,255,255,0.3); }
    #uw-exit-email:focus { border-color: rgba(36,215,88,0.5); }
    #uw-exit-btn {
      padding: 0.75rem 1.25rem; background: #24d758; border: none;
      border-radius: 0 8px 8px 0; color: #000; font-size: 0.85rem;
      font-weight: 600; font-family: inherit; cursor: pointer;
      white-space: nowrap; transition: background 0.2s;
    }
    #uw-exit-btn:hover { background: #1db84a; }
    #uw-exit-btn:disabled { opacity: 0.7; cursor: not-allowed; }
    #uw-exit-privacy {
      font-size: 0.7rem; color: rgba(255,255,255,0.3);
      margin: 0.75rem 0 0;
    }
    @media (max-width: 480px) {
      #uw-exit-card { padding: 2rem 1.5rem; }
      #uw-exit-input-row { flex-direction: column; gap: 0.5rem; }
      #uw-exit-email { border-radius: 8px; }
      #uw-exit-btn { border-radius: 8px; }
    }
  </style>

  <script is:inline nonce={nonce}>
  (function() {
    var popup = document.getElementById('uw-exit-popup');
    var closeBtn = document.getElementById('uw-exit-close');
    var backdrop = document.getElementById('uw-exit-backdrop-overlay');
    var form = document.getElementById('uw-exit-form');
    var shown = false;
    var STORAGE_KEY = 'uw-exit-popup-shown';

    // Don't show if already shown or dismissed
    if (sessionStorage.getItem(STORAGE_KEY) || localStorage.getItem(STORAGE_KEY)) return;

    // Wait 15s minimum before showing
    var minTime = Date.now() + 15000;

    function showPopup() {
      if (shown || Date.now() < minTime) return;
      shown = true;
      popup.style.display = 'flex';
      sessionStorage.setItem(STORAGE_KEY, '1');
    }

    function closePopup() {
      popup.style.display = 'none';
      localStorage.setItem(STORAGE_KEY, '1');
    }

    // Exit intent: mouse leaves viewport from top
    document.addEventListener('mouseout', function(e) {
      if (e.clientY <= 0 && !shown) showPopup();
    });

    // Mobile: detect back/tab switch via visibilitychange (subtle approach)
    // Skipped to avoid being annoying on mobile

    closeBtn.addEventListener('click', closePopup);
    backdrop.addEventListener('click', closePopup);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && shown && popup.style.display === 'flex') closePopup();
    });

    // Form submission
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = document.getElementById('uw-exit-email').value.trim();
      if (!email) return;
      var btn = document.getElementById('uw-exit-btn');
      var textEl = btn.querySelector('.uw-exit-btn-text');
      var loadEl = btn.querySelector('.uw-exit-btn-loading');
      textEl.style.display = 'none';
      loadEl.style.display = 'inline';
      btn.disabled = true;

      fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, lead_magnet: 'Security Assessment Checklist' })
      })
      .then(function(res) {
        if (res.ok) {
          document.getElementById('uw-exit-success').style.display = 'block';
          document.getElementById('uw-exit-error').style.display = 'none';
          form.querySelector('#uw-exit-email').value = '';
          localStorage.setItem(STORAGE_KEY, '1');
        } else { throw new Error('fail'); }
      })
      .catch(function() {
        document.getElementById('uw-exit-error').style.display = 'block';
      })
      .finally(function() {
        textEl.style.display = '';
        loadEl.style.display = 'none';
        btn.disabled = false;
      });
    });
  })();
  </script>
</body>
</html>
