---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FooterRedesigned from '../components/FooterRedesigned.astro';
---

<Layout
  title="About Underwings - Cybersecurity Company UAE"
  description="Underwings Technologies is a UAE-based cybersecurity company providing security software sales, VAPT services, ISO 27001 implementation, and security training."
  keywords="Underwings Technologies, cybersecurity company UAE, security consulting Dubai, about Underwings"
  wfPage="about-page"
  schema={null}
>
  <Header currentPage="about" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">About Us</div>
              </div>
              <h1 class="heading-large hero-heading-large">Your Cybersecurity <span class="text-gradient-clip bg-color-green-gradient">Partner</span></h1>
              <p class="text text-center" style="max-width: 700px; margin: 1.5rem auto;">Underwings Technologies is a UAE-based cybersecurity company delivering comprehensive security solutions — from enterprise software sales to hands-on security services.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Do -->
    <section class="section bg-color-dark">
      <div class="container">
        <div class="section-wrapper-vertical">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <h2 class="heading">What We Do</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">We bridge the gap between security products and effective protection. Not just vendors — partners in your security journey.</p>
              </div>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-top: 3rem;">
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">01</span> Security Software</h3>
              <p class="text-medium color-grey">We partner with leading vendors to deliver enterprise security solutions. Every sale includes implementation, training, and ongoing support.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">02</span> VAPT Services</h3>
              <p class="text-medium color-grey">Hands-on penetration testing and vulnerability assessments that find real risks — not just automated scan results.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">03</span> ISO 27001</h3>
              <p class="text-medium color-grey">End-to-end ISO 27001 implementation. From gap assessment to certification — we guide you through the entire journey.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">04</span> Security Training</h3>
              <p class="text-medium color-grey">Transform employees from security risks into security assets with engaging awareness training and phishing simulations.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Approach -->
    <section class="section">
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Our Philosophy</div>
          </div>
          <h2 class="heading heading-center">How We <span class="text-gradient-clip bg-color-green-gradient">Work</span></h2>
          <div style="max-width: 800px; margin: 3rem auto; text-align: left;">
            <div style="margin-bottom: 2rem; padding: 1.5rem; border-left: 2px solid var(--colors--green-light-gradient);">
              <h3 class="heading-small" style="margin-bottom: 0.5rem;">Honest Advice</h3>
              <p class="text-medium color-grey">We recommend what fits your needs, not what has the highest margin. If you don't need something, we'll tell you.</p>
            </div>
            <div style="margin-bottom: 2rem; padding: 1.5rem; border-left: 2px solid var(--colors--green-light-gradient);">
              <h3 class="heading-small" style="margin-bottom: 0.5rem;">Practical Security</h3>
              <p class="text-medium color-grey">Security that works in the real world. We focus on risk reduction, not checkbox compliance or security theater.</p>
            </div>
            <div style="margin-bottom: 2rem; padding: 1.5rem; border-left: 2px solid var(--colors--green-light-gradient);">
              <h3 class="heading-small" style="margin-bottom: 0.5rem;">Long-Term Partnership</h3>
              <p class="text-medium color-grey">We're not here for one-time sales. We build relationships and support our clients through their security evolution.</p>
            </div>
            <div style="padding: 1.5rem; border-left: 2px solid var(--colors--green-light-gradient);">
              <h3 class="heading-small" style="margin-bottom: 0.5rem;">Local Expertise</h3>
              <p class="text-medium color-grey">Based in UAE, we understand regional regulations, business culture, and the specific threats facing organizations in the Middle East.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="section bg-color-dark">
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Get in <span class="text-gradient-clip bg-color-green-gradient">Touch</span></h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 3rem; text-align: center;">
            <div style="padding: 2rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-small color-grey" style="margin-bottom: 0.5rem;">Email</p>
              <p class="text-medium">contact@underwings.org</p>
            </div>
            <div style="padding: 2rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-small color-grey" style="margin-bottom: 0.5rem;">Phone</p>
              <p class="text-medium">+971 547078203</p>
            </div>
            <div style="padding: 2rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-small color-grey" style="margin-bottom: 0.5rem;">Location</p>
              <p class="text-medium">Headquartered in UAE</p>
            </div>
          </div>
          <div style="margin-top: 3rem; text-align: center;">
            <div class="button" style="display: inline-block;">
              <a href="/#contact" class="button-hidden w-button">Contact Form</a>
              <div class="button-wrapper">
                <div class="button-text">Send Us a Message</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterRedesigned />
</Layout>
