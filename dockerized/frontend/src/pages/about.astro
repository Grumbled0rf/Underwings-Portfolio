---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PartnerLogos from '../components/PartnerLogos.astro';
---

<Layout
  title="About Underwings - Cybersecurity Company India & UAE"
  description="Underwings Technologies is a cybersecurity company operating from India and UAE, providing security software sales, VAPT services, ISO 27001 implementation, and security training."
  keywords="Underwings Technologies, cybersecurity company India, cybersecurity UAE, security consulting Dubai, about Underwings"
  wfPage="about-page"
  schema={null}
>
  <Header currentPage="about" />

  <main id="main" class="main">

    <!-- ============ HERO ============ -->
    <section class="section top-padding-small bottom-padding-medium">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">About Underwings</div>
              </div>
              <h1 class="heading-large hero-heading-large">Young Team, <span class="text-gradient-clip bg-color-green-gradient">Serious Security</span></h1>
              <p class="text text-center" style="max-width: 680px; margin: 1.5rem auto 0; text-align: center;">We're a team of certified security professionals building the cybersecurity partner we wish existed — one that leads with honesty, delivers real results, and grows alongside your business.</p>
            </div>
          </div>
        </div>

        <!-- Stats Bar -->
        <div class="about-stats">
          <div class="about-stat">
            <span class="about-stat-number">India & UAE</span>
            <span class="about-stat-label">Operating From</span>
          </div>
          <div class="about-stat-divider"></div>
          <div class="about-stat">
            <span class="about-stat-number">10+</span>
            <span class="about-stat-label">Certifications Held</span>
          </div>
          <div class="about-stat-divider"></div>
          <div class="about-stat">
            <span class="about-stat-number">OSCP</span>
            <span class="about-stat-label">CPTS &bull; CEH &bull; CDSA</span>
          </div>
          <div class="about-stat-divider"></div>
          <div class="about-stat">
            <span class="about-stat-number">24h</span>
            <span class="about-stat-label">Response Time</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ OUR STORY / MISSION ============ -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="about-story">
          <div class="about-story-left">
            <div class="label" style="margin-bottom: 0.75rem;">
              <div class="text-small color-grey">Our Story</div>
            </div>
            <h2 class="heading">Why We <span class="text-gradient-clip bg-color-green-gradient">Started</span></h2>
          </div>
          <div class="about-story-right">
            <p class="text-medium" style="margin-bottom: 1.5rem;">We started Underwings because we kept seeing the same problem — businesses buying security tools they didn't need, or getting generic advice that didn't fit their actual risks. The gap between what's sold and what actually protects is wide.</p>
            <p class="text-medium" style="margin-bottom: 1.5rem;">So we built something different. A small, focused team of certified security professionals who lead with understanding before recommending. We don't push products — we solve problems. Whether it's a penetration test, ISO 27001 certification, or the right security software, we start by listening.</p>
            <p class="text-medium color-grey">We operate from India and the UAE, working with businesses that want security done right — practical, affordable, and built around real risks, not vendor hype.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ HOW WE WORK ============ -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 3rem;">
          <div class="label" style="margin-bottom: 0.75rem;">
            <div class="text-small color-grey">Our Philosophy</div>
          </div>
          <h2 class="heading heading-center">How We <span class="text-gradient-clip bg-color-green-gradient">Work</span></h2>
        </div>
        <div class="about-values-grid">
          <div class="about-value-card">
            <div class="about-value-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4v8l5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M4 14h2M22 14h2M14 4V2M14 24v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Honest Advice</h3>
            <p class="text-medium color-grey">We recommend what fits your needs, not what has the highest margin. If you don't need something, we'll tell you.</p>
          </div>
          <div class="about-value-card">
            <div class="about-value-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3l3 6 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Practical Security</h3>
            <p class="text-medium color-grey">Security that works in the real world. We focus on risk reduction, not checkbox compliance or security theater.</p>
          </div>
          <div class="about-value-card">
            <div class="about-value-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M7 20c0-4 3-5 7-5s7 1 7 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="3" width="22" height="22" rx="4" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Long-Term Partnership</h3>
            <p class="text-medium color-grey">We're not here for one-time sales. We build relationships and support our clients through their security evolution.</p>
          </div>
          <div class="about-value-card">
            <div class="about-value-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 25s-9-5.5-9-13V6l9-3 9 3v6c0 7.5-9 13-9 13z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 14l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Regional Presence</h3>
            <p class="text-medium color-grey">Operating from India and the UAE, we understand the compliance landscape, business culture, and threat environment across both regions.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ TEAM ============ -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 3rem;">
          <div class="label" style="margin-bottom: 0.75rem;">
            <div class="text-small color-grey">Our Team</div>
          </div>
          <h2 class="heading heading-center">The Experts Behind <span class="text-gradient-clip bg-color-green-gradient">Your Security</span></h2>
          <p class="text-medium" style="max-width: 600px; margin: 1rem auto 0; color: rgba(255,255,255,0.5); text-align: center;">Certified professionals with deep expertise in offensive security, compliance, infrastructure, and development.</p>
        </div>
        <div class="about-team-grid">

          <div class="about-team-card">
            <div class="about-team-avatar">MP</div>
            <div class="about-team-name">Manoj Prabhakaran</div>
            <div class="about-team-role">Founder</div>
            <div class="about-team-exp">5+ Years in Cybersecurity</div>
            <p class="about-team-desc">Cybersecurity consultant leading Underwings' mission to deliver honest, effective security solutions. Specializes in penetration testing, compliance strategy, and cloud security architecture.</p>
            <div class="about-team-certs">
              <span class="about-team-cert">CPTS</span>
              <span class="about-team-cert">CDSA</span>
              <span class="about-team-cert">Security+</span>
              <span class="about-team-cert">Azure Cloud Security</span>
              <span class="about-team-cert">ISO 27001 Lead Auditor</span>
              <span class="about-team-cert">HTB Omniscient</span>
            </div>
          </div>

          <div class="about-team-card">
            <div class="about-team-avatar">ND</div>
            <div class="about-team-name">Nelson Durairaj</div>
            <div class="about-team-role">Senior Penetration Tester</div>
            <div class="about-team-exp">5+ Years in Offensive Security</div>
            <p class="about-team-desc">Offensive security specialist focused on uncovering real-world vulnerabilities across networks, web applications, and infrastructure. Proven track record on HackTheBox.</p>
            <div class="about-team-certs">
              <span class="about-team-cert">OSCP</span>
              <span class="about-team-cert">eJPT</span>
              <span class="about-team-cert">CEH</span>
              <span class="about-team-cert">BlackHat Linux</span>
              <span class="about-team-cert">HTB Omniscient</span>
            </div>
          </div>

          <div class="about-team-card">
            <div class="about-team-avatar">S</div>
            <div class="about-team-name">Sivaraj</div>
            <div class="about-team-role">Chief Technology Officer</div>
            <div class="about-team-exp">15+ Years in IT Infrastructure</div>
            <p class="about-team-desc">Seasoned IT infrastructure leader with deep expertise in enterprise networking, systems architecture, and technology operations. Ensures robust, scalable solutions for every client.</p>
            <div class="about-team-certs">
              <span class="about-team-cert">CCNA</span>
              <span class="about-team-cert">CCNP</span>
              <span class="about-team-cert">Microsoft Certified</span>
            </div>
          </div>

          <div class="about-team-card">
            <div class="about-team-avatar">G</div>
            <div class="about-team-name">Gowtham</div>
            <div class="about-team-role">Senior Developer</div>
            <div class="about-team-exp">8+ Years in Full Stack Development</div>
            <p class="about-team-desc">Full stack developer building secure, scalable web applications. Handles development, testing, and quality assurance across Underwings' products and client projects.</p>
            <div class="about-team-certs">
              <span class="about-team-cert">Full Stack</span>
              <span class="about-team-cert">QA & Testing</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============ PARTNERS ============ -->
    <section class="section bottom-padding-medium">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 2.5rem;">
          <div class="label" style="margin-bottom: 0.75rem;">
            <div class="text-small color-grey">Our Partners</div>
          </div>
          <h2 class="heading heading-center">Trusted Technology <span class="text-gradient-clip bg-color-green-gradient">Partners</span></h2>
          <p class="text-medium" style="max-width: 550px; margin: 1rem auto 0; color: rgba(255,255,255,0.5); text-align: center;">We work with industry-leading vendors to deliver best-in-class security solutions.</p>
        </div>
        <div style="display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 2.5rem; max-width: 900px; margin: 0 auto;">
          <PartnerLogos size="small" linkTo="/software" />
        </div>
      </div>
    </section>

    <!-- ============ CTA / CONTACT ============ -->
    <section class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 3rem;">
          <h2 class="heading heading-center">Ready to Secure <span class="text-gradient-clip bg-color-green-gradient">Your Business?</span></h2>
          <p class="text-medium" style="max-width: 550px; margin: 1rem auto 0; color: rgba(255,255,255,0.5); text-align: center;">Let's talk about your security needs. Reach out directly or use our contact form — we respond within 24 hours.</p>
        </div>

        <div class="about-contact-grid">
          <a href="mailto:contact@underwings.org" class="about-contact-card">
            <div class="about-contact-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="about-contact-label">Email</div>
            <div class="about-contact-value">contact@underwings.org</div>
          </a>
          <a href="tel:+971547078203" class="about-contact-card">
            <div class="about-contact-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="about-contact-label">Phone</div>
            <div class="about-contact-value">+971 547078203</div>
          </a>
          <div class="about-contact-card">
            <div class="about-contact-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <div class="about-contact-label">Location</div>
            <div class="about-contact-value">India & UAE</div>
          </div>
        </div>

        <div style="margin-top: 3rem; text-align: center;">
          <div class="button" style="display: inline-block;">
            <a href="/#contact" class="button-hidden w-button">Contact Form</a>
            <div class="button-wrapper">
              <div class="button-text">Start a Conversation</div>
            </div>
            <div class="button-accent-gradinet"></div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:inline>
  /* ---- Label fix ---- */
  #main .label {
    display: inline-block;
  }

  /* ---- Heading constraint ---- */
  #main .heading.heading-center {
    text-align: center;
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ---- Stats Bar ---- */
  .about-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    margin-top: 3.5rem;
    padding: 2rem 2.5rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
  }
  .about-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .about-stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, #24d758, #27dab4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    white-space: nowrap;
  }
  .about-stat-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .about-stat-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(255,255,255,0.1);
  }

  /* ---- Story / Mission ---- */
  .about-story {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
    max-width: 960px;
    margin: 0 auto;
  }
  .about-story-left .heading {
    margin-top: 0.5rem;
  }
  .about-story-right .text-medium {
    line-height: 1.7;
  }

  /* ---- Values Grid ---- */
  .about-values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .about-value-card {
    padding: 2rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .about-value-card:hover {
    border-color: rgba(36,215,88,0.25);
    background: rgba(255,255,255,0.05);
  }
  .about-value-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #24d758;
    margin-bottom: 1.25rem;
    background: rgba(36,215,88,0.08);
    border-radius: 10px;
  }

  /* ---- Team Grid ---- */
  .about-team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .about-team-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
  }
  .about-team-card:hover {
    border-color: rgba(36,215,88,0.3);
    background: rgba(255,255,255,0.05);
    transform: translateY(-4px);
  }
  .about-team-avatar {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(36,215,88,0.15), rgba(39,218,180,0.15));
    border: 2px solid rgba(36,215,88,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    font-size: 1.35rem;
    font-weight: 600;
    color: #24d758;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .about-team-card:hover .about-team-avatar {
    border-color: #24d758;
    box-shadow: 0 0 20px rgba(36,215,88,0.2);
  }
  .about-team-name {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.25rem;
  }
  .about-team-role {
    font-size: 0.8rem;
    font-weight: 500;
    color: #24d758;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.5rem;
  }
  .about-team-exp {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1rem;
  }
  .about-team-desc {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    max-width: 340px;
  }
  .about-team-certs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    margin-top: auto;
  }
  .about-team-cert {
    font-size: 0.675rem;
    padding: 0.25rem 0.6rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.3px;
  }

  /* ---- Contact Grid ---- */
  .about-contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .about-contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 2rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  a.about-contact-card:hover {
    border-color: rgba(36,215,88,0.3);
    background: rgba(255,255,255,0.05);
  }
  .about-contact-icon {
    color: #24d758;
    margin-bottom: 1rem;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(36,215,88,0.08);
    border-radius: 50%;
  }
  .about-contact-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.45);
    margin-bottom: 0.5rem;
  }
  .about-contact-value {
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
  }
  a.about-contact-card:hover .about-contact-value {
    color: #24d758;
  }

  /* ---- Responsive ---- */
  @media (max-width: 991px) {
    .about-story {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .about-team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .about-stats {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
    .about-stat-divider {
      display: none;
    }
    .about-stat {
      min-width: 120px;
    }
    .about-values-grid {
      grid-template-columns: 1fr;
    }
    .about-contact-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 479px) {
    .about-team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Stagger entrance animation for cards
  (function() {
    if (typeof IntersectionObserver === 'undefined') return;
    var cards = document.querySelectorAll('.about-value-card, .about-team-card, .about-contact-card, .about-stat');
    cards.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var parent = entry.target.parentElement;
          var siblings = parent ? Array.from(parent.children).filter(function(c) { return c.style.opacity === '0'; }) : [];
          var idx = siblings.indexOf(entry.target);
          setTimeout(function() {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }, Math.max(0, idx) * 100);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    cards.forEach(function(el) { observer.observe(el); });
  })();
</script>
