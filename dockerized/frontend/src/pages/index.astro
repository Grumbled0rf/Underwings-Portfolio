---
// ===========================================
// HOMEPAGE
// Underwings Cybersecurity Solutions
// ===========================================
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PartnerLogos from '../components/PartnerLogos.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://underwings.org";

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Underwings Cybersecurity Solutions",
    "url": siteUrl,
    "logo": `${siteUrl}/images/logowhiteUW.png`,
    "description": "Cybersecurity startup offering security software sales, VAPT services, ISO 27001 implementation, and security awareness training in India & UAE.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AE",
      "addressRegion": "Dubai"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+971-547078203",
      "email": "contact@underwings.org",
      "contactType": "sales"
    },
    "sameAs": [
      "https://www.linkedin.com/company/underwings-technologies"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Cybersecurity Services",
    "provider": {
      "@type": "Organization",
      "name": "Underwings Cybersecurity Solutions"
    },
    "areaServed": {
      "@type": "Country",
      "name": "United Arab Emirates"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Cybersecurity Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Vulnerability Assessment & Penetration Testing (VAPT)" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ISO 27001 Implementation & Certification" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cybersecurity Awareness Training" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Security Software Sales & Implementation" } }
      ]
    }
  }
];
---

<Layout
  title="Underwings – Cybersecurity Solutions | India & UAE"
  description="Cybersecurity startup in India & UAE. OSCP+ & CPTS certified VAPT, ISO 27001 implementation, security awareness training, and software sales with hands-on support."
  keywords="cybersecurity startup India, cybersecurity UAE, VAPT services Dubai, ISO 27001 implementation, security software sales, penetration testing, cybersecurity training, OSCP penetration testing, compliance services UAE"
  wfPage="6920627afaad5c7afb54bfa8"
  schema={schemas}
>
  <Fragment slot="head">
    <style is:inline>
