      // Render Turnstile widget if site key is configured
      if (window.__TURNSTILE_SITE_KEY && typeof turnstile !== 'undefined') {
        turnstile.render('#ctf-turnstile', {
          sitekey: window.__TURNSTILE_SITE_KEY,
          theme: 'dark',
        });
      } else if (window.__TURNSTILE_SITE_KEY) {
        // Turnstile script may not be loaded yet, wait for it
        document.addEventListener('DOMContentLoaded', function() {
          if (typeof turnstile !== 'undefined') {
            turnstile.render('#ctf-turnstile', {
              sitekey: window.__TURNSTILE_SITE_KEY,
              theme: 'dark',
            });
          }
        });
      }

      // HubSpot Forms API Integration (proxied through server)

      var form = document.getElementById('contact-form');
      if (!form) return;

      form.addEventListener('submit', function(e) {
        e.preventDefault();

        // Honeypot
        if (form.querySelector('[name="website"]').value) return;

        // Validate required fields and set aria-invalid
        var requiredFields = form.querySelectorAll('[required]');
        var hasError = false;
        requiredFields.forEach(function(field) {
          if (!field.value || (field.type === 'checkbox' && !field.checked)) {
            field.setAttribute('aria-invalid', 'true');
            hasError = true;
          } else {
            field.setAttribute('aria-invalid', 'false');
          }
        });
        if (hasError) return;

        var submitBtn = form.querySelector('.ctf-submit');
        var textEl = submitBtn.querySelector('.ctf-submit-text');
        var loadEl = submitBtn.querySelector('.ctf-submit-loading');
        var arrowEl = submitBtn.querySelector('.ctf-submit-arrow');
        textEl.style.display = 'none';
        arrowEl.style.display = 'none';
        loadEl.style.display = 'inline-flex';
        submitBtn.disabled = true;

        var fullName = form.querySelector('#ctf-name').value.trim();
        var nameParts = fullName.split(' ');
        var firstName = nameParts[0] || '';
        var lastName = nameParts.slice(1).join(' ') || '';

        // Include Turnstile token if available
        var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
        var turnstileToken = turnstileInput ? turnstileInput.value : '';

        var payload = {
          fields: [
            { name: 'firstname', value: firstName },
            { name: 'lastname', value: lastName },
            { name: '0-2/name', value: fullName },
            { name: 'company', value: form.querySelector('#ctf-company').value },
            { name: 'email', value: form.querySelector('#ctf-email').value },
            { name: 'phone', value: form.querySelector('#ctf-phone').value },
            { name: 'what_can_we_help_with_', value: form.querySelector('#ctf-service').value },
            { name: 'message', value: form.querySelector('#ctf-message').value }
          ],
          'cf-turnstile-response': turnstileToken,
          context: Object.assign(
            { pageUri: window.location.href, pageName: document.title },
            (function() { var m = document.cookie.match(/hubspotutk=([^;]+)/); return m ? { hutk: m[1] } : {}; })()
          ),
          legalConsentOptions: {
            consent: {
              consentToProcess: true,
              text: 'I agree to allow Underwings Cybersecurity Solutions to store and process my personal data.'
            }
          }
        };

        fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function(res) {
          return res.text().then(function(body) {
            console.log('HubSpot response:', res.status, body);
            if (res.ok) {
              form.style.display = 'none';
              form.parentElement.querySelector('.ctf-success').style.display = 'flex';
            } else {
              throw new Error('Status ' + res.status + ': ' + body);
            }
          });
        })
        .catch(function(err) {
          console.error('Form submit error:', err);
          form.parentElement.querySelector('.ctf-error').style.display = 'block';
        })
        .finally(function() {
          textEl.style.display = '';
          arrowEl.style.display = '';
          loadEl.style.display = 'none';
          submitBtn.disabled = false;
        });
      });
    })();
    </script>

    <!-- Timezone-aware response indicator -->
    <script is:inline nonce={Astro.locals.nonce || ""}>
    (function() {
      var el = document.getElementById('ctf-response-text');
      var dot = document.querySelector('.ctf-response-dot');
      if (!el || !dot) return;

      var now = new Date();
      // India: UTC+5:30, UAE: UTC+4 — business hours roughly 9-18 IST (3:30-12:30 UTC)
      var utcHour = now.getUTCHours();
      var utcMin = now.getUTCMinutes();
      var istHour = utcHour + 5 + (utcMin >= 30 ? 1 : 0);
      var uaeHour = utcHour + 4;
      var day = now.getUTCDay();
      var isWeekend = day === 0 || day === 6;
      var isIndiaHours = istHour >= 9 && istHour < 18;
      var isUaeHours = uaeHour >= 9 && uaeHour < 18;

      if (isWeekend) {
        el.textContent = 'Weekend — we\'ll respond by Monday morning (India/UAE time)';
        dot.classList.add('offline');
      } else if (isIndiaHours || isUaeHours) {
        var tz = isUaeHours ? 'UAE' : 'India';
        el.textContent = 'Our ' + tz + ' team is online — expect a reply within a few hours';
      } else {
        el.textContent = 'Our team is currently offline — we\'ll respond within 24 hours';
        dot.classList.add('offline');
      }
    })();
    </script>
  </main>

  <Footer />
</Layout>
