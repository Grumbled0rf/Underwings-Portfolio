---
// ===========================================
// HOMEPAGE
// Underwings Technologies
// ===========================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PentestDiagram from '../components/PentestDiagram.astro';
import PartnerLogos from '../components/PartnerLogos.astro';
import { getBlogPosts } from '../lib/supabase';

const recentPosts = await getBlogPosts(3);
const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://underwings.org";

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Underwings Technologies",
    "url": siteUrl,
    "logo": `${siteUrl}/images/logowhiteUW.png`,
    "description": "Enterprise cybersecurity solutions provider offering security software sales, VAPT services, ISO 27001 implementation, and security awareness training.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AE",
      "addressRegion": "Dubai"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+971-547078203",
      "email": "contact@underwings.org",
      "contactType": "sales"
    },
    "sameAs": [
      "https://www.linkedin.com/company/underwings-technologies"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Cybersecurity Services",
    "provider": {
      "@type": "Organization",
      "name": "Underwings Technologies"
    },
    "areaServed": {
      "@type": "Country",
      "name": "United Arab Emirates"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Cybersecurity Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Vulnerability Assessment & Penetration Testing (VAPT)" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "ISO 27001 Implementation & Certification" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cybersecurity Awareness Training" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Security Software Sales & Implementation" } }
      ]
    }
  }
];
---

<Layout
  title="Underwings – Cybersecurity Solutions & Software Sales"
  description="Underwings provides comprehensive cybersecurity services including VAPT, ISO 27001 implementation, security awareness training, and enterprise security software sales with implementation, support, and training."
  keywords="cybersecurity UAE, VAPT services Dubai, ISO 27001 implementation, security software sales, penetration testing UAE, cybersecurity training, Pitstack, security awareness training, compliance services UAE"
  wfPage="6920627afaad5c7afb54bfa8"
  schema={schemas}
>
  <Fragment slot="head">
    <style is:inline>
