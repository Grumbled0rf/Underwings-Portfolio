        width: 1px;
        height: 100%;
        inset: 0% 0% 0% auto;
      }
      .cube-rib-light.cube-rib-right.cube-rib-right-topper {
        height: 7%;
        top: 100%;
        bottom: auto;
      }
      .cube-rib-light.cube-rib-left {
