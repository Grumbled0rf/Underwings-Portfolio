      <div class="container">
        <div class="section-grid-wrapper">
          <div id="w-node-_35d33ae6-e2a1-4340-2cb1-58ad3d2196ef-fb54bfa8" class="heading-grid heading-grid-middle">
            <div class="heading-grid-inner heading-grid-inner-medium">
              <div data-w-id="35d33ae6-e2a1-4340-2cb1-58ad3d2196f1" style="filter:blur(3px);opacity:0" class="label label-white">
                <div class="text-small">Contact</div>
              </div>
              <h2 data-w-id="35d33ae6-e2a1-4340-2cb1-58ad3d2196f4" style="filter:blur(3px);opacity:0" class="heading">Ready to strengthen your security?</h2>
              <p data-w-id="34b857a7-c01d-957b-e744-fd0e8835e124" style="filter:blur(3px);opacity:0" class="text">Tell us about your needs — whether it&#x27;s security software, VAPT services, ISO 27001 implementation, or security training. We&#x27;ll get back to you within 24 hours with a clear next step.</p>
            </div>
          </div>
          <div id="w-node-_35d33ae6-e2a1-4340-2cb1-58ad3d2196f6-fb54bfa8" class="content-grid content-grid-middle">
            <div class="form-content">
              <div class="form-box">
                <div class="form-block w-form">
                  <form id="contact-form" name="contact-form" data-name="Contact Form" method="post" class="form" data-wf-page-id="6920627afaad5c7afb54bfa8" data-wf-element-id="ce358e6b-f124-3fb3-3659-c0853c165cbb">
                    <p data-w-id="7bbce9c1-f69b-265f-9d15-5e2e550cd851" style="filter:blur(3px);opacity:0" class="text-medium text-desktop-right">* required fields</p>
                    <div class="form-fields-grid">
                      <div class="form-field-box"><label for="full-name" class="form-field-label">Full Name *</label><input class="form-field w-input" maxlength="256" name="full-name" data-name="Full Name" placeholder="Your name" type="text" id="full-name" required="">
                        <div class="form-neon-line-box"></div>
                      </div>
                      <div class="form-field-box"><label for="company" class="form-field-label">Company *</label><input class="form-field w-input" maxlength="256" name="company" data-name="Company" placeholder="Company name" type="text" id="company" required="">
                        <div class="form-neon-line-box"></div>
                      </div>
                    </div>
                    <div class="form-fields-grid">
                      <div class="form-field-box"><label for="email" class="form-field-label">Work Email *</label><input class="form-field w-input" maxlength="256" name="email" data-name="Email" placeholder="you@company.com" type="email" id="email" required="">
                        <div class="form-neon-line-box"></div>
                      </div>
                      <div class="form-field-box"><label for="phone" class="form-field-label">Phone</label><input class="form-field w-input" maxlength="256" name="phone" data-name="Phone" placeholder="+971 XXX XXXXXX" type="tel" id="phone">
                        <div class="form-neon-line-box"></div>
                      </div>
                    </div>
                    <div class="form-field-box"><label for="service" class="form-field-label">What can we help with? *</label>
                      <select class="form-field w-input" name="service" data-name="Service" id="service" required="" style="background-color: transparent; color: inherit; cursor: pointer;">
                        <option value="" disabled selected>Select a service</option>
                        <option value="security-software">Security Software Solutions</option>
                        <option value="vapt">Penetration Testing (VAPT)</option>
                        <option value="iso-27001">ISO 27001 Implementation</option>
                        <option value="training">Security Awareness Training</option>
                        <option value="pitstack">Pitstack Platform</option>
                        <option value="multiple">Multiple Services</option>
                        <option value="other">Other / General Inquiry</option>
                      </select>
                      <div class="form-neon-line-box"></div>
                    </div>
                    <div class="form-field-box"><label for="message" class="form-field-label">Tell us about your project *</label>
                      <textarea class="form-field w-input" maxlength="5000" name="message" data-name="Message" placeholder="Brief description of your security needs, timeline, or any questions..." id="message" required="" style="min-height: 120px; resize: vertical;"></textarea>
                      <div class="form-neon-line-box"></div>
                    </div>
                    <div data-w-id="c6e8bdce-8c8f-fd8f-a5c8-1f0a81ab7a4a" style="filter:blur(3px);opacity:0" class="button"><input type="submit" data-wait="Sending..." class="button-hidden w-button" value="Submit">
                      <div class="button-wrapper">
                        <div class="button-text color-white">Send Message</div>
                      </div>
                      <div class="button-accent-gradinet"></div>
                    </div>
                    <div style="position:absolute;left:-9999px;"><label for="website">Website</label><input type="text" name="website" id="website" tabindex="-1" autocomplete="off"></div>
                    <p class="text-small color-grey" style="margin-top: 1rem; text-align: center;">We respond within 24 hours on business days.</p>
                  </form>
                  <script is:inline>
                  (function() {
                    // ==============================================
                    // HubSpot Forms API Integration
                    // TODO: Replace these with your actual HubSpot IDs
                    // Get Portal ID: HubSpot > Settings > Account > Account Defaults
                    // Get Form GUID: HubSpot > Marketing > Forms > Create form > copy GUID from URL
                    // ==============================================
                    var HUBSPOT_PORTAL_ID = 'YOUR_PORTAL_ID';
                    var HUBSPOT_FORM_GUID = 'YOUR_FORM_GUID';

                    var form = document.getElementById('contact-form');
                    if (!form) return;

                    form.addEventListener('submit', function(e) {
                      e.preventDefault();

                      // Honeypot check
                      if (form.querySelector('[name="website"]').value) return;

                      var btn = form.querySelector('input[type="submit"]');
                      var origVal = btn.value;
                      btn.value = 'Sending...';
                      btn.disabled = true;

                      var data = {
                        fields: [
                          { name: 'firstname', value: form.querySelector('#full-name').value },
                          { name: 'company', value: form.querySelector('#company').value },
                          { name: 'email', value: form.querySelector('#email').value },
                          { name: 'phone', value: form.querySelector('#phone').value },
                          { name: 'service_interest', value: form.querySelector('#service').value },
                          { name: 'message', value: form.querySelector('#message').value }
                        ],
                        context: {
                          pageUri: window.location.href,
                          pageName: document.title
                        }
                      };

                      var url = 'https://api.hsforms.com/submissions/v3/integration/submit/' + HUBSPOT_PORTAL_ID + '/' + HUBSPOT_FORM_GUID;

                      fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                      })
                      .then(function(res) {
                        if (res.ok || res.status === 200) {
                          form.style.display = 'none';
                          form.parentElement.querySelector('.w-form-done').style.display = 'block';
                        } else {
                          throw new Error('Submission failed');
                        }
                      })
                      .catch(function() {
                        form.parentElement.querySelector('.w-form-fail').style.display = 'block';
                      })
                      .finally(function() {
                        btn.value = origVal;
                        btn.disabled = false;
                      });
                    });
                  })();
                  </script>
                  <div class="form-message w-form-done">
                    <div><strong>Thank you for reaching out.</strong><br>We've received your inquiry and will get back to you within 24 hours.</div>
                  </div>
                  <div class="error-message w-form-fail">
                    <div>Something went wrong. Please try again or email us directly at <a href="mailto:contact@underwings.org" style="color: var(--colors--green-light-gradient);">contact@underwings.org</a></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
