    <script is:inline nonce={Astro.locals.nonce || ""}>
      (function() {
        var section = document.getElementById('about-us');
        if (!section) return;
        var cubes = section.querySelectorAll('.motion-cube-col');
        var animEls = section.querySelectorAll('.about-anim');
        var neonParent = section.querySelector('.about-neon-parent');

        // Cubes animation
        var cubeObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              cubes.forEach(function(col) { col.classList.add('cube-visible'); });
            } else {
              cubes.forEach(function(col) { col.classList.remove('cube-visible'); });
            }
          });
        }, { threshold: 0.2 });
        var motionCubes = section.querySelector('.motion-cubes');
        if (motionCubes) cubeObserver.observe(motionCubes);

        // Text + neon line animation with stagger
        var textObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var delay = 0;
              animEls.forEach(function(el) {
                setTimeout(function() { el.classList.add('anim-visible'); }, delay);
                delay += 200;
              });
              if (neonParent) {
                setTimeout(function() { neonParent.classList.add('anim-visible'); }, 300);
              }
            }
          });
        }, { threshold: 0.1 });
        textObserver.observe(section.querySelector('.vertical-heading-top'));
      })();
    </script>
