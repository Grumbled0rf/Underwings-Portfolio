---
// ===========================================
// SOFTWARE SALES PAGE
// Underwings Technologies
// ===========================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PartnerLogos from '../components/PartnerLogos.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Enterprise Cybersecurity Software Sales",
  "provider": {
    "@type": "Organization",
    "name": "Underwings Technologies",
    "url": "https://underwings.org"
  },
  "description": "Enterprise cybersecurity software sales with full implementation, training, and ongoing support. Endpoint protection, SIEM, email security, network security and more.",
  "areaServed": ["IN", "AE"],
  "serviceType": "Cybersecurity Software Sales & Implementation"
};
---

<Layout
  title="Cybersecurity Software Sales | Underwings"
  description="Enterprise cybersecurity software sales with full implementation, training, and support. Endpoint protection, SIEM, email security, and more from leading vendors."
  keywords="cybersecurity software, security software sales, endpoint protection, SIEM solutions, email security, firewall solutions, security software implementation, Sophos, Fortinet, ManageEngine"
  wfPage="software-page"
  schema={serviceSchema}
  bodyClass="body"
>

  <Header currentPage="software" />

  <main id="main" class="main">

    <!-- ============ HERO ============ -->
    <section class="section top-padding-small bottom-padding-medium">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="sw-label">
                <div class="text-small color-grey">Software Sales</div>
              </div>
              <h1 class="heading-large hero-heading-large">The Right Security Tools, <span class="text-gradient-clip bg-color-green-gradient">Properly Deployed</span></h1>
              <p class="text" style="max-width: 680px; margin: 1.5rem auto 0; text-align: center;">We don't just sell licenses — we assess your environment, recommend the right fit, deploy it properly, train your team, and support you long after the sale.</p>
              <div style="margin-top: 2rem; text-align: center;">
                <div class="button" style="display: inline-block;">
                  <a href="/#contact" class="button-hidden w-button">Request Quote</a>
                  <div class="button-wrapper">
                    <div class="button-text">Request a Quote</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PARTNER LOGOS ============ -->
    <section class="section top-padding-small bottom-padding-small" style="background: linear-gradient(180deg, rgba(17,17,17,0) 0%, rgba(36,215,88,0.03) 50%, rgba(17,17,17,0) 100%);">
      <div class="container">
        <div style="text-align: center;">
          <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 2.5rem;">Our Technology Partners</p>
          <div style="display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 3rem;">
            <PartnerLogos size="large" linkTo="/software" />
          </div>
        </div>
      </div>
    </section>

    <!-- ============ WHY BUY THROUGH US ============ -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 3rem;">
          <div class="sw-label">
            <div class="text-small color-grey">Why Underwings</div>
          </div>
          <h2 class="heading heading-center" style="margin-top: 0.75rem;">More Than Just a <span class="text-gradient-clip bg-color-green-gradient">Reseller</span></h2>
        </div>
        <div class="sw-benefits-grid">
          <div class="sw-benefit-card">
            <div class="sw-benefit-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3v22M3 14h22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="6" y="6" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Expert Deployment</h3>
            <p class="text-medium color-grey">Proper configuration, integration with your infrastructure, and hardening from day one. No shelfware — every tool works as intended.</p>
          </div>
          <div class="sw-benefit-card">
            <div class="sw-benefit-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M7 20c0-4 3-5 7-5s7 1 7 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M22 10c2 1 3 3 3 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="22" cy="7" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Team Training</h3>
            <p class="text-medium color-grey">Hands-on sessions for your IT and security teams. We make sure your staff can effectively operate and manage every tool.</p>
          </div>
          <div class="sw-benefit-card">
            <div class="sw-benefit-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 25s-9-5.5-9-13V6l9-3 9 3v6c0 7.5-9 13-9 13z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 14l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Ongoing Support</h3>
            <p class="text-medium color-grey">Local, responsive support whenever you need it. We're your first point of contact — faster than going vendor-direct.</p>
          </div>
          <div class="sw-benefit-card">
            <div class="sw-benefit-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M14 8v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="heading-small" style="margin-bottom: 0.5rem;">Honest Guidance</h3>
            <p class="text-medium color-grey">We recommend what fits your needs and budget — not what pays us the most. If you don't need it, we'll tell you.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SOLUTION CATEGORIES ============ -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 3rem;">
          <div class="sw-label">
            <div class="text-small color-grey">Solutions</div>
          </div>
          <h2 class="heading heading-center" style="margin-top: 0.75rem;">Security Software <span class="text-gradient-clip bg-color-green-gradient">Categories</span></h2>
          <p class="text-medium" style="max-width: 580px; margin: 1rem auto 0; color: rgba(255,255,255,0.7); text-align: center;">Complete security stack from industry-leading vendors. Contact us for tailored recommendations.</p>
        </div>
        <div class="sw-cat-grid">

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><rect x="7" y="4" width="18" height="22" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M12 26h8M16 22v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="16" cy="13" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M13 17l3-2 3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="sw-cat-title">Endpoint Protection</h3>
            <p class="sw-cat-desc">EPP, EDR, and XDR solutions. Protect workstations, servers, and mobile devices with next-gen threat detection.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">Sophos</span>
              <span class="sw-vendor-tag">Fortinet</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><rect x="4" y="8" width="24" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M4 12h24M8 16h6M8 20h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="24" cy="18" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M24 16v2l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="sw-cat-title">SIEM & Analytics</h3>
            <p class="sw-cat-desc">Centralized log management, threat detection, correlation, and alerting for your security operations center.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">Securonix</span>
              <span class="sw-vendor-tag">Wazuh</span>
              <span class="sw-vendor-tag">ManageEngine</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><rect x="5" y="8" width="22" height="16" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M5 13h22" stroke="currentColor" stroke-width="1.5"/><path d="M10 18h5M10 21h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M22 17l-2 2 2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="sw-cat-title">Email Security</h3>
            <p class="sw-cat-desc">Advanced protection against phishing, BEC, malware, and spam. Secure your #1 attack vector with AI-powered detection.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">Sophos</span>
              <span class="sw-vendor-tag">Fortinet</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><rect x="4" y="6" width="10" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="18" y="6" width="10" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="18" width="10" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 14v2a2 2 0 002 2h1M23 14v2a2 2 0 01-2 2h-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3 class="sw-cat-title">Network Security</h3>
            <p class="sw-cat-desc">Next-gen firewalls, IDS/IPS, network access control, and secure web gateways. Perimeter and internal protection.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">Fortinet</span>
              <span class="sw-vendor-tag">Sophos</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M8 26c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M20 10l2-2M22 8l-1 3 3-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="sw-cat-title">Identity & Access</h3>
            <p class="sw-cat-desc">SSO, MFA, privileged access management, and identity governance. Control who accesses what, and when.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">ManageEngine</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><path d="M16 6c6 0 10 3 10 6v8c0 3-4 6-10 6S6 23 6 20v-8c0-3 4-6 10-6z" stroke="currentColor" stroke-width="1.5"/><path d="M6 12c0 3 4 6 10 6s10-3 10-6" stroke="currentColor" stroke-width="1.5"/><path d="M6 16c0 3 4 6 10 6s10-3 10-6" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <h3 class="sw-cat-title">Cloud Security</h3>
            <p class="sw-cat-desc">CASB, CSPM, workload protection, and cloud-native security for AWS, Azure, and GCP environments.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">Qualys</span>
              <span class="sw-vendor-tag">Rapid7</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M16 10v6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="16" cy="21" r="1.2" fill="currentColor"/></svg>
            </div>
            <h3 class="sw-cat-title">Vulnerability Management</h3>
            <p class="sw-cat-desc">Continuous scanning, prioritization, and remediation tracking. Know your attack surface and fix what matters.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">Qualys</span>
              <span class="sw-vendor-tag">Rapid7</span>
              <span class="sw-vendor-tag">Tenable</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><path d="M8 26V14l8-8 8 8v12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 16l12-12 12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 26v-6h6v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="sw-cat-title">Backup & Recovery</h3>
            <p class="sw-cat-desc">Ransomware-resistant backup and disaster recovery. Ensure business continuity when incidents strike.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">Sophos</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

          <a href="/#contact" class="sw-cat-card">
            <div class="sw-cat-icon-wrap">
              <svg class="sw-cat-icon" viewBox="0 0 32 32" fill="none"><rect x="6" y="4" width="20" height="24" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M11 10h10M11 14h10M11 18h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="22" cy="22" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M22 20v2l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="sw-cat-title">IT Operations & Monitoring</h3>
            <p class="sw-cat-desc">Unified endpoint management, IT service desk, network monitoring, and asset management under one roof.</p>
            <div class="sw-cat-vendors">
              <span class="sw-vendor-tag">ManageEngine</span>
              <span class="sw-vendor-tag">Teramind</span>
            </div>
            <span class="sw-cat-link">Get a quote <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </a>

        </div>
      </div>
    </section>

    <!-- ============ HOW IT WORKS ============ -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 3rem;">
          <div class="sw-label">
            <div class="text-small color-grey">Our Process</div>
          </div>
          <h2 class="heading heading-center" style="margin-top: 0.75rem;">How We <span class="text-gradient-clip bg-color-green-gradient">Deliver</span></h2>
        </div>
        <div class="sw-process-grid">
          <div class="sw-process-step">
            <div class="sw-process-num">01</div>
            <h3 class="sw-process-title">Assess</h3>
            <p class="sw-process-desc">We audit your current stack, understand your risks, compliance requirements, and budget constraints.</p>
          </div>
          <div class="sw-process-connector">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M14 7l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="sw-process-step">
            <div class="sw-process-num">02</div>
            <h3 class="sw-process-title">Recommend</h3>
            <p class="sw-process-desc">We shortlist the best-fit solutions from our vendor portfolio — no upselling, just what works for you.</p>
          </div>
          <div class="sw-process-connector">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M14 7l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="sw-process-step">
            <div class="sw-process-num">03</div>
            <h3 class="sw-process-title">Deploy</h3>
            <p class="sw-process-desc">Full implementation, configuration, integration with your infrastructure, and hands-on team training.</p>
          </div>
          <div class="sw-process-connector">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M14 7l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="sw-process-step">
            <div class="sw-process-num">04</div>
            <h3 class="sw-process-title">Support</h3>
            <p class="sw-process-desc">Ongoing local support, health checks, and optimization. We're your first call — not a vendor hotline.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center;">
          <h2 class="heading heading-center">Not Sure What You <span class="text-gradient-clip bg-color-green-gradient">Need?</span></h2>
          <p class="text-medium" style="max-width: 560px; margin: 1.25rem auto 0; color: rgba(255,255,255,0.7); text-align: center;">Tell us your challenges. We'll assess your environment and recommend the right tools — with a clear quote including implementation and training.</p>
          <div style="margin-top: 2.5rem;">
            <div class="button" style="display: inline-block;">
              <a href="/#contact" class="button-hidden w-button">Get Started</a>
              <div class="button-wrapper">
                <div class="button-text">Start a Conversation</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

</Layout>

<style is:inline>
  /* ---- Label fix ---- */
  #main .sw-label {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 5.625rem;
    padding: 0.625rem 1rem;
  }

  /* ---- Heading constraint ---- */
  #main .heading.heading-center {
    text-align: center;
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ---- Benefits Grid ---- */
  .sw-benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .sw-benefit-card {
    padding: 2rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .sw-benefit-card:hover {
    border-color: rgba(36,215,88,0.25);
    background: rgba(255,255,255,0.05);
  }
  .sw-benefit-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #24d758;
    margin-bottom: 1.25rem;
    background: rgba(36,215,88,0.08);
    border-radius: 10px;
  }

  /* ---- Categories Grid ---- */
  .sw-cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .sw-cat-card {
