---
// ===========================================
// SINGLE BLOG POST PAGE
// Dynamic routing by slug
// ===========================================
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getBlogPost, getBlogPosts } from '../../lib/supabase';
import DOMPurify from 'isomorphic-dompurify';
import { marked } from 'marked';

const { slug } = Astro.params;
const post = await getBlogPost(slug);

// If post not found, redirect to blog index
if (!post) {
  return Astro.redirect('/blog');
}

const formattedDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : '';

// Get related posts
const allPosts = await getBlogPosts(4);
const relatedPosts = allPosts.filter(p => p.id !== post.id).slice(0, 3);

// Convert markdown to sanitized HTML
function markdownToHtml(markdown) {
  if (!markdown) return '';
  return DOMPurify.sanitize(marked.parse(markdown));
}

// Estimate reading time
const wordCount = (post.content || '').split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 230));

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://underwings.org';
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.excerpt || post.meta_description || '',
  "image": post.featured_image ? `${siteUrl}${post.featured_image}` : undefined,
  "datePublished": post.published_at,
  "dateModified": post.updated_at || post.published_at,
  "author": {
    "@type": "Organization",
    "name": "Underwings Cybersecurity Solutions",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "Underwings Cybersecurity Solutions",
    "logo": { "@type": "ImageObject", "url": `${siteUrl}/images/logowhiteUW.png` }
  },
  "mainEntityOfPage": `${siteUrl}/blog/${slug}`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog` },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": `${siteUrl}/blog/${slug}` }
  ]
};
---

<Layout
  title={`${post.title} - Underwings Blog`}
  description={post.excerpt || post.meta_description || `Read ${post.title} on Underwings Cybersecurity Solutions blog.`}
  ogImage={post.featured_image}
  schema={[articleSchema, breadcrumbSchema]}
>
  <Header currentPage="blog" />

  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress"></div>

  <!-- TTS Player bar -->
  <div class="tts-player" id="tts-player">
    <div class="tts-player-inner">
      <button class="tts-control" id="tts-play-pause" aria-label="Play/Pause">
        <svg class="tts-icon-play" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        <svg class="tts-icon-pause" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      </button>
      <div class="tts-progress-wrap" id="tts-progress-wrap">
        <div class="tts-progress-bar" id="tts-progress-bar"></div>
      </div>
      <span class="tts-time" id="tts-time">0:00</span>
      <div class="tts-speed" id="tts-speed" title="Playback speed">1x</div>
      <button class="tts-close" id="tts-close" aria-label="Stop listening">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <main id="main" class="main">
    <article class="blog-post">
      <!-- Header -->
      <section class="section top-padding-large bottom-padding-small">
        <div class="post-container-wide">
          <div class="post-header">
            <a href="/blog" class="back-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              All posts
            </a>

            {post.category && (
              <span class="post-category">{post.category}</span>
            )}

            <h1 class="post-title">{post.title}</h1>

            {post.excerpt && (
              <p class="post-subtitle">{post.excerpt}</p>
            )}

            <div class="post-meta">
              <div class="post-author-block">
                <div class="post-author-avatar">
                  {post.author_name ? post.author_name.split(' ').map(n => n[0]).join('') : 'UT'}
                </div>
                <div class="post-author-info">
                  {post.author_name && <span class="post-author-name">{post.author_name}</span>}
                  <div class="post-meta-details">
                    {formattedDate && <span>{formattedDate}</span>}
                    <span>&middot;</span>
                    <span>{readingTime} min read</span>
                  </div>
                </div>
              </div>
              <!-- Listen button -->
              <div class="post-actions">
                <button class="listen-btn" id="listen-btn" title="Listen to article" aria-label="Listen to article">
                  <svg class="listen-icon-play" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  <svg class="listen-icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                  <span class="listen-label">Listen</span>
                </button>
                <!-- Share actions -->
                <div class="post-share">
                  <button class="share-btn" id="share-copy" title="Copy link" aria-label="Copy link to clipboard">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                  </button>
                  <a class="share-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(siteUrl + '/blog/' + slug)}`} target="_blank" rel="noopener noreferrer" title="Share on LinkedIn" aria-label="Share on LinkedIn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                  <a class="share-btn" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(siteUrl + '/blog/' + slug)}&text=${encodeURIComponent(post.title)}`} target="_blank" rel="noopener noreferrer" title="Share on X" aria-label="Share on X">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Featured Image -->
      {post.featured_image && (
        <section class="post-image-section">
          <div class="post-container-wide">
            <div class="post-featured-image">
              <img src={post.featured_image} alt={post.title} loading="lazy" />
            </div>
          </div>
        </section>
      )}

      <!-- Content -->
      <section class="post-body-section">
        <div class="post-container-reading">
          <div class="post-content" set:html={markdownToHtml(post.content)} />

          {post.tags && post.tags.length > 0 && (
            <div class="post-tags">
              {post.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}

          <!-- Post footer -->
          <div class="post-footer">
            <div class="post-footer-author">
              <div class="post-author-avatar post-author-avatar-lg">
                {post.author_name ? post.author_name.split(' ').map(n => n[0]).join('') : 'UT'}
              </div>
              <div>
                <div class="post-footer-written">Written by</div>
                <div class="post-footer-name">{post.author_name || 'Underwings Team'}</div>
                <div class="post-footer-bio">Cybersecurity insights from the Underwings Cybersecurity Solutions team — OSCP & CPTS certified professionals serving businesses in India and UAE.</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="post-cta-section">
        <div class="post-container-reading">
          <div class="blog-cta">
            <div class="blog-cta-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 2L4 6v6c0 5.5 3.5 8.5 8 10 4.5-1.5 8-4.5 8-10V6l-8-4z" stroke="#24d758" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="#24d758" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="blog-cta-title">Need help securing your systems?</h3>
            <p class="blog-cta-desc">Our certified team can assess your vulnerabilities and provide actionable remediation guidance. Get in touch for a free consultation.</p>
            <a href="/#contact" class="blog-cta-button">Get a Free Consultation</a>
          </div>
        </div>
      </section>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <section class="related-posts-section">
          <div class="post-container-wide">
            <div class="related-header">
              <div class="related-line"></div>
              <h2 class="related-heading">Recommended</h2>
              <div class="related-line"></div>
            </div>
            <div class="related-posts-grid">
              {relatedPosts.map(relatedPost => (
                <a href={`/blog/${relatedPost.slug}`} class="related-post-card">
                  <span class="related-post-category">{relatedPost.category}</span>
                  <h3>{relatedPost.title}</h3>
                  <span class="related-read-more">Read article &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}
    </article>
  </main>

  <script is:inline nonce={Astro.locals.nonce || ""}>
  // Reading progress bar
  (function() {
    var bar = document.getElementById('reading-progress');
    if (!bar) return;
    function update() {
      var h = document.documentElement.scrollHeight - window.innerHeight;
      var pct = h > 0 ? (window.scrollY / h) * 100 : 0;
      bar.style.width = pct + '%';
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  })();

  // Copy link button
  (function() {
    var btn = document.getElementById('share-copy');
    if (!btn) return;
    btn.addEventListener('click', function() {
      navigator.clipboard.writeText(window.location.href).then(function() {
        btn.classList.add('is-copied');
        btn.title = 'Copied!';
        setTimeout(function() { btn.classList.remove('is-copied'); btn.title = 'Copy link'; }, 2000);
      });
    });
  })();

  // Text-to-Speech (server-side with natural voice)
  (function() {
    var listenBtn = document.getElementById('listen-btn');
    var player = document.getElementById('tts-player');
    var playPause = document.getElementById('tts-play-pause');
    var closeBtn = document.getElementById('tts-close');
    var speedBtn = document.getElementById('tts-speed');
    var progressBar = document.getElementById('tts-progress-bar');
    var timeEl = document.getElementById('tts-time');

    if (!listenBtn || !player) return;

    var audio = new Audio();
    var state = 'idle'; // idle | loading | playing | paused
    var speeds = [1, 1.25, 1.5, 0.75];
    var speedIdx = 0;

    function getText() {
      var el = document.querySelector('.post-content');
      return el ? (el.innerText || el.textContent || '') : '';
    }

    function fmt(s) {
      var m = Math.floor(s / 60), sec = Math.floor(s % 60);
      return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    function ui(playing) {
      var lp = listenBtn.querySelector('.listen-icon-play');
      var lk = listenBtn.querySelector('.listen-icon-pause');
      var ll = listenBtn.querySelector('.listen-label');
      if (lp) lp.style.display = playing ? 'none' : '';
      if (lk) lk.style.display = playing ? '' : 'none';
      if (ll) ll.textContent = state === 'loading' ? 'Loading...' : (playing ? 'Listening' : 'Listen');
      var pp = playPause.querySelector('.tts-icon-play');
      var pk = playPause.querySelector('.tts-icon-pause');
      if (pp) pp.style.display = playing ? 'none' : '';
      if (pk) pk.style.display = playing ? '' : 'none';
    }

    // Audio event handlers
    audio.addEventListener('timeupdate', function() {
      if (audio.duration && progressBar) {
        progressBar.style.width = (audio.currentTime / audio.duration * 100) + '%';
      }
      if (timeEl) timeEl.textContent = fmt(audio.currentTime);
    });

    audio.addEventListener('ended', function() {
      state = 'idle';
      ui(false);
      player.classList.remove('is-visible');
      if (progressBar) progressBar.style.width = '0%';
      if (timeEl) timeEl.textContent = '0:00';
    });

    audio.addEventListener('error', function() {
      state = 'idle';
      ui(false);
      player.classList.remove('is-visible');
      var ll = listenBtn.querySelector('.listen-label');
      if (ll) ll.textContent = 'Error';
      setTimeout(function() { if (ll) ll.textContent = 'Listen'; }, 3000);
    });

    function doStart() {
      var text = getText();
      if (!text) return;

      state = 'loading';
      ui(false);
      var ll = listenBtn.querySelector('.listen-label');
      if (ll) ll.textContent = 'Loading...';
      player.classList.add('is-visible');
      if (progressBar) progressBar.style.width = '0%';
      if (timeEl) timeEl.textContent = '0:00';

      fetch('/api/tts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: text.slice(0, 15000) })
      })
      .then(function(res) {
        if (!res.ok) throw new Error('TTS failed');
        return res.arrayBuffer();
      })
      .then(function(buf) {
        var blob = new Blob([buf], { type: 'audio/mpeg' });
        var url = URL.createObjectURL(blob);
        audio.src = url;
        audio.playbackRate = speeds[speedIdx];
        return audio.play();
      })
      .then(function() {
        state = 'playing';
        ui(true);
      })
      .catch(function(err) {
        console.error('[TTS]', err);
        state = 'idle';
        ui(false);
        player.classList.remove('is-visible');
        if (ll) ll.textContent = 'Error';
        setTimeout(function() { if (ll) ll.textContent = 'Listen'; }, 3000);
      });
    }

    function doPause() {
      audio.pause();
      state = 'paused';
      ui(false);
    }

    function doResume() {
      audio.play();
      state = 'playing';
      ui(true);
    }

    function doStop() {
      audio.pause();
      audio.currentTime = 0;
      state = 'idle';
      ui(false);
      player.classList.remove('is-visible');
      if (progressBar) progressBar.style.width = '0%';
      if (timeEl) timeEl.textContent = '0:00';
    }

    function toggle() {
      if (state === 'playing') doPause();
      else if (state === 'paused') doResume();
      else if (state === 'idle') doStart();
    }

    listenBtn.addEventListener('click', toggle);
    playPause.addEventListener('click', toggle);
    closeBtn.addEventListener('click', doStop);

    speedBtn.addEventListener('click', function() {
      speedIdx = (speedIdx + 1) % speeds.length;
      speedBtn.textContent = speeds[speedIdx] + 'x';
      audio.playbackRate = speeds[speedIdx];
    });
  })();
  </script>

  <Footer />
</Layout>

<style>
  /* ---- Reading progress ---- */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(90deg, #24d758, #27dab4);
    z-index: 9999;
    transition: width 0.1s linear;
  }

  /* ---- Layout containers ---- */
  .post-container-wide {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .post-container-reading {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ---- Header ---- */
  .post-header {
    text-align: left;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    font-size: 0.82rem;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }
  .back-link:hover { color: #24d758; }

  .post-category {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    background: rgba(36, 215, 88, 0.06);
    border: 1px solid rgba(36, 215, 88, 0.2);
    border-radius: 20px;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #24d758;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .post-title {
    font-family: 'Geist', sans-serif;
    font-size: 2.85rem;
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.12;
    color: #fff;
    margin-bottom: 1.5rem;
  }
  .post-subtitle {
    font-size: 1.3rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 400;
    margin-bottom: 2.25rem;
    letter-spacing: -0.01em;
  }

  /* ---- Author + Share row ---- */
  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }
  .post-author-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .post-author-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(36, 215, 88, 0.18), rgba(39, 218, 180, 0.18));
    border: 1px solid rgba(36, 215, 88, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: #24d758;
    flex-shrink: 0;
  }
  .post-author-avatar-lg {
    width: 3.5rem;
    height: 3.5rem;
    font-size: 0.95rem;
  }
  .post-author-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .post-author-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
  }
  .post-meta-details {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.45);
    display: flex;
    gap: 0.35rem;
  }

  /* Actions row (listen + share) */
  .post-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Listen button */
  .listen-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 1rem 0.45rem 0.75rem;
    background: rgba(36, 215, 88, 0.06);
    border: 1px solid rgba(36, 215, 88, 0.2);
    border-radius: 20px;
    color: #24d758;
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 500;
    transition: all 0.2s;
    font-family: inherit;
    white-space: nowrap;
  }
  .listen-btn:hover {
    background: rgba(36, 215, 88, 0.12);
    border-color: rgba(36, 215, 88, 0.4);
  }

  /* TTS Player bar */
  .tts-player {
    position: fixed;
    bottom: -80px;
    left: 0;
    right: 0;
    z-index: 9998;
    transition: bottom 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .tts-player.is-visible {
    bottom: 0;
  }
  .tts-player-inner {
    max-width: 680px;
    margin: 0 auto 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    background: rgba(18, 18, 20, 0.95);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }
  .tts-control {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(36, 215, 88, 0.12);
    border: 1px solid rgba(36, 215, 88, 0.3);
    color: #24d758;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.2s;
  }
  .tts-control:hover {
    background: rgba(36, 215, 88, 0.2);
  }
  .tts-progress-wrap {
    flex: 1;
    height: 4px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
  }
  .tts-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #24d758, #27dab4);
    border-radius: 4px;
    transition: width 0.3s linear;
  }
  .tts-time {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5);
    font-variant-numeric: tabular-nums;
    min-width: 2.5rem;
    text-align: center;
    flex-shrink: 0;
  }
  .tts-speed {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.2s;
    flex-shrink: 0;
    user-select: none;
    font-family: inherit;
    font-weight: 500;
  }
  .tts-speed:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }
  .tts-close {
    display: flex;
