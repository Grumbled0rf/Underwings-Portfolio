---
// ===========================================
// PITSTACK - CYBERSECURITY INTELLIGENCE PLATFORM
// Underwings Technologies
// ===========================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Pitstack",
  "applicationCategory": "SecurityApplication",
  "operatingSystem": "Web",
  "description": "Unified cybersecurity intelligence hub — CTF events, CVE feeds, bug bounties, conferences, breach alerts, and threat intelligence in one dashboard.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "availability": "https://schema.org/PreOrder"
  },
  "creator": {
    "@type": "Organization",
    "name": "Underwings Technologies"
  }
};
---

<Layout
  title="Pitstack - Cybersecurity Intelligence Platform | Underwings"
  description="Pitstack is your unified cybersecurity intelligence hub. CTF events, CVE feeds, bug bounties, conferences, breach alerts, and threat intelligence in one dashboard."
  keywords="cybersecurity intelligence, threat intelligence platform, CVE monitoring, CTF events, bug bounty platform, security dashboard, breach alerts, Pitstack"
  wfPage="pitstack-page"
  schema={schema}
  bodyClass="body"
>
  <Header currentPage="pitstack" />

  <main id="main" class="main">

    <!-- ============ HERO ============ -->
    <section class="section bottom-padding-clear top-padding-small">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="pit-label">
                <div class="text-small color-grey">Intelligence Platform</div>
              </div>
              <h1 class="heading-large hero-heading-large"><span class="text-gradient-clip bg-color-green-gradient">Pitstack</span></h1>
              <p class="text" style="font-size: 1.35rem; margin-top: 0.5rem; text-align: center; color: rgba(255,255,255,0.7);">Your Cybersecurity Intelligence Hub</p>
              <p class="text text-center" style="max-width: 660px; margin: 1.25rem auto 0;">Stop drowning in scattered security feeds. Pitstack aggregates CTF events, CVE updates, bug bounties, conferences, breach alerts, and threat intelligence into one intelligent dashboard.</p>

              <!-- Status badge -->
              <div style="display: flex; justify-content: center; gap: 1rem; margin-top: 2rem; flex-wrap: wrap;">
                <span class="pit-status-badge">
                  <span class="pit-status-dot"></span>
                  Early Access — Coming Soon
                </span>
              </div>

              <div style="margin-top: 1.5rem;">
                <div class="button">
                  <a href="/#contact" class="button-hidden w-button">Join Waitlist</a>
                  <div class="button-wrapper">
                    <div class="button-text">Join Waitlist</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Dashboard Preview -->
        <div class="pit-preview">
          <div class="pit-preview-bar">
            <div class="pit-preview-dots"><span></span><span></span><span></span></div>
            <span class="pit-preview-url">app.pitstack.io/dashboard</span>
          </div>
          <div class="pit-preview-body">
            <div class="pit-preview-sidebar">
              <div class="pit-preview-nav-item active">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="1" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/></svg>
                Dashboard
              </div>
              <div class="pit-preview-nav-item">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.2"/><path d="M7 4v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                CVE Feed
              </div>
              <div class="pit-preview-nav-item">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1l1.5 3.5H12L9.5 7l1 3.5L7 8.5 3.5 10.5l1-3.5L1 4.5h3.5L7 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
                CTF Events
              </div>
              <div class="pit-preview-nav-item">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M13 2L5 10l-3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Bounties
              </div>
              <div class="pit-preview-nav-item">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 13s5-3 5-7V3l-5-2-5 2v3c0 4 5 7 5 7z" stroke="currentColor" stroke-width="1.2"/></svg>
                Alerts
              </div>
            </div>
            <div class="pit-preview-content">
              <div class="pit-preview-row">
                <div class="pit-preview-widget">
                  <div class="pit-widget-header">Critical CVEs <span class="pit-widget-badge red">3 new</span></div>
                  <div class="pit-widget-item"><span class="pit-cve-tag critical">9.8</span> CVE-2026-1234 — RCE in Apache</div>
                  <div class="pit-widget-item"><span class="pit-cve-tag critical">9.1</span> CVE-2026-5678 — SQLi in WordPress</div>
                  <div class="pit-widget-item"><span class="pit-cve-tag high">8.6</span> CVE-2026-9012 — Auth bypass Fortinet</div>
                </div>
                <div class="pit-preview-widget">
                  <div class="pit-widget-header">Upcoming CTFs <span class="pit-widget-badge green">5 this week</span></div>
                  <div class="pit-widget-item"><span class="pit-ctf-dot"></span> HTB University CTF — Mar 8</div>
                  <div class="pit-widget-item"><span class="pit-ctf-dot"></span> PicoCTF 2026 — Mar 12</div>
                  <div class="pit-widget-item"><span class="pit-ctf-dot"></span> Google CTF Quals — Mar 15</div>
                </div>
              </div>
              <div class="pit-preview-row">
                <div class="pit-preview-widget wide">
                  <div class="pit-widget-header">Breach Feed</div>
                  <div class="pit-widget-item">
                    <span class="pit-breach-dot"></span>
                    <span style="color: rgba(255,255,255,0.7);">Healthcare provider exposes 2.1M records</span>
                    <span class="pit-widget-time">2h ago</span>
                  </div>
                  <div class="pit-widget-item">
                    <span class="pit-breach-dot"></span>
                    <span style="color: rgba(255,255,255,0.7);">Ransomware group claims fintech company data</span>
                    <span class="pit-widget-time">5h ago</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FEEDS GRID ============ -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="heading-horizontal" style="margin-bottom: 3rem;">
          <div class="heading-horizontal-inner">
            <div class="heading-horizontal-left-part">
              <h2 class="heading">Intelligence Feeds</h2>
            </div>
            <div class="heading-horizontal-right-part">
              <p class="text-medium">Everything a security professional needs to stay informed — aggregated, filtered, and prioritized.</p>
            </div>
          </div>
        </div>

        <div class="pit-feed-grid">
          <div class="pit-feed-card pit-stagger">
            <div class="pit-feed-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><circle cx="13" cy="13" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M13 7v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 3l-2-1M18 3l2-1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.4"/></svg>
            </div>
            <h3 class="pit-feed-title">CVE & Vulnerability Feeds</h3>
            <p class="pit-feed-desc">Real-time CVE updates filtered by your tech stack. CVSS scores, exploit availability, and vendor patches — know which vulnerabilities matter to you.</p>
            <div class="pit-feed-tags"><span>NVD</span><span>CVSS</span><span>Exploit DB</span></div>
          </div>

          <div class="pit-feed-card pit-stagger">
            <div class="pit-feed-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M4 20V10l9-7 9 7v10a2 2 0 01-2 2H6a2 2 0 01-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 22v-6h6v6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="pit-feed-title">CTF Events Calendar</h3>
            <p class="pit-feed-desc">Never miss a CTF competition. Upcoming events, registration deadlines, difficulty ratings, and team formation — all tracked for you.</p>
            <div class="pit-feed-tags"><span>HTB</span><span>CTFtime</span><span>PicoCTF</span></div>
          </div>

          <div class="pit-feed-card pit-stagger">
            <div class="pit-feed-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M13 3l3 6h7l-5.5 4.5 2 7L13 17l-6.5 3.5 2-7L3 9h7l3-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="pit-feed-title">Bug Bounty Programs</h3>
            <p class="pit-feed-desc">New and updated programs across major platforms. Scope changes, payout updates, and launches aggregated in one feed.</p>
            <div class="pit-feed-tags"><span>HackerOne</span><span>Bugcrowd</span><span>Intigriti</span></div>
          </div>

          <div class="pit-feed-card pit-stagger">
            <div class="pit-feed-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M5 4h16a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5"/><path d="M9 22h8M13 20v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="13" cy="12" r="3" stroke="currentColor" stroke-width="1.3"/></svg>
            </div>
            <h3 class="pit-feed-title">Security Conferences</h3>
            <p class="pit-feed-desc">DEF CON, Black Hat, BSides, and regional events. CFP deadlines, registration dates, and early bird pricing tracked automatically.</p>
            <div class="pit-feed-tags"><span>DEF CON</span><span>Black Hat</span><span>BSides</span></div>
          </div>

          <div class="pit-feed-card pit-stagger">
            <div class="pit-feed-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><path d="M13 23s8-4 8-10V7l-8-4-8 4v6c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 13l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="pit-feed-title">Breach Alerts</h3>
            <p class="pit-feed-desc">Data breach notifications, ransomware incidents, and major security events. Know what's happening in the threat landscape as it unfolds.</p>
            <div class="pit-feed-tags"><span>Real-time</span><span>Ransomware</span><span>Data Leaks</span></div>
          </div>

          <div class="pit-feed-card pit-stagger">
            <div class="pit-feed-icon">
              <svg width="26" height="26" viewBox="0 0 26 26" fill="none"><circle cx="13" cy="13" r="4" stroke="currentColor" stroke-width="1.5"/><circle cx="13" cy="13" r="10" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3"/><path d="M13 3v3M13 20v3M3 13h3M20 13h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
            </div>
            <h3 class="pit-feed-title">Threat Intelligence</h3>
            <p class="pit-feed-desc">APT reports, malware analysis, and emerging attack techniques from trusted sources. Stay informed about threats targeting your industry.</p>
            <div class="pit-feed-tags"><span>APT</span><span>MITRE ATT&CK</span><span>IOCs</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ WHY PITSTACK ============ -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="pit-label">
            <div class="text-small color-grey">Platform Features</div>
          </div>
          <h2 class="heading heading-center">Why <span class="text-gradient-clip bg-color-green-gradient">Pitstack?</span></h2>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-top: 2.5rem; text-align: left;">
            <div class="pit-feature-card pit-stagger">
              <div class="pit-feature-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 12h10M4 18h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="20" cy="12" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="14" cy="18" r="2" stroke="currentColor" stroke-width="1.3"/></svg>
              </div>
              <div>
                <h3 class="pit-feature-title">Customizable Feeds</h3>
                <p class="pit-feature-desc">Filter by technology, vendor, severity, or topic. Only see what's relevant to your work and interests.</p>
              </div>
            </div>
            <div class="pit-feature-card pit-stagger">
              <div class="pit-feature-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.73 21a2 2 0 01-3.46 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <h3 class="pit-feature-title">Smart Notifications</h3>
                <p class="pit-feature-desc">Get alerted about critical updates via email, Slack, or webhooks. No noise — just signal.</p>
              </div>
            </div>
            <div class="pit-feature-card pit-stagger">
              <div class="pit-feature-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M16 18l2-2-2-2M8 18l-2-2 2-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 4l-4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <h3 class="pit-feature-title">API Access</h3>
                <p class="pit-feature-desc">Integrate Pitstack data into your security tools, dashboards, and workflows via REST API.</p>
              </div>
            </div>
            <div class="pit-feature-card pit-stagger">
              <div class="pit-feature-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <h3 class="pit-feature-title">Team Collaboration</h3>
                <p class="pit-feature-desc">Share feeds, save searches, and collaborate with your security team on a shared dashboard.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section id="cta" class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top" style="text-align: center;">
          <h2 class="heading heading-center">Stay Ahead of <span class="text-gradient-clip bg-color-green-gradient">Threats</span></h2>
          <p class="text-medium" style="max-width: 560px; margin: 1.25rem auto; color: rgba(255,255,255,0.5); text-align: center;">Pitstack is currently in early access. Join the waitlist to be among the first to experience unified cybersecurity intelligence.</p>
          <div style="margin-top: 2rem;">
            <div class="button" style="display: inline-block;">
              <a href="/#contact" class="button-hidden w-button">Join Waitlist</a>
              <div class="button-wrapper">
                <div class="button-text">Join Waitlist</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:inline>
  /* ---- Label ---- */
  #main .pit-label {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 5.625rem;
    padding: 0.625rem 1rem;
  }

  /* ---- Status badge ---- */
  .pit-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(36,215,88,0.4);
    border-radius: 20px;
    font-size: 0.85rem;
    color: #fff;
    background: rgba(36,215,88,0.08);
  }
  .pit-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #24d758;
    animation: pitPulse 2s ease-in-out infinite;
  }
  @keyframes pitPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(36,215,88,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(36,215,88,0); }
  }

  /* ---- Dashboard Preview ---- */
  .pit-preview {
    margin-top: 3rem;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    background: #0d0d0d;
  }
  .pit-preview-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .pit-preview-dots {
    display: flex;
    gap: 5px;
  }
  .pit-preview-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
  }
  .pit-preview-dots span:first-child { background: #ff5f57; }
  .pit-preview-dots span:nth-child(2) { background: #ffbd2e; }
  .pit-preview-dots span:nth-child(3) { background: #28c840; }
  .pit-preview-url {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    font-family: 'Geist Mono', monospace;
    background: rgba(255,255,255,0.04);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    flex: 1;
    text-align: center;
  }
  .pit-preview-body {
    display: flex;
    min-height: 260px;
  }
  .pit-preview-sidebar {
    width: 140px;
    flex-shrink: 0;
    padding: 0.75rem 0;
    border-right: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pit-preview-nav-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    cursor: default;
  }
  .pit-preview-nav-item.active {
    color: #24d758;
    background: rgba(36,215,88,0.06);
    border-right: 2px solid #24d758;
  }
  .pit-preview-content {
    flex: 1;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pit-preview-row {
    display: flex;
    gap: 0.75rem;
  }
  .pit-preview-widget {
    flex: 1;
    padding: 0.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .pit-preview-widget.wide { flex: 1; }
  .pit-widget-header {
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  .pit-widget-badge {
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 500;
  }
  .pit-widget-badge.red { background: rgba(255,79,87,0.15); color: #ff4f57; }
  .pit-widget-badge.green { background: rgba(36,215,88,0.12); color: #24d758; }
  .pit-widget-item {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .pit-widget-time {
    margin-left: auto;
    font-size: 0.58rem;
    color: rgba(255,255,255,0.2);
    white-space: nowrap;
  }
  .pit-cve-tag {
    font-size: 0.58rem;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-weight: 600;
    font-family: 'Geist Mono', monospace;
    flex-shrink: 0;
  }
  .pit-cve-tag.critical { background: rgba(255,59,48,0.15); color: #ff3b30; }
  .pit-cve-tag.high { background: rgba(255,149,0,0.15); color: #ff9500; }
  .pit-ctf-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #24d758;
    flex-shrink: 0;
  }
  .pit-breach-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ff4f57;
    flex-shrink: 0;
  }

  /* ---- Feeds Grid ---- */
  .pit-feed-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .pit-feed-card {
    padding: 1.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    transition: border-color 0.3s ease, transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .pit-feed-card:hover {
    border-color: rgba(36,215,88,0.3);
