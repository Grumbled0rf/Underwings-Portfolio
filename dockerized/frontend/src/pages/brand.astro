</style>

<script>
  // Stagger entrance animation
  (function() {
    if (typeof IntersectionObserver === 'undefined') return;
    var cards = document.querySelectorAll('.brand-logo-card, .brand-color-card, .brand-type-card, .brand-guideline-card, .brand-scale-item');
    cards.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(16px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var parent = entry.target.parentElement;
          var siblings = parent ? Array.from(parent.children).filter(function(c) { return c.style && c.style.opacity === '0'; }) : [];
          var idx = siblings.indexOf(entry.target);
          setTimeout(function() {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }, Math.max(0, idx) * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    cards.forEach(function(el) { observer.observe(el); });
  })();
</script>
