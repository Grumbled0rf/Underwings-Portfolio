---
// ===========================================
// BRAND GUIDELINES PAGE
// Underwings Technologies
// ===========================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Brand Guidelines | Underwings Technologies"
  description="Official brand guidelines for Underwings Technologies. Logo usage, color palette, typography, and downloadable brand assets."
  keywords="Underwings brand, brand guidelines, logo, brand assets, media kit"
  wfPage="brand-page"
  schema={null}
  bodyClass="body"
>

  <Header currentPage="brand" />

  <main id="main" class="main">

    <!-- ============ HERO ============ -->
    <section class="section top-padding-small bottom-padding-medium">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="brand-label">
                <div class="text-small color-grey">Brand Guidelines</div>
              </div>
              <h1 class="heading-large hero-heading-large">Our <span class="text-gradient-clip bg-color-green-gradient">Identity</span></h1>
              <p class="text" style="max-width: 620px; margin: 1rem auto 0; text-align: center;">Guidelines for using the Underwings brand. Follow these rules to maintain consistency across all communications.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ LOGO ============ -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 1.75rem;">
          <div class="brand-label">
            <div class="text-small color-grey">Logo</div>
          </div>
          <h2 class="heading heading-center" style="margin-top: 0.75rem;">Primary <span class="text-gradient-clip bg-color-green-gradient">Logo</span></h2>
        </div>

        <div class="brand-logo-grid">
          <!-- Logo on Dark -->
          <div class="brand-logo-card brand-logo-dark">
            <div class="brand-logo-preview">
              <img src="/images/logowhiteUW.png" alt="Underwings logo on dark background" loading="lazy" style="max-height: 60px; width: auto;">
            </div>
            <div class="brand-logo-info">
              <span class="brand-logo-label">On dark backgrounds</span>
              <span class="brand-logo-badge">Primary</span>
            </div>
          </div>
          <!-- Logo on Light -->
          <div class="brand-logo-card brand-logo-light">
            <div class="brand-logo-preview">
              <img src="/images/logowhiteUW.png" alt="Underwings logo on light background" loading="lazy" style="max-height: 60px; width: auto; filter: invert(1);">
            </div>
            <div class="brand-logo-info">
              <span class="brand-logo-label">On light backgrounds</span>
              <span class="brand-logo-badge">Inverted</span>
            </div>
          </div>
        </div>

        <!-- Logo Rules -->
        <div class="brand-rules">
          <div class="brand-rule">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 18a8 8 0 100-16 8 8 0 000 16z" stroke="#24d758" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="#24d758" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Always maintain clear space around the logo equal to the height of the "U" character</span>
          </div>
          <div class="brand-rule">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 18a8 8 0 100-16 8 8 0 000 16z" stroke="#24d758" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="#24d758" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Minimum width: 120px for digital, 30mm for print</span>
          </div>
          <div class="brand-rule">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="#ff4b4b" stroke-width="1.5"/><path d="M7 7l6 6M13 7l-6 6" stroke="#ff4b4b" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span>Do not stretch, rotate, add effects, or change the logo colors</span>
          </div>
          <div class="brand-rule">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="#ff4b4b" stroke-width="1.5"/><path d="M7 7l6 6M13 7l-6 6" stroke="#ff4b4b" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span>Do not place on busy backgrounds without sufficient contrast</span>
          </div>
        </div>

        <!-- Download -->
        <div style="text-align: center; margin-top: 1.75rem;">
          <a href="/images/logowhiteUW.png" download="underwings-logo-white.png" class="brand-download-btn">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v9M4 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Download Logo (PNG)
          </a>
        </div>
      </div>
    </section>

    <!-- ============ COLORS ============ -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 1.75rem;">
          <div class="brand-label">
            <div class="text-small color-grey">Colors</div>
          </div>
          <h2 class="heading heading-center" style="margin-top: 0.75rem;">Color <span class="text-gradient-clip bg-color-green-gradient">Palette</span></h2>
        </div>

        <div class="brand-color-grid">
          <!-- Primary -->
          <div class="brand-color-card">
            <div class="brand-color-swatch" style="background: #24d758;"></div>
            <div class="brand-color-details">
              <span class="brand-color-name">Green Primary</span>
              <code class="brand-color-code">#24D758</code>
              <span class="brand-color-use">Accents, CTAs, highlights</span>
            </div>
          </div>
          <div class="brand-color-card">
            <div class="brand-color-swatch" style="background: #27dab4;"></div>
            <div class="brand-color-details">
              <span class="brand-color-name">Teal Secondary</span>
              <code class="brand-color-code">#27DAB4</code>
              <span class="brand-color-use">Gradient end, secondary accent</span>
            </div>
          </div>
          <div class="brand-color-card">
            <div class="brand-color-swatch" style="background: linear-gradient(135deg, #24d758, #27dab4);"></div>
            <div class="brand-color-details">
              <span class="brand-color-name">Brand Gradient</span>
              <code class="brand-color-code">#24D758 → #27DAB4</code>
              <span class="brand-color-use">Headings, badges, key elements</span>
            </div>
          </div>
          <!-- Neutrals -->
          <div class="brand-color-card">
            <div class="brand-color-swatch" style="background: #171717;"></div>
            <div class="brand-color-details">
              <span class="brand-color-name">Black</span>
              <code class="brand-color-code">#171717</code>
              <span class="brand-color-use">Primary background</span>
            </div>
          </div>
          <div class="brand-color-card">
            <div class="brand-color-swatch" style="background: #1e1e1e;"></div>
            <div class="brand-color-details">
              <span class="brand-color-name">Dark</span>
              <code class="brand-color-code">#1E1E1E</code>
              <span class="brand-color-use">Card backgrounds, sections</span>
            </div>
          </div>
          <div class="brand-color-card">
            <div class="brand-color-swatch" style="background: #ffffff; border: 1px solid rgba(255,255,255,0.15);"></div>
            <div class="brand-color-details">
              <span class="brand-color-name">White</span>
              <code class="brand-color-code">#FFFFFF</code>
              <span class="brand-color-use">Primary text, headings</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ TYPOGRAPHY ============ -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 1.75rem;">
          <div class="brand-label">
            <div class="text-small color-grey">Typography</div>
          </div>
          <h2 class="heading heading-center" style="margin-top: 0.75rem;">Type <span class="text-gradient-clip bg-color-green-gradient">System</span></h2>
        </div>

        <div class="brand-type-grid">
          <!-- Geist -->
          <div class="brand-type-card">
            <div class="brand-type-preview" style="font-family: 'Geist', sans-serif;">
              <span class="brand-type-sample">Aa</span>
              <span class="brand-type-alphabet">ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>abcdefghijklmnopqrstuvwxyz<br>0123456789</span>
            </div>
            <div class="brand-type-info">
              <span class="brand-type-name">Geist</span>
              <span class="brand-type-use">Headings & Display</span>
              <div class="brand-type-weights">
                <span style="font-weight: 300;">Light 300</span>
                <span style="font-weight: 400;">Regular 400</span>
                <span style="font-weight: 500;">Medium 500</span>
                <span style="font-weight: 600;">Semi 600</span>
                <span style="font-weight: 700;">Bold 700</span>
              </div>
            </div>
          </div>
          <!-- Geist Mono -->
          <div class="brand-type-card">
            <div class="brand-type-preview" style="font-family: 'Geist Mono', monospace;">
              <span class="brand-type-sample">Aa</span>
              <span class="brand-type-alphabet">ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>abcdefghijklmnopqrstuvwxyz<br>0123456789</span>
            </div>
            <div class="brand-type-info">
              <span class="brand-type-name">Geist Mono</span>
              <span class="brand-type-use">Body Text & UI</span>
              <div class="brand-type-weights">
                <span style="font-weight: 300;">Light 300</span>
                <span style="font-weight: 400;">Regular 400</span>
                <span style="font-weight: 500;">Medium 500</span>
                <span style="font-weight: 600;">Semi 600</span>
                <span style="font-weight: 700;">Bold 700</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Type Scale -->
        <div class="brand-type-scale">
          <div class="brand-scale-item">
            <span class="brand-scale-label">H1</span>
            <span style="font-family: 'Geist', sans-serif; font-size: 3rem; font-weight: 300; letter-spacing: -0.06em; line-height: 1;">Display Heading</span>
            <span class="brand-scale-spec">Geist Light / 6rem / -0.06em</span>
          </div>
          <div class="brand-scale-item">
            <span class="brand-scale-label">H2</span>
            <span style="font-family: 'Geist', sans-serif; font-size: 2rem; font-weight: 300; letter-spacing: -0.07em; line-height: 1;">Section Heading</span>
            <span class="brand-scale-spec">Geist Light / 3rem / -0.07em</span>
          </div>
          <div class="brand-scale-item">
            <span class="brand-scale-label">H3</span>
            <span style="font-family: 'Geist', sans-serif; font-size: 1.5rem; font-weight: 300; letter-spacing: -0.04em; line-height: 1.15;">Card Heading</span>
            <span class="brand-scale-spec">Geist Light / 1.85rem / -0.04em</span>
          </div>
          <div class="brand-scale-item">
            <span class="brand-scale-label">Body</span>
            <span style="font-family: 'Geist Mono', monospace; font-size: 1.0625rem; font-weight: 500; line-height: 1.5;">Body text in Geist Mono</span>
            <span class="brand-scale-spec">Geist Mono Medium / 1.0625rem / 1.5</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ USAGE GUIDELINES ============ -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center; margin-bottom: 1.75rem;">
          <div class="brand-label">
            <div class="text-small color-grey">Guidelines</div>
          </div>
          <h2 class="heading heading-center" style="margin-top: 0.75rem;">Usage <span class="text-gradient-clip bg-color-green-gradient">Rules</span></h2>
        </div>

        <div class="brand-guidelines-grid">
          <div class="brand-guideline-card">
            <div class="brand-guideline-icon" style="color: #24d758;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3 class="brand-guideline-title">Spacing</h3>
            <p class="brand-guideline-text">Use 8px base grid. Components use 1.5rem (24px) gaps. Sections use 6rem (96px) vertical padding.</p>
          </div>
          <div class="brand-guideline-card">
            <div class="brand-guideline-icon" style="color: #24d758;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M8 8h3v3H8zM13 8h3v3h-3zM8 13h3v3H8z" stroke="currentColor" stroke-width="1.2"/></svg>
            </div>
            <h3 class="brand-guideline-title">Border Radius</h3>
            <p class="brand-guideline-text">Cards and containers: 12px. Buttons and badges: 8px. Pills and tags: 4px. Avatars: 50%.</p>
          </div>
          <div class="brand-guideline-card">
            <div class="brand-guideline-icon" style="color: #24d758;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="brand-guideline-title">Animations</h3>
            <p class="brand-guideline-text">Transitions: 0.3s ease. Entrance animations: 0.5s ease with stagger. Prefer subtle over dramatic.</p>
          </div>
          <div class="brand-guideline-card">
            <div class="brand-guideline-icon" style="color: #24d758;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3l2 6h6l-5 4 2 6-5-3-5 3 2-6-5-4h6l2-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="brand-guideline-title">Tone of Voice</h3>
            <p class="brand-guideline-text">Confident but not arrogant. Technical but accessible. Honest and direct. No jargon for the sake of jargon.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div style="text-align: center;">
          <h2 class="heading heading-center">Need Brand <span class="text-gradient-clip bg-color-green-gradient">Assets?</span></h2>
          <p class="text-medium" style="max-width: 500px; margin: 1rem auto 0; color: rgba(255,255,255,0.5); text-align: center;">For press inquiries, partnership materials, or custom brand assets, reach out to our team.</p>
          <div style="margin-top: 1.75rem;">
            <div class="button" style="display: inline-block;">
              <a href="mailto:contact@underwings.org" class="button-hidden w-button">Contact</a>
              <div class="button-wrapper">
                <div class="button-text">Contact Us</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

</Layout>

<style is:inline>
  /* ---- Compact section spacing ---- */
  #main .section {
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
  }
  #main .section.top-padding-small {
    padding-top: 0;
  }

  /* ---- Label ---- */
  #main .brand-label {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 5.625rem;
    padding: 0.625rem 1rem;
  }

  /* ---- Heading constraint ---- */
  #main .heading.heading-center {
    text-align: center;
    max-width: 18ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ---- Logo Section ---- */
  .brand-logo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .brand-logo-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .brand-logo-preview {
    padding: 2.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
  }
  .brand-logo-dark .brand-logo-preview {
    background: #171717;
  }
  .brand-logo-light .brand-logo-preview {
    background: #f0f0f0;
  }
  .brand-logo-info {
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255,255,255,0.03);
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .brand-logo-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
  }
  .brand-logo-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    background: rgba(36,215,88,0.1);
    border: 1px solid rgba(36,215,88,0.25);
    border-radius: 4px;
    color: #24d758;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Logo Rules */
  .brand-rules {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 1.75rem;
  }
  .brand-rule {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
  }
  .brand-rule svg {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Download Button */
  .brand-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: rgba(36,215,88,0.08);
    border: 1px solid rgba(36,215,88,0.25);
    border-radius: 8px;
    color: #24d758;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .brand-download-btn:hover {
    background: rgba(36,215,88,0.15);
    border-color: #24d758;
  }

  /* ---- Color Palette ---- */
  .brand-color-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .brand-color-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
  }
  .brand-color-swatch {
    height: 72px;
  }
  .brand-color-details {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .brand-color-name {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }
  .brand-color-code {
    font-family: 'Geist Mono', monospace;
    font-size: 0.825rem;
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.06);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    display: inline-block;
    width: fit-content;
  }
  .brand-color-use {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    margin-top: 0.25rem;
  }

  /* ---- Typography ---- */
  .brand-type-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .brand-type-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
  }
  .brand-type-preview {
    padding: 1.75rem 1.5rem;
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
  }
  .brand-type-sample {
    font-size: 3.25rem;
    font-weight: 300;
    color: #fff;
    line-height: 1;
  }
  .brand-type-alphabet {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
    letter-spacing: 0.05em;
  }
  .brand-type-info {
    padding: 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .brand-type-name {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.25rem;
  }
  .brand-type-use {
    display: block;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.75rem;
  }
  .brand-type-weights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: 'Geist', sans-serif;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.5);
  }

  /* Type Scale */
  .brand-type-scale {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .brand-scale-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    color: #fff;
  }
  .brand-scale-item:first-child {
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .brand-scale-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #24d758;
    width: 3rem;
    flex-shrink: 0;
  }
  .brand-scale-spec {
    font-size: 0.75rem;
