---
// ===========================================
// NEWS & UPDATES PAGE
// Underwings Cybersecurity Solutions
// Auto-fetches cybersecurity vendor advisories
// ===========================================
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Cybersecurity News & Threat Intelligence | Underwings"
  description="Stay informed with the latest cybersecurity advisories, vulnerability disclosures, and threat intelligence from CISA, The Hacker News, and BleepingComputer."
  keywords="cybersecurity news, CISA advisories, vulnerability updates, threat intelligence, security updates UAE, cyber alerts"
  wfPage="updates-page"
  schema={null}
  bodyClass="body"
>
  <Fragment slot="head">
    <style is:inline>
      /* Updates Page Styles */
      .upd-hero {
        text-align: center;
        padding-top: 2rem;
      }
      .upd-hero .label {
        margin-bottom: 1rem;
      }
      .upd-hero h1 {
        margin-bottom: 1rem;
      }
      .upd-hero p {
        max-width: 640px;
        margin: 0 auto;
      }
      .upd-live-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: #24d758;
        border-radius: 50%;
        margin-right: 6px;
        animation: upd-pulse 2s ease-in-out infinite;
        vertical-align: middle;
      }
      @keyframes upd-pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(36,215,88,0.5); }
        50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(36,215,88,0); }
      }

      /* Filter Tabs */
      .upd-filters {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 2rem;
        margin-bottom: 2.5rem;
      }
      .upd-filter-btn {
        padding: 0.45rem 1rem;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 6px;
        color: rgba(255,255,255,0.6);
        font-size: 0.8rem;
        font-family: 'Geist', sans-serif;
        cursor: pointer;
        transition: all 0.2s ease;
      }
      .upd-filter-btn:hover {
        border-color: rgba(36,215,88,0.3);
        color: #fff;
      }
      .upd-filter-btn.is-active {
        background: rgba(36,215,88,0.1);
        border-color: #24d758;
        color: #24d758;
      }

      /* Cards Grid */
      .upd-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.25rem;
      }
      .upd-card {
        padding: 1.5rem;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        transition: border-color 0.3s ease, transform 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        text-decoration: none;
        color: inherit;
        opacity: 0;
        filter: blur(4px);
        transform: translateY(12px);
        transition: opacity 0.5s ease, filter 0.5s ease, transform 0.5s ease, border-color 0.3s ease;
      }
      .upd-card.is-visible {
        opacity: 1;
        filter: blur(0);
        transform: translateY(0);
      }
      .upd-card:hover {
        border-color: rgba(36,215,88,0.3);
        transform: translateY(-2px);
      }
      .upd-card-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .upd-source-tag {
        font-size: 0.65rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .upd-source-cisa {
        background: rgba(30,90,200,0.15);
        border: 1px solid rgba(30,90,200,0.3);
        color: #5b9cf5;
      }
      .upd-source-thn {
        background: rgba(200,50,50,0.1);
        border: 1px solid rgba(200,50,50,0.25);
        color: #e05555;
      }
      .upd-source-bleeping {
        background: rgba(200,130,20,0.1);
        border: 1px solid rgba(200,130,20,0.25);
        color: #e0a030;
      }
      .upd-severity {
        font-size: 0.6rem;
        padding: 0.15rem 0.45rem;
        border-radius: 3px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .upd-severity-critical {
        background: rgba(220,38,38,0.15);
        color: #f87171;
        border: 1px solid rgba(220,38,38,0.3);
      }
      .upd-severity-high {
        background: rgba(245,158,11,0.12);
        color: #fbbf24;
        border: 1px solid rgba(245,158,11,0.25);
      }
      .upd-severity-medium {
        background: rgba(59,130,246,0.1);
        color: #60a5fa;
        border: 1px solid rgba(59,130,246,0.2);
      }
      .upd-card-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: #fff;
        line-height: 1.35;
      }
      .upd-card-desc {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.7);
        line-height: 1.5;
      }
      .upd-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 0.5rem;
        border-top: 1px solid rgba(255,255,255,0.06);
      }
      .upd-date {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.6);
        font-family: 'Geist Mono', monospace;
      }
      .upd-read-more {
        font-size: 0.7rem;
        color: #24d758;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.3rem;
      }

      /* Loading State */
      .upd-loading {
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(255,255,255,0.65);
      }
      .upd-spinner {
        width: 32px;
        height: 32px;
        border: 2px solid rgba(255,255,255,0.1);
        border-top-color: #24d758;
        border-radius: 50%;
        animation: upd-spin 0.8s linear infinite;
        margin: 0 auto 1rem;
      }
      @keyframes upd-spin {
        to { transform: rotate(360deg); }
      }

      /* Empty / Error State */
      .upd-empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(255,255,255,0.65);
      }

      /* Stats Bar */
      .upd-stats {
        display: flex;
        gap: 2rem;
        justify-content: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
      }
      .upd-stat {
        text-align: center;
      }
      .upd-stat-num {
        font-size: 1.5rem;
        font-weight: 700;
        color: #24d758;
        font-family: 'Geist Mono', monospace;
        display: block;
      }
      .upd-stat-label {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.6);
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      /* Last Updated */
      .upd-last-updated {
        text-align: center;
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        font-size: 0.75rem;
        color: rgba(255,255,255,0.25);
        font-family: 'Geist Mono', monospace;
      }

      @media screen and (max-width: 768px) {
        .upd-grid { grid-template-columns: 1fr; }
        .upd-stats { gap: 1.5rem; }
      }
    </style>
  </Fragment>

  <Header currentPage="updates" />

  <main id="main" class="main">
    <!-- Hero -->
    <section class="section top-padding-large bottom-padding-medium" style="position: relative;">
      <div class="container-medium">
        <div class="upd-hero">
          <div class="label">
            <div class="text-small color-grey">
              <span class="upd-live-dot"></span> Live Feed
            </div>
          </div>
          <h1 class="heading-large">Cybersecurity <span class="text-gradient-clip bg-color-green-gradient">Updates</span></h1>
          <p class="text color-grey">Real-time advisories and threat intelligence from trusted sources. Auto-refreshed every 30 minutes.</p>

          <!-- Filter Tabs -->
          <div class="upd-filters" id="updFilters">
            <button class="upd-filter-btn is-active" data-filter="all">All Sources</button>
            <button class="upd-filter-btn" data-filter="cisa">CISA</button>
            <button class="upd-filter-btn" data-filter="thn">The Hacker News</button>
            <button class="upd-filter-btn" data-filter="bleeping">BleepingComputer</button>
          </div>
        </div>

        <!-- Stats -->
        <div class="upd-stats" id="updStats" style="display: none;">
          <div class="upd-stat">
            <span class="upd-stat-num" id="statTotal">0</span>
            <span class="upd-stat-label">Updates</span>
          </div>
          <div class="upd-stat">
            <span class="upd-stat-num" id="statCritical">0</span>
            <span class="upd-stat-label">Critical</span>
          </div>
          <div class="upd-stat">
            <span class="upd-stat-num" id="statSources">0</span>
            <span class="upd-stat-label">Sources</span>
          </div>
        </div>

        <!-- Loading State -->
        <div class="upd-loading" id="updLoading">
          <div class="upd-spinner"></div>
          <p>Fetching latest advisories...</p>
        </div>

        <!-- Updates Grid -->
        <div class="upd-grid" id="updGrid" style="display: none;"></div>

        <!-- Last Updated -->
        <div class="upd-last-updated" id="updTimestamp" style="display: none;"></div>
      </div>
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline nonce={Astro.locals.nonce || ""} src="/js/updates-feed.js"></script>
