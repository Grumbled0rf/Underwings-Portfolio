---
// ===========================================
// 404 NOT FOUND PAGE
// Underwings Technologies
// ===========================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found | Underwings Technologies"
  description="The page you're looking for doesn't exist or has been moved."
  schema={null}
  bodyClass="body"
>
  <Header />

  <main id="main" class="main">
    <section class="section top-padding-large bottom-padding-large not-found-fade-in" style="position: relative; min-height: 60vh; display: flex; align-items: center;">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium" style="text-align: center;">
        <div class="notfound-code">404</div>
        <h1 class="heading" style="margin-bottom: 1rem;">Page not found</h1>
        <p class="text" style="color: rgba(255,255,255,0.7); max-width: 440px; margin: 0 auto 2.5rem;">The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
        <div class="notfound-links">
          <a href="/" class="notfound-link">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 6l6-4 6 4v7a1 1 0 01-1 1H3a1 1 0 01-1-1V6z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M6 14V9h4v5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Homepage
          </a>
          <a href="/services/vapt" class="notfound-link">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1.5L3 4v4c0 3.5 2.5 5.5 5 6.5 2.5-1 5-3 5-6.5V4L8 1.5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
            Services
          </a>
          <a href="/blog" class="notfound-link">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 2h9l3 3v9H2V2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M5 8h6M5 11h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            Blog
          </a>
          <a href="/#contact" class="notfound-link notfound-link-primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="1" stroke="currentColor" stroke-width="1.2"/><path d="M2 5l6 4 6-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:inline>
  @keyframes notFoundFadeIn {
    from { opacity: 0; filter: blur(3px); transform: translateY(10px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
  .not-found-fade-in {
    animation: notFoundFadeIn 0.6s ease-out forwards;
  }
  .notfound-code {
    font-size: 6rem;
    font-weight: 700;
    font-family: 'Geist Mono', monospace;
    background: linear-gradient(135deg, #24d758, #27dab4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 1rem;
  }
  .notfound-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .notfound-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }
  .notfound-link:hover {
    border-color: rgba(36,215,88,0.4);
    color: #fff;
    background: rgba(36,215,88,0.06);
  }
  .notfound-link-primary {
    background: rgba(36,215,88,0.1);
    border-color: rgba(36,215,88,0.3);
    color: #24d758;
  }
  .notfound-link-primary:hover {
    background: rgba(36,215,88,0.15);
    border-color: #24d758;
    color: #24d758;
  }
  @media (max-width: 480px) {
    .notfound-code { font-size: 4rem; }
    .notfound-links { flex-direction: column; align-items: center; }
  }
</style>
