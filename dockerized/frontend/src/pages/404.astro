---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found | Underwings Technologies"
  description="The page you are looking for doesn't exist or has been moved."
  wfPage="6920627afaad5c7afb54bfaa"
  schema={null}
  bodyClass=""
>
  <Header currentPage="" />

  <main id="main" class="main">
    <section class="section not-found-fade-in">
      <div class="container">
        <div class="section-wrapper section-wrapper-not-found">
          <h1 class="heading heading-not-found">404</h1>
          <div class="not-found-utility">
            <p class="text color-grey not-found-utility-text">The page you are looking for doesn&#x27;t exist or has been moved</p>
            <div class="button">
              <a href="/" class="button-hidden w-button">Back to main page</a>
              <div class="button-wrapper">
                <div class="button-text color-white">Back to main page</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:inline>
  @keyframes notFoundFadeIn {
    from { opacity: 0; filter: blur(3px); transform: translateY(10px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
  .not-found-fade-in {
    animation: notFoundFadeIn 0.6s ease-out forwards;
  }
</style>
