---
// ===========================================
// CLIENT PORTAL
// Underwings Cybersecurity Solutions
// ===========================================

export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Client Portal - Underwings Cybersecurity Solutions"
  description="Secure client portal for viewing VAPT reports, tracking remediation progress, and managing your cybersecurity engagements."
  keywords="client portal, VAPT reports, remediation tracking, cybersecurity dashboard"
  wfPage="portal-page"
  schema={null}
>
  <Header currentPage="portal" />

  <main id="main" class="main">
    <section class="section top-padding-small">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">

        <!-- LOGIN SCREEN -->
        <div id="ptl-login" class="ptl-login-wrapper">
          <div class="ptl-login-card">
            <div class="ptl-login-icon">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#24d758" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                <circle cx="12" cy="16" r="1"/>
              </svg>
            </div>
            <h1 class="heading ptl-login-heading">Client Portal</h1>
            <p class="text color-grey" style="margin-bottom:2rem;text-align:center;">Sign in to access your project dashboard, reports, and remediation tracking.</p>

            <div id="ptl-login-error" class="ptl-error" style="display:none;"></div>

            <form id="ptl-login-form" class="ptl-form">
              <div class="ptl-field">
                <label for="ptl-email" class="ptl-label">Email</label>
                <input type="email" id="ptl-email" class="ptl-input" placeholder="you@company.com" required autocomplete="email" />
              </div>
              <div class="ptl-field">
                <label for="ptl-password" class="ptl-label">Password</label>
                <input type="password" id="ptl-password" class="ptl-input" placeholder="Your password" required autocomplete="current-password" />
              </div>
              <button type="submit" class="ptl-btn ptl-btn-primary" id="ptl-login-btn">
                <span class="ptl-btn-text">Sign In</span>
                <svg class="ptl-btn-spinner" style="display:none;" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
              </button>
            </form>

            <p class="ptl-login-help">Need access? <a href="/#contact" class="ptl-link">Contact us</a> to set up your account.</p>
          </div>
        </div>

        <!-- DASHBOARD (hidden until authenticated) -->
        <div id="ptl-dashboard" style="display:none;">

          <!-- Header -->
          <div class="ptl-dash-header">
            <div>
              <div class="label" style="margin-bottom:0.5rem;">
                <div class="text-small color-grey">Client Portal</div>
              </div>
              <h1 class="heading">Welcome, <span id="ptl-client-name" class="text-gradient-clip bg-color-green-gradient">Client</span></h1>
            </div>
            <button id="ptl-logout-btn" class="ptl-btn ptl-btn-ghost">Sign Out</button>
          </div>

          <!-- Summary Stats -->
          <div class="ptl-stats" id="ptl-stats">
            <div class="ptl-stat-card">
              <span class="ptl-stat-number" id="ptl-stat-active">0</span>
              <span class="ptl-stat-label">Active Projects</span>
            </div>
            <div class="ptl-stat-card">
              <span class="ptl-stat-number" id="ptl-stat-findings">0</span>
              <span class="ptl-stat-label">Total Findings</span>
            </div>
            <div class="ptl-stat-card">
              <span class="ptl-stat-number ptl-stat-green" id="ptl-stat-resolved">0%</span>
              <span class="ptl-stat-label">Remediation</span>
            </div>
            <div class="ptl-stat-card">
              <span class="ptl-stat-number" id="ptl-stat-reports">0</span>
              <span class="ptl-stat-label">Reports</span>
            </div>
          </div>

          <!-- Projects List -->
          <div id="ptl-projects" class="ptl-projects"></div>

          <!-- Empty State -->
          <div id="ptl-empty" class="ptl-empty" style="display:none;">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
            <h3 class="ptl-empty-title">No projects yet</h3>
            <p class="ptl-empty-text">Your dashboard will appear here once your engagement begins. We'll notify you by email when your first project is set up.</p>
            <a href="/#contact" class="ptl-btn ptl-btn-primary" style="margin-top:1rem;">Get Started</a>
          </div>

        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ============================================
     CLIENT PORTAL STYLES (ptl- prefix)
     ============================================ */

  /* ---- Login ---- */
  .ptl-login-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
    padding: 2rem 0 4rem;
  }
  .ptl-login-card {
    width: 100%;
    max-width: 420px;
    padding: 3rem 2.5rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ptl-login-icon {
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(36,215,88,0.08);
    border-radius: 50%;
    margin-bottom: 1.5rem;
  }
  .ptl-login-heading {
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .ptl-login-help {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
  }

  /* ---- Form Elements ---- */
  .ptl-form {
    width: 100%;
  }
  .ptl-field {
    margin-bottom: 1.25rem;
  }
  .ptl-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.6);
    margin-bottom: 0.5rem;
  }
  .ptl-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: #fff;
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 0.2s ease, background 0.2s ease;
    outline: none;
    box-sizing: border-box;
  }
  .ptl-input:focus {
    border-color: rgba(36,215,88,0.5);
    background: rgba(255,255,255,0.07);
  }
  .ptl-input::placeholder {
    color: rgba(255,255,255,0.25);
  }

  /* ---- Buttons ---- */
  .ptl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    text-decoration: none;
  }
  .ptl-btn-primary {
    background: linear-gradient(135deg, #24d758, #1fb94a);
    color: #000;
    width: 100%;
  }
  .ptl-btn-primary:hover {
    background: linear-gradient(135deg, #2ee666, #24d758);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(36,215,88,0.3);
  }
  .ptl-btn-ghost {
    background: transparent;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }
  .ptl-btn-ghost:hover {
    border-color: rgba(255,255,255,0.3);
    color: #fff;
  }
  .ptl-btn-small {
    padding: 0.4rem 0.8rem;
    font-size: 0.75rem;
    border-radius: 6px;
  }
  .ptl-btn-spinner {
    animation: ptl-spin 1s linear infinite;
  }
  @keyframes ptl-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .ptl-link {
    color: #24d758;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .ptl-link:hover {
    opacity: 0.8;
  }

  .ptl-error {
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(255,59,48,0.1);
    border: 1px solid rgba(255,59,48,0.3);
    border-radius: 8px;
    color: #ff6b6b;
    font-size: 0.85rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  /* ---- Dashboard Header ---- */
  .ptl-dash-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    padding-top: 2rem;
  }

  /* ---- Stats Row ---- */
  .ptl-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .ptl-stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 1.5rem 1rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
  }
  .ptl-stat-number {
    font-size: 1.75rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }
  .ptl-stat-green {
    background: linear-gradient(135deg, #24d758, #27dab4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .ptl-stat-label {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* ---- Project Cards ---- */
  .ptl-projects {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 3rem;
  }
  .ptl-project-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    transition: border-color 0.3s ease;
    overflow: hidden;
  }
  .ptl-project-card:hover {
    border-color: rgba(36,215,88,0.2);
  }
  .ptl-project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    cursor: pointer;
    user-select: none;
    gap: 1rem;
  }
  .ptl-project-header:hover {
    background: rgba(255,255,255,0.02);
  }
  .ptl-project-info {
    flex: 1;
    min-width: 0;
  }
  .ptl-project-top-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .ptl-project-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
  }
  .ptl-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ptl-badge-scoping { background: rgba(255,214,10,0.12); color: #ffd60a; border: 1px solid rgba(255,214,10,0.25); }
  .ptl-badge-in_progress { background: rgba(48,176,255,0.12); color: #30b0ff; border: 1px solid rgba(48,176,255,0.25); }
  .ptl-badge-review { background: rgba(175,130,255,0.12); color: #af82ff; border: 1px solid rgba(175,130,255,0.25); }
  .ptl-badge-completed { background: rgba(36,215,88,0.12); color: #24d758; border: 1px solid rgba(36,215,88,0.25); }
  .ptl-badge-retesting { background: rgba(255,149,0,0.12); color: #ff9500; border: 1px solid rgba(255,149,0,0.25); }

  .ptl-type-badge {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ptl-project-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .ptl-meta-item {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
  }

  /* Findings pills */
  .ptl-findings-row {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .ptl-finding-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .ptl-sev-critical { background: rgba(255,59,48,0.15); color: #ff3b30; }
  .ptl-sev-high { background: rgba(255,149,0,0.15); color: #ff9500; }
  .ptl-sev-medium { background: rgba(255,214,10,0.15); color: #ffd60a; }
  .ptl-sev-low { background: rgba(48,176,255,0.15); color: #30b0ff; }
  .ptl-sev-info { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); }

  /* Progress bar */
  .ptl-progress-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .ptl-progress-bar {
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    overflow: hidden;
    min-width: 80px;
  }
  .ptl-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #24d758, #27dab4);
    border-radius: 3px;
    transition: width 0.5s ease;
  }
  .ptl-progress-text {
    font-size: 0.75rem;
    font-weight: 600;
    color: #24d758;
    min-width: 30px;
    text-align: right;
  }

  /* Chevron */
  .ptl-chevron {
    width: 20px;
    height: 20px;
    color: rgba(255,255,255,0.3);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  .ptl-project-card.ptl-expanded .ptl-chevron {
    transform: rotate(180deg);
  }

  /* ---- Expanded Content ---- */
  .ptl-project-body {
    display: none;
    padding: 0 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .ptl-project-card.ptl-expanded .ptl-project-body {
    display: block;
  }

  .ptl-section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.5);
    margin: 1.5rem 0 0.75rem;
  }

  .ptl-scope-text {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  /* Reports list */
  .ptl-reports-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ptl-report-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    gap: 1rem;
  }
  .ptl-report-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
    flex: 1;
  }
  .ptl-report-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(36,215,88,0.08);
    border-radius: 6px;
    color: #24d758;
    flex-shrink: 0;
  }
  .ptl-report-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ptl-report-meta {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
  }
  .ptl-report-download {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    background: rgba(36,215,88,0.1);
    border: 1px solid rgba(36,215,88,0.2);
    border-radius: 6px;
    color: #24d758;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
  }
  .ptl-report-download:hover {
    background: rgba(36,215,88,0.2);
    border-color: rgba(36,215,88,0.4);
  }

  /* Remediation list */
  .ptl-remediation-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ptl-remediation-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
  }
  .ptl-remediation-status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 5px;
    flex-shrink: 0;
  }
  .ptl-rstat-open { background: #ff3b30; }
  .ptl-rstat-in_progress { background: #ff9500; }
  .ptl-rstat-resolved { background: #24d758; }
  .ptl-rstat-accepted_risk { background: #af82ff; }

  .ptl-remediation-content {
    flex: 1;
    min-width: 0;
  }
  .ptl-remediation-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: #fff;
    margin-bottom: 0.25rem;
  }
  .ptl-remediation-desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
    margin-bottom: 0.35rem;
  }
  .ptl-remediation-rec {
    font-size: 0.75rem;
    color: rgba(36,215,88,0.7);
    line-height: 1.5;
    font-style: italic;
  }
  .ptl-remediation-badges {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-shrink: 0;
  }

  .ptl-status-select {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    color: rgba(255,255,255,0.7);
    font-size: 0.7rem;
    padding: 0.25rem 0.4rem;
    cursor: pointer;
    font-family: inherit;
    outline: none;
  }
  .ptl-status-select:focus {
    border-color: rgba(36,215,88,0.4);
  }
  .ptl-status-select option {
    background: #1a1a1a;
    color: #fff;
  }

  /* Retest button */
  .ptl-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }
  .ptl-btn-retest {
    background: rgba(255,149,0,0.1);
    border: 1px solid rgba(255,149,0,0.25);
    color: #ff9500;
  }
  .ptl-btn-retest:hover {
    background: rgba(255,149,0,0.2);
    border-color: rgba(255,149,0,0.4);
  }

  /* ---- Empty State ---- */
  .ptl-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem 6rem;
  }
  .ptl-empty-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    margin: 1.5rem 0 0.5rem;
  }
  .ptl-empty-text {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.4);
    max-width: 400px;
    line-height: 1.6;
  }

  /* ---- No items inline empty ---- */
  .ptl-no-items {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.35);
    font-style: italic;
    padding: 0.5rem 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .ptl-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .ptl-project-header {
      padding: 1.25rem 1.25rem;
      flex-wrap: wrap;
    }
    .ptl-project-body {
      padding: 0 1.25rem 1.5rem;
    }
    .ptl-project-meta {
      gap: 0.75rem;
    }
    .ptl-report-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .ptl-dash-header {
      flex-direction: column;
      gap: 1rem;
    }
    .ptl-login-card {
      padding: 2rem 1.5rem;
    }
  }
  @media (max-width: 479px) {
    .ptl-stats {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .ptl-findings-row {
      flex-wrap: wrap;
    }
  }
</style>

<!-- Inject Supabase config for client-side use -->
<script is:inline nonce={Astro.locals.nonce || ""} define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL || '', supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '' }}>
  window.__SUPABASE_URL__ = supabaseUrl;
  window.__SUPABASE_KEY__ = supabaseKey;
</script>

<script is:inline nonce={Astro.locals.nonce || ""}>
(function() {
  // ============================================
  // CLIENT PORTAL - CLIENT-SIDE APPLICATION
  // ============================================

  const SUPABASE_URL = document.querySelector('meta[name="x-supabase-url"]')?.content;
  const SUPABASE_KEY = document.querySelector('meta[name="x-supabase-key"]')?.content;

  // We'll initialize Supabase client-side
  let sb = null;
  let currentUser = null;
  let projectsData = [];
  let reportsData = {};
  let remediationData = {};

  // DOM refs
  const loginSection = document.getElementById('ptl-login');
  const dashboard = document.getElementById('ptl-dashboard');
  const loginForm = document.getElementById('ptl-login-form');
  const loginError = document.getElementById('ptl-login-error');
  const loginBtn = document.getElementById('ptl-login-btn');
  const logoutBtn = document.getElementById('ptl-logout-btn');
  const clientNameEl = document.getElementById('ptl-client-name');
  const projectsEl = document.getElementById('ptl-projects');
  const emptyEl = document.getElementById('ptl-empty');

  // ---- Initialize ----
  async function init() {
    // Load Supabase JS from CDN if not already available
    if (typeof window.supabase === 'undefined') {
      await loadScript('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js');
    }

    // Get config from env vars embedded in the page
    const url = window.__SUPABASE_URL__;
    const key = window.__SUPABASE_KEY__;

    if (!url || !key) {
      showError('Portal configuration error. Please contact support.');
      return;
    }

    sb = window.supabase.createClient(url, key);

    // Check for existing session
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      currentUser = session.user;
      showDashboard();
    }

    // Listen for auth changes
    sb.auth.onAuthStateChange((event, session) => {
      if (event === 'SIGNED_IN' && session) {
        currentUser = session.user;
        showDashboard();
      } else if (event === 'SIGNED_OUT') {
        currentUser = null;
        showLogin();
      }
    });
  }

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  // ---- Auth ----
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('ptl-email').value.trim();
    const password = document.getElementById('ptl-password').value;

    if (!email || !password) return;

    setLoading(true);
    hideError();

    try {
      const { data, error } = await sb.auth.signInWithPassword({ email, password });
      if (error) throw error;
      currentUser = data.user;
      showDashboard();
    } catch (err) {
      showError(err.message || 'Invalid credentials. Please try again.');
    } finally {
      setLoading(false);
    }
  });

  logoutBtn.addEventListener('click', async () => {
    await sb.auth.signOut();
    showLogin();
  });

  // ---- UI State ----
  function showLogin() {
    loginSection.style.display = '';
    dashboard.style.display = 'none';
    loginForm.reset();
    hideError();
  }

  function showDashboard() {
    loginSection.style.display = 'none';
    dashboard.style.display = '';
    const name = currentUser.user_metadata?.full_name || currentUser.email?.split('@')[0] || 'Client';
    clientNameEl.textContent = name;
    loadProjects();
  }

  function setLoading(loading) {
    loginBtn.querySelector('.ptl-btn-text').style.display = loading ? 'none' : '';
    loginBtn.querySelector('.ptl-btn-spinner').style.display = loading ? '' : 'none';
    loginBtn.disabled = loading;
  }

  function showError(msg) {
    loginError.textContent = msg;
    loginError.style.display = '';
  }

  function hideError() {
    loginError.style.display = 'none';
  }

  // ---- Load Data ----
  async function loadProjects() {
    try {
      const { data: projects, error } = await sb
        .from('client_projects')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) throw error;
      projectsData = projects || [];

      // Load reports and remediation for all projects
      if (projectsData.length > 0) {
        const projectIds = projectsData.map(p => p.id);

        const [reportsRes, remRes] = await Promise.all([
          sb.from('client_reports').select('*').in('project_id', projectIds).order('uploaded_at', { ascending: false }),
          sb.from('client_remediation').select('*').in('project_id', projectIds).order('severity_order(severity)', { foreignTable: false }).order('created_at', { ascending: true })
        ]);

        // Group by project
        reportsData = {};
        (reportsRes.data || []).forEach(r => {
          if (!reportsData[r.project_id]) reportsData[r.project_id] = [];
          reportsData[r.project_id].push(r);
        });

        remediationData = {};
        (remRes.data || []).forEach(r => {
          if (!remediationData[r.project_id]) remediationData[r.project_id] = [];
          remediationData[r.project_id].push(r);
        });
      }

      renderDashboard();
      setupRealtime();
    } catch (err) {
      console.error('Error loading projects:', err);
      projectsData = [];
      renderDashboard();
    }
  }

  // ---- Realtime ----
  function setupRealtime() {
    if (!sb || !currentUser) return;

    sb.channel('portal-changes')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'client_projects' }, () => loadProjects())
      .on('postgres_changes', { event: '*', schema: 'public', table: 'client_reports' }, () => loadProjects())
      .on('postgres_changes', { event: '*', schema: 'public', table: 'client_remediation' }, () => loadProjects())
      .subscribe();
  }

  // ---- Render ----
  function renderDashboard() {
    // Stats
    const activeCount = projectsData.filter(p => p.status !== 'completed').length;
    const totalFindings = projectsData.reduce((sum, p) =>
      sum + (p.findings_critical || 0) + (p.findings_high || 0) + (p.findings_medium || 0) + (p.findings_low || 0) + (p.findings_info || 0), 0);
    const avgRemediation = projectsData.length
      ? Math.round(projectsData.reduce((sum, p) => sum + (p.remediation_progress || 0), 0) / projectsData.length)
      : 0;
    const totalReports = Object.values(reportsData).reduce((sum, arr) => sum + arr.length, 0);

    document.getElementById('ptl-stat-active').textContent = activeCount;
    document.getElementById('ptl-stat-findings').textContent = totalFindings;
    document.getElementById('ptl-stat-resolved').textContent = avgRemediation + '%';
    document.getElementById('ptl-stat-reports').textContent = totalReports;

    // Projects
    if (projectsData.length === 0) {
      projectsEl.style.display = 'none';
      document.getElementById('ptl-stats').style.display = 'none';
      emptyEl.style.display = '';
      return;
    }

    projectsEl.style.display = '';
    document.getElementById('ptl-stats').style.display = '';
    emptyEl.style.display = 'none';

    projectsEl.innerHTML = projectsData.map(p => renderProjectCard(p)).join('');

    // Attach expand handlers
    projectsEl.querySelectorAll('.ptl-project-header').forEach(header => {
      header.addEventListener('click', () => {
        header.closest('.ptl-project-card').classList.toggle('ptl-expanded');
      });
    });

    // Attach status change handlers
    projectsEl.querySelectorAll('.ptl-status-select').forEach(select => {
      select.addEventListener('change', async (e) => {
        const remId = e.target.dataset.remId;
        const newStatus = e.target.value;
        try {
          const updates = { status: newStatus };
          if (newStatus === 'resolved') updates.resolved_at = new Date().toISOString();
          await sb.from('client_remediation').update(updates).eq('id', remId);
        } catch (err) {
          console.error('Error updating status:', err);
        }
      });
    });
  }

  function renderProjectCard(project) {
    const reports = reportsData[project.id] || [];
    const remediation = remediationData[project.id] || [];
    const statusLabel = (project.status || '').replace('_', ' ');

    const findingsPills = [
      { key: 'critical', count: project.findings_critical, cls: 'ptl-sev-critical', label: 'C' },
      { key: 'high', count: project.findings_high, cls: 'ptl-sev-high', label: 'H' },
      { key: 'medium', count: project.findings_medium, cls: 'ptl-sev-medium', label: 'M' },
      { key: 'low', count: project.findings_low, cls: 'ptl-sev-low', label: 'L' },
      { key: 'info', count: project.findings_info, cls: 'ptl-sev-info', label: 'I' },
    ].filter(f => f.count > 0).map(f =>
      '<span class="ptl-finding-pill ' + f.cls + '">' + f.label + ' ' + f.count + '</span>'
    ).join('');

    const dateRange = [
      project.start_date ? formatDate(project.start_date) : '',
      project.target_end_date ? formatDate(project.target_end_date) : ''
    ].filter(Boolean).join(' — ');

    const typeLabels = { vapt: 'VAPT', 'iso-27001': 'ISO 27001', training: 'Training', consultation: 'Consultation' };

    return `
      <div class="ptl-project-card">
        <div class="ptl-project-header">
          <div class="ptl-project-info">
            <div class="ptl-project-top-row">
              <span class="ptl-project-name">${esc(project.project_name)}</span>
              <span class="ptl-badge ptl-badge-${project.status}">${esc(statusLabel)}</span>
              <span class="ptl-type-badge">${esc(typeLabels[project.project_type] || project.project_type)}</span>
            </div>
            <div class="ptl-project-meta">
              ${dateRange ? '<span class="ptl-meta-item">' + esc(dateRange) + '</span>' : ''}
              ${findingsPills ? '<div class="ptl-findings-row">' + findingsPills + '</div>' : ''}
              <div class="ptl-progress-wrapper">
                <div class="ptl-progress-bar"><div class="ptl-progress-fill" style="width:${project.remediation_progress || 0}%"></div></div>
                <span class="ptl-progress-text">${project.remediation_progress || 0}%</span>
              </div>
            </div>
          </div>
          <svg class="ptl-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="ptl-project-body">
          ${project.scope_summary ? '<div class="ptl-section-title">Scope</div><p class="ptl-scope-text">' + esc(project.scope_summary) + '</p>' : ''}

          <div class="ptl-section-title">Reports (${reports.length})</div>
          ${reports.length ? '<div class="ptl-reports-list">' + reports.map(r => renderReport(r)).join('') + '</div>' : '<p class="ptl-no-items">No reports uploaded yet.</p>'}

          <div class="ptl-section-title">Remediation Items (${remediation.length})</div>
          ${remediation.length ? '<div class="ptl-remediation-list">' + remediation.map(r => renderRemediation(r)).join('') + '</div>' : '<p class="ptl-no-items">No findings to remediate.</p>'}

          <div class="ptl-actions">
            <a href="https://calendly.com" target="_blank" rel="noopener noreferrer" class="ptl-btn ptl-btn-small ptl-btn-retest">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.78 7.78 5.5 5.5 0 0 1 7.78-7.78zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
              Schedule Retest
            </a>
          </div>
        </div>
      </div>
    `;
  }

  function renderReport(report) {
    const typeLabels = { initial: 'Initial Report', retest: 'Retest Report', executive_summary: 'Executive Summary', remediation_guide: 'Remediation Guide' };
    const size = report.file_size_bytes ? formatBytes(report.file_size_bytes) : '';
    const date = report.uploaded_at ? formatDate(report.uploaded_at) : '';

    return `
      <div class="ptl-report-item">
        <div class="ptl-report-info">
          <div class="ptl-report-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div>
            <div class="ptl-report-name">${esc(report.report_name)}</div>
            <div class="ptl-report-meta">${esc(typeLabels[report.report_type] || report.report_type)}${size ? ' &middot; ' + esc(size) : ''}${date ? ' &middot; ' + esc(date) : ''}</div>
          </div>
        </div>
        <a href="${esc(report.file_path)}" target="_blank" rel="noopener noreferrer" class="ptl-report-download">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
      </div>
    `;
  }

  function renderRemediation(item) {
    const sevCls = 'ptl-sev-' + item.severity;
    const statCls = 'ptl-rstat-' + item.status;

    return `
      <div class="ptl-remediation-item">
        <div class="ptl-remediation-status ${statCls}"></div>
        <div class="ptl-remediation-content">
          <div class="ptl-remediation-title">${esc(item.finding_title)}</div>
          ${item.description ? '<div class="ptl-remediation-desc">' + esc(item.description) + '</div>' : ''}
          ${item.recommendation ? '<div class="ptl-remediation-rec">Rec: ' + esc(item.recommendation) + '</div>' : ''}
        </div>
        <div class="ptl-remediation-badges">
          <span class="ptl-finding-pill ${sevCls}">${esc(item.severity)}</span>
          <select class="ptl-status-select" data-rem-id="${esc(item.id)}">
            <option value="open"${item.status === 'open' ? ' selected' : ''}>Open</option>
            <option value="in_progress"${item.status === 'in_progress' ? ' selected' : ''}>In Progress</option>
            <option value="resolved"${item.status === 'resolved' ? ' selected' : ''}>Resolved</option>
            <option value="accepted_risk"${item.status === 'accepted_risk' ? ' selected' : ''}>Accepted Risk</option>
          </select>
        </div>
      </div>
    `;
  }

  // ---- Helpers ----
  function formatDate(dateStr) {
    try {
      const d = new Date(dateStr);
      return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
    } catch { return dateStr; }
  }

  function formatBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function esc(str) {
    if (!str) return '';
    const d = document.createElement('div');
    d.textContent = String(str);
    return d.innerHTML;
  }

  // ---- Boot ----
  init();
})();
</script>

