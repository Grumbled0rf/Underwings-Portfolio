---
// ===========================================
// 500 SERVER ERROR PAGE
// Underwings Technologies
// ===========================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Server Error | Underwings Technologies"
  description="Something went wrong on our end."
  schema={null}
  bodyClass="body"
>
  <Header />

  <main id="main" class="main">
    <section class="section top-padding-large bottom-padding-large server-error-fade-in" style="position: relative; min-height: 60vh; display: flex; align-items: center;">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium" style="text-align: center;">
        <div class="error-code">500</div>
        <h1 class="heading" style="margin-bottom: 1rem;">Something went wrong</h1>
        <p class="text" style="color: rgba(255,255,255,0.5); max-width: 440px; margin: 0 auto 2.5rem;">We're experiencing a temporary issue on our end. Please try again in a moment.</p>
        <div class="error-links">
          <a href="/" class="error-link">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 6l6-4 6 4v7a1 1 0 01-1 1H3a1 1 0 01-1-1V6z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M6 14V9h4v5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Homepage
          </a>
          <a href="/#contact" class="error-link error-link-primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="1" stroke="currentColor" stroke-width="1.2"/><path d="M2 5l6 4 6-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Report Issue
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:inline>
  @keyframes serverErrorFadeIn {
    from { opacity: 0; filter: blur(3px); transform: translateY(10px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }
  .server-error-fade-in {
    animation: serverErrorFadeIn 0.6s ease-out forwards;
  }
  .error-code {
    font-size: 6rem;
    font-weight: 700;
    font-family: 'Geist Mono', monospace;
    background: linear-gradient(135deg, #ff5454, #ff8c42);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 1rem;
  }
  .error-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .error-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }
  .error-link:hover {
    border-color: rgba(36,215,88,0.4);
    color: #fff;
    background: rgba(36,215,88,0.06);
  }
  .error-link-primary {
    background: rgba(255,84,84,0.1);
    border-color: rgba(255,84,84,0.3);
    color: #ff8c42;
  }
  .error-link-primary:hover {
    background: rgba(255,84,84,0.15);
    border-color: #ff5454;
    color: #ff8c42;
  }
  @media (max-width: 480px) {
    .error-code { font-size: 4rem; }
    .error-links { flex-direction: column; align-items: center; }
  }
</style>
