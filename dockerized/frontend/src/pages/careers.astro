---
// ===========================================
// CAREERS / JOIN US PAGE
// Underwings Cybersecurity Solutions
// ===========================================

export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase';

// Fetch career openings from Supabase (active + future only via RLS)
let positions: Array<{title: string; location: string; description: string; requirements: string[]; status: string}> = [];
try {
  const { data } = await supabase
    .from('career_openings')
    .select('title, location, description, requirements, status')
    .order('display_order', { ascending: true });
  if (data) positions = data;
} catch {
  // Fallback: page renders with empty positions
}

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://underwings.org" },
      { "@type": "ListItem", "position": 2, "name": "Careers", "item": "https://underwings.org/careers" }
    ]
  }
];
---

<Layout
  title="Careers – Join the Underwings Team | Cybersecurity Jobs India & UAE"
  description="Join Underwings Cybersecurity Solutions. We're hiring penetration testers, security consultants, developers, and sales professionals across India and UAE. Remote-first, startup culture."
  keywords="cybersecurity jobs, penetration tester jobs UAE, security consultant India, infosec careers, cybersecurity startup jobs"
  wfPage="careers-page"
  schema={schema}
  bodyClass="body"
>
  <Header currentPage="careers" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">Careers</div>
              </div>
              <h1 class="heading-large hero-heading-large">Join the <span class="text-gradient-clip bg-color-green-gradient">Underwings</span> Team</h1>
              <p class="text text-center car-hero-subtitle">Build the future of cybersecurity with us. We're a growing startup based in India and the UAE, making real security accessible to businesses everywhere.</p>
              <div class="car-hero-cta">
                <div class="button">
                  <a href="#open-positions" class="button-hidden w-button">View Openings</a>
                  <div class="button-wrapper">
                    <div class="button-text">View Openings</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Join Us -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Why Join Us</div>
          </div>
          <h2 class="heading heading-center">Why <span class="text-gradient-clip bg-color-green-gradient">Underwings</span></h2>
          <div class="car-why-grid">
            <div class="car-why-card car-stagger">
              <div class="car-why-number">01</div>
              <h3 class="car-card-title">Small Team, Big Impact</h3>
              <p class="car-card-desc">No layers of bureaucracy. Your work directly shapes our products, services, and client outcomes. Every person here matters.</p>
            </div>
            <div class="car-why-card car-stagger">
              <div class="car-why-number">02</div>
              <h3 class="car-card-title">Work on Real Engagements</h3>
              <p class="car-card-desc">From day one, you'll work on live pentests, real compliance projects, and production security tools — not theoretical exercises.</p>
            </div>
            <div class="car-why-card car-stagger">
              <div class="car-why-number">03</div>
              <h3 class="car-card-title">Remote-First & Flexible</h3>
              <p class="car-card-desc">Work from anywhere. We care about output, not hours logged. Async communication, flexible schedules, and trust by default.</p>
            </div>
            <div class="car-why-card car-stagger">
              <div class="car-why-number">04</div>
              <h3 class="car-card-title">Startup Culture with Purpose</h3>
              <p class="car-card-desc">We're building something meaningful — making cybersecurity accessible to businesses that can't afford the Big 4. Growth, ownership, and real purpose.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Open Positions -->
    <section id="open-positions" class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Opportunities</div>
          </div>
          <h2 class="heading heading-center">Open <span class="text-gradient-clip bg-color-green-gradient">Positions</span></h2>
          <p class="text-medium color-grey car-positions-subtitle">These roles are planned as we grow. If something catches your eye, reach out early — we'd love to hear from you.</p>

          <div class="car-positions-grid">
            {positions.map((pos) => (
              <div class="car-position-card car-stagger">
                <div class="car-position-header">
                  <span class={pos.status === 'active' ? 'car-active-tag' : 'car-future-tag'}>{pos.status === 'active' ? 'Now Hiring' : 'Future Opening'}</span>
                  <span class="car-location-tag">{pos.location}</span>
                </div>
                <h3 class="car-position-title">{pos.title}</h3>
                <p class="car-position-desc">{pos.description}</p>
                <ul class="car-position-reqs">
                  {pos.requirements.map((req) => (
                    <li>{req}</li>
                  ))}
                </ul>
                <a href="mailto:careers@underwings.org?subject=Interest: {pos.title}" class="car-position-apply">Express Interest</a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- What We Look For -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Our Values</div>
          </div>
          <h2 class="heading heading-center">What We <span class="text-gradient-clip bg-color-green-gradient">Look For</span></h2>
          <div class="car-values-grid">
            <div class="car-value-card car-stagger">
              <div class="car-value-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><circle cx="14" cy="14" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M14 10v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 5l-2-2M18 5l2-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <h3 class="car-card-title">Curiosity</h3>
              <p class="car-card-desc">You ask "why" and "what if" constantly. You dig into problems, read RFCs for fun, and never stop learning.</p>
            </div>
            <div class="car-value-card car-stagger">
              <div class="car-value-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M14 24s8-4 8-10V8l-8-4-8 4v6c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 14l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="car-card-title">Honesty</h3>
              <p class="car-card-desc">We tell clients the truth, even when it's uncomfortable. Integrity is non-negotiable in security work.</p>
            </div>
            <div class="car-value-card car-stagger">
              <div class="car-value-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M13 4L3 14h9l-1 10 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="car-card-title">Self-Starters</h3>
              <p class="car-card-desc">You don't wait to be told what to do. You see a gap, you fill it. Ownership and initiative are in your DNA.</p>
            </div>
            <div class="car-value-card car-stagger">
              <div class="car-value-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M10 18s1.5 2 4 2 4-2 4-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="12" r="1.5" fill="currentColor"/><circle cx="18" cy="12" r="1.5" fill="currentColor"/><circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
              <h3 class="car-card-title">Passion for Security</h3>
              <p class="car-card-desc">Whether it's CTFs, bug bounties, open-source tools, or compliance frameworks — you genuinely care about making things secure.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How to Apply CTA -->
    <section id="cta" class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top" style="text-align: center;">
          <div class="label">
            <div class="text-small color-grey">How to Apply</div>
          </div>
          <h2 class="heading heading-center">Ready to <span class="text-gradient-clip bg-color-green-gradient">Join?</span></h2>
          <p class="text-medium car-cta-text">Send your CV and a short note about why you want to join Underwings. Tell us what excites you about cybersecurity and what you'd bring to the team.</p>
          <div class="car-cta-email">
            <a href="mailto:careers@underwings.org" class="car-email-link">careers@underwings.org</a>
          </div>
          <p class="text-medium color-grey car-cta-alt">You can also reach out to us on <a href="https://www.linkedin.com/company/underwings-technologies" target="_blank" rel="noopener noreferrer" class="car-linkedin-link">LinkedIn</a> — we'd love to connect.</p>
          <div class="car-hero-cta">
            <div class="button" style="display: inline-block;">
              <a href="mailto:careers@underwings.org" class="button-hidden w-button">Send Your Application</a>
              <div class="button-wrapper">
                <div class="button-text">Send Your Application</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:inline>
  /* ---- Hero ---- */
  .car-hero-subtitle {
    max-width: 680px;
    margin: 1.5rem auto;
  }
  .car-hero-cta {
    margin-top: 2rem;
  }

  /* ---- Why Join Us grid ---- */
  .car-why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 3rem;
  }
  .car-why-card {
    padding: 1.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    transition: border-color 0.3s ease;
  }
  .car-why-card:hover {
    border-color: rgba(36,215,88,0.3);
  }
  .car-why-number {
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #24d758, #27dab4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
    line-height: 1;
  }
  .car-card-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .car-card-desc {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.55;
  }
  @media (max-width: 600px) {
    .car-why-grid { grid-template-columns: 1fr; }
  }

  /* ---- Open Positions ---- */
  .car-positions-subtitle {
    max-width: 620px;
    margin: 1rem auto 0;
    text-align: center;
  }
  .car-positions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 3rem;
  }
  .car-position-card {
    padding: 1.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .car-position-card:hover {
    border-color: rgba(36,215,88,0.3);
    transform: translateY(-2px);
  }
  .car-position-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .car-future-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    background: rgba(255,180,0,0.12);
    border: 1px solid rgba(255,180,0,0.3);
    border-radius: 4px;
    color: #ffb400;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }
  .car-active-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    background: rgba(36,215,88,0.12);
    border: 1px solid rgba(36,215,88,0.3);
    border-radius: 4px;
    color: #24d758;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }
  .car-location-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    background: rgba(36,215,88,0.08);
    border: 1px solid rgba(36,215,88,0.2);
    border-radius: 4px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.3px;
  }
  .car-position-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .car-position-desc {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .car-position-reqs {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    flex: 1;
  }
  .car-position-reqs li {
    font-size: 0.7rem;
    padding: 0.2rem 0.55rem;
    background: rgba(36,215,88,0.08);
    border: 1px solid rgba(36,215,88,0.2);
    border-radius: 4px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.3px;
  }
  .car-position-apply {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #24d758;
    text-decoration: none;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    transition: color 0.2s ease;
    margin-top: auto;
  }
  .car-position-apply:hover {
    color: #1db84a;
  }
  @media (max-width: 768px) {
    .car-positions-grid { grid-template-columns: 1fr; }
  }

  /* ---- What We Look For ---- */
  .car-values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 3rem;
  }
  .car-value-card {
    padding: 1.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    transition: border-color 0.3s ease;
  }
  .car-value-card:hover {
    border-color: rgba(36,215,88,0.3);
  }
  .car-value-icon {
    color: #24d758;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 600px) {
    .car-values-grid { grid-template-columns: 1fr; }
  }

  /* ---- CTA ---- */
  .car-cta-text {
    max-width: 620px;
    margin: 1.25rem auto;
    color: rgba(255,255,255,0.7);
    text-align: center;
  }
  .car-cta-email {
    margin: 1.5rem 0 1rem;
  }
  .car-email-link {
    font-size: 1.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, #24d758, #27dab4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .car-email-link:hover {
    opacity: 0.8;
  }
  .car-cta-alt {
    max-width: 500px;
    margin: 0 auto 1.5rem;
    text-align: center;
  }
  .car-linkedin-link {
    color: #24d758;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .car-linkedin-link:hover {
    color: #1db84a;
  }
</style>

<script is:inline nonce={Astro.locals.nonce || ""} src="/js/stagger-animate.js" data-selector=".car-stagger"></script>
