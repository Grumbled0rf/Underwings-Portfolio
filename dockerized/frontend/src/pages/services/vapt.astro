---
// ===========================================
// VAPT SERVICES PAGE
// Underwings Technologies
// ===========================================

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterRedesigned from '../../components/FooterRedesigned.astro';
import PentestDiagram from '../../components/PentestDiagram.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Vulnerability Assessment & Penetration Testing (VAPT)",
  "provider": {
    "@type": "Organization",
    "name": "Underwings Technologies"
  },
  "description": "Comprehensive VAPT services including web application, network, API, mobile, and cloud penetration testing with detailed vulnerability assessments.",
  "areaServed": "United Arab Emirates"
};
---

<Layout
  title="VAPT Services - Vulnerability Assessment & Penetration Testing | Underwings"
  description="Professional VAPT services in UAE. Web application, network, API, and cloud penetration testing. Comprehensive vulnerability assessments with detailed remediation guidance."
  keywords="VAPT UAE, penetration testing Dubai, vulnerability assessment, web application security, API security testing, network penetration testing, cloud security assessment"
  wfPage="vapt-page"
  schema={schema}
>
  <Fragment slot="head">
    <style is:inline>
      .pentest-diagram { width: 100%; height: auto; max-width: 100%; margin-top: 3rem; border-radius: 12px; overflow: visible; }
      .pentest-diagram .phase-node { opacity: 0; animation: fadeInNode 0.5s ease-out forwards; }
      .pentest-diagram .flow-line { opacity: 0; animation: fadeInFlow 0.8s ease-out forwards; animation-delay: 0.3s; }
      .pentest-diagram .pulse-ring { transform-origin: center; animation: pulseRing 2.5s ease-in-out infinite; animation-delay: 1s; }
      @keyframes fadeInNode { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
      @keyframes fadeInFlow { from { opacity: 0; } to { opacity: 0.8; } }
      @keyframes pulseRing { 0%, 100% { opacity: 0.2; transform: scale(1); } 50% { opacity: 0.4; transform: scale(1.08); } }
      .pentest-diagram .phase-node:nth-child(4) { animation-delay: 0.05s; }
      .pentest-diagram .phase-node:nth-child(5) { animation-delay: 0.1s; }
      .pentest-diagram .phase-node:nth-child(6) { animation-delay: 0.15s; }
      .pentest-diagram .phase-node:nth-child(7) { animation-delay: 0.2s; }
      .pentest-diagram .phase-node:nth-child(8) { animation-delay: 0.25s; }
      .pentest-diagram .phase-node:nth-child(9) { animation-delay: 0.3s; }
      .pentest-diagram .phase-node:nth-child(10) { animation-delay: 0.35s; }
      .pentest-diagram .phase-node:nth-child(11) { animation-delay: 0.4s; }
    </style>
  </Fragment>

  <Header currentPage="services" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">VAPT Services</div>
              </div>
              <h1 class="heading-large hero-heading-large">Vulnerability Assessment & <span class="text-gradient-clip bg-color-green-gradient">Penetration Testing</span></h1>
              <p class="text text-center" style="max-width: 700px; margin: 1.5rem auto;">Find and fix security vulnerabilities before attackers exploit them. Our expert team simulates real-world attacks to uncover weaknesses in your systems.</p>
              <!-- Certification Logos & Badges -->
              <div style="display: flex; justify-content: center; align-items: center; gap: 3rem; margin-top: 2.5rem; flex-wrap: wrap;">
                <!-- CPTS Certification -->
                <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
                  <img src="/images/certifications/cpts.png" alt="CPTS - Certified Penetration Testing Specialist" style="width: 100px; height: 100px; object-fit: contain; filter: drop-shadow(0 0 15px rgba(36, 215, 88, 0.4));">
                  <span style="padding: 0.5rem 1rem; border: 1px solid rgba(36, 215, 88, 0.5); border-radius: 20px; font-size: 0.85rem; color: #fff; background: rgba(36, 215, 88, 0.1);">CPTS Certified</span>
                </div>
                <!-- OSCP Certification -->
                <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
                  <img src="https://www.offsec.com/_astro/OSCP-plus.BZHuApYA_Ztlntl.svg" alt="OSCP+ - Offensive Security Certified Professional" style="width: 100px; height: 100px; object-fit: contain; filter: drop-shadow(0 0 15px rgba(36, 215, 88, 0.4));">
                  <span style="padding: 0.5rem 1rem; border: 1px solid rgba(36, 215, 88, 0.5); border-radius: 20px; font-size: 0.85rem; color: #fff; background: rgba(36, 215, 88, 0.1);">OSCP Certified</span>
                </div>
              </div>
              <div style="margin-top: 2rem;">
                <div class="button">
                  <a href="/#contact" class="button-hidden w-button">Request Assessment</a>
                  <div class="button-wrapper">
                    <div class="button-text">Request Assessment</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="section bg-color-dark">
      <div class="container">
        <div class="section-wrapper-vertical section-wrapper-vertical-large">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <h2 class="heading">What We Test</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">Comprehensive security testing across your entire attack surface — from web applications to cloud infrastructure.</p>
              </div>
            </div>
          </div>

          <div class="content-risks">
            <!-- Web Application Testing -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">01</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Web Application Penetration Testing</h3>
                    <p class="text-medium color-grey">OWASP Top 10 coverage, authentication bypass, session management, SQL injection, XSS, CSRF, business logic flaws, and API security testing. We test like real attackers think.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Network Testing -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">02</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Network Penetration Testing</h3>
                    <p class="text-medium color-grey">External and internal network assessments, firewall testing, segmentation validation, lateral movement simulation, and Active Directory security review.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- API Testing -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">03</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">API Security Testing</h3>
                    <p class="text-medium color-grey">REST and GraphQL API testing, authentication flaws, authorization bypass, rate limiting, data exposure, and business logic vulnerabilities in your APIs.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Mobile Testing -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">04</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Mobile Application Testing</h3>
                    <p class="text-medium color-grey">iOS and Android application security assessment, local data storage, certificate pinning, reverse engineering protection, and backend API security.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Cloud Testing -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">05</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Cloud Security Assessment</h3>
                    <p class="text-medium color-grey">AWS, Azure, and GCP security configuration review, IAM policy analysis, storage bucket security, serverless function testing, and cloud infrastructure hardening.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Methodology Section -->
    <section class="section">
      <div class="container">
        <div class="section-wrapper-vertical">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <div class="label">
                  <div class="text-small color-grey">Our Approach</div>
                </div>
                <h2 class="heading">VAPT Methodology</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">We follow industry-standard methodologies (OWASP, PTES, NIST) combined with real-world attack techniques.</p>
              </div>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-top: 3rem;">
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">1.</span> Scoping & Reconnaissance</h3>
              <p class="text-medium color-grey">Define scope, gather intelligence, map attack surface, identify technologies and potential entry points.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">2.</span> Vulnerability Assessment</h3>
              <p class="text-medium color-grey">Automated scanning combined with manual analysis to identify security weaknesses and misconfigurations.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">3.</span> Exploitation & Validation</h3>
              <p class="text-medium color-grey">Safe exploitation of vulnerabilities to validate risk, demonstrate impact, and chain findings.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">4.</span> Reporting & Remediation</h3>
              <p class="text-medium color-grey">Detailed technical report with risk ratings, proof-of-concept, and prioritized remediation guidance.</p>
            </div>
          </div>

          <PentestDiagram />
        </div>
      </div>
    </section>

    <!-- Deliverables -->
    <section class="section bg-color-dark">
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">What You Get</div>
          </div>
          <h2 class="heading heading-center">Comprehensive <span class="text-gradient-clip bg-color-green-gradient">Deliverables</span></h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-top: 3rem; text-align: left;">
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Executive Summary</p>
              <p class="text-small color-grey" style="margin-top: 0.5rem;">High-level findings for management and stakeholders</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Technical Report</p>
              <p class="text-small color-grey" style="margin-top: 0.5rem;">Detailed vulnerability descriptions with proof-of-concept</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Risk Ratings</p>
              <p class="text-small color-grey" style="margin-top: 0.5rem;">CVSS scores and business impact assessment</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Remediation Guidance</p>
              <p class="text-small color-grey" style="margin-top: 0.5rem;">Step-by-step fix recommendations prioritized by risk</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Retest Verification</p>
              <p class="text-small color-grey" style="margin-top: 0.5rem;">Free retest to confirm vulnerabilities are fixed</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Debrief Session</p>
              <p class="text-small color-grey" style="margin-top: 0.5rem;">Walkthrough call with your technical team</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Services -->
    <section class="section">
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Other <span class="text-gradient-clip bg-color-green-gradient">Services</span></h2>
          <div style="display: flex; gap: 2rem; margin-top: 3rem; flex-wrap: wrap; justify-content: center;">
            <a href="/services/iso-27001" class="button" style="text-decoration: none;">
              <div class="button-wrapper">
                <div class="button-text">ISO 27001 Implementation</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </a>
            <a href="/services/training" class="button" style="text-decoration: none;">
              <div class="button-wrapper">
                <div class="button-text">Security Training</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </a>
            <a href="/software" class="button" style="text-decoration: none;">
              <div class="button-wrapper">
                <div class="button-text">Security Software</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="cta" class="section bg-color-dark">
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Ready to Test Your <span class="text-gradient-clip bg-color-green-gradient">Security?</span></h2>
          <p class="text-medium vertical-heading-description" style="max-width: 600px; margin: 1.5rem auto;">Get a comprehensive security assessment tailored to your infrastructure. Contact us for a free scoping call.</p>
          <div style="margin-top: 2rem;">
            <div class="button">
              <a href="/#contact" class="button-hidden w-button">Get Started</a>
              <div class="button-wrapper">
                <div class="button-text">Request Free Consultation</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterRedesigned />
</Layout>
