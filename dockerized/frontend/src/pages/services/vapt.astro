---
// ===========================================
// VAPT SERVICES PAGE
// Underwings Technologies
// ===========================================

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterRedesigned from '../../components/FooterRedesigned.astro';
import PentestDiagram from '../../components/PentestDiagram.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Vulnerability Assessment & Penetration Testing (VAPT)",
  "provider": {
    "@type": "Organization",
    "name": "Underwings Technologies",
    "url": "https://underwings.org"
  },
  "description": "Comprehensive VAPT services including web application, network, API, mobile, and cloud penetration testing with detailed vulnerability assessments.",
  "areaServed": ["IN", "AE"],
  "serviceType": "Penetration Testing"
};
---

<Layout
  title="VAPT Services - Vulnerability Assessment & Penetration Testing | Underwings"
  description="Professional VAPT services in India & UAE. Web application, network, API, and cloud penetration testing. Comprehensive vulnerability assessments with detailed remediation guidance."
  keywords="VAPT UAE, penetration testing Dubai, vulnerability assessment, web application security, API security testing, network penetration testing, cloud security assessment"
  wfPage="vapt-page"
  schema={schema}
  bodyClass="body"
>
  <Fragment slot="head">
    <style is:inline>
      .pentest-diagram { width: 100%; height: auto; max-width: 100%; margin-top: 3rem; border-radius: 12px; overflow: visible; }
      .pentest-diagram .phase-node { opacity: 0; animation: fadeInNode 0.5s ease-out forwards; }
      .pentest-diagram .flow-line { opacity: 0; animation: fadeInFlow 0.8s ease-out forwards; animation-delay: 0.3s; }
      .pentest-diagram .pulse-ring { transform-origin: center; animation: pulseRing 2.5s ease-in-out infinite; animation-delay: 1s; }
      @keyframes fadeInNode { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
      @keyframes fadeInFlow { from { opacity: 0; } to { opacity: 0.8; } }
      @keyframes pulseRing { 0%, 100% { opacity: 0.2; transform: scale(1); } 50% { opacity: 0.4; transform: scale(1.08); } }
      .pentest-diagram .phase-node:nth-child(4) { animation-delay: 0.05s; }
      .pentest-diagram .phase-node:nth-child(5) { animation-delay: 0.1s; }
      .pentest-diagram .phase-node:nth-child(6) { animation-delay: 0.15s; }
      .pentest-diagram .phase-node:nth-child(7) { animation-delay: 0.2s; }
      .pentest-diagram .phase-node:nth-child(8) { animation-delay: 0.25s; }
      .pentest-diagram .phase-node:nth-child(9) { animation-delay: 0.3s; }
      .pentest-diagram .phase-node:nth-child(10) { animation-delay: 0.35s; }
      .pentest-diagram .phase-node:nth-child(11) { animation-delay: 0.4s; }
    </style>
  </Fragment>

  <Header currentPage="services" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">VAPT Services</div>
              </div>
              <h1 class="heading-large hero-heading-large">Vulnerability Assessment & <span class="text-gradient-clip bg-color-green-gradient">Penetration Testing</span></h1>
              <p class="text text-center" style="max-width: 700px; margin: 1.5rem auto;">Find and fix security vulnerabilities before attackers exploit them. Our expert team simulates real-world attacks to uncover weaknesses in your systems.</p>
              <!-- Certification Badges -->
              <div style="display: flex; justify-content: center; align-items: center; gap: 3rem; margin-top: 2.5rem; flex-wrap: wrap;">
                <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
                  <img src="/images/certifications/cpts.png" alt="CPTS - Certified Penetration Testing Specialist" loading="lazy" style="width: 100px; height: 100px; object-fit: contain; filter: drop-shadow(0 0 15px rgba(36, 215, 88, 0.4));">
                  <span style="padding: 0.5rem 1rem; border: 1px solid rgba(36, 215, 88, 0.5); border-radius: 20px; font-size: 0.85rem; color: #fff; background: rgba(36, 215, 88, 0.1);">CPTS Certified</span>
                </div>
                <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
                  <img src="/images/certifications/oscp.png" alt="OSCP - Offensive Security Certified Professional" loading="lazy" style="width: 90px; height: 90px; object-fit: contain; filter: drop-shadow(0 0 12px rgba(36, 215, 88, 0.5)) drop-shadow(0 0 25px rgba(36, 215, 88, 0.3));">
                  <span style="padding: 0.5rem 1rem; border: 1px solid rgba(36, 215, 88, 0.5); border-radius: 20px; font-size: 0.85rem; color: #fff; background: rgba(36, 215, 88, 0.1);">OSCP Certified</span>
                </div>
              </div>
              <div style="margin-top: 2rem;">
                <div class="button">
                  <a href="/#contact" class="button-hidden w-button">Request Assessment</a>
                  <div class="button-wrapper">
                    <div class="button-text">Request Assessment</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="section-wrapper-vertical section-wrapper-vertical-large">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <h2 class="heading">What We Test</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">Comprehensive security testing across your entire attack surface — from web applications to cloud infrastructure.</p>
              </div>
            </div>
          </div>

          <div class="vapt-test-grid">
            <!-- Web Application -->
            <div class="vapt-test-card vapt-stagger">
              <div class="vapt-test-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="4" width="22" height="16" rx="2.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 24h8M14 20v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 10l2 2 3-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 10h4M16 13h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.5"/></svg>
              </div>
              <h3 class="vapt-test-title">Web Application Testing</h3>
              <p class="vapt-test-desc">OWASP Top 10 coverage, authentication bypass, session management, business logic flaws. We test like real attackers think.</p>
              <div class="vapt-test-tags">
                <span>SQLi</span><span>XSS</span><span>CSRF</span><span>IDOR</span><span>Auth Bypass</span>
              </div>
            </div>

            <!-- Network -->
            <div class="vapt-test-card vapt-stagger">
              <div class="vapt-test-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="6" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="6" cy="22" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="22" cy="22" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M14 9v4M10 18l-2 2M18 18l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="9" y="13" width="10" height="5" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
              <h3 class="vapt-test-title">Network Penetration Testing</h3>
              <p class="vapt-test-desc">External and internal assessments, firewall testing, segmentation validation, lateral movement, and Active Directory review.</p>
              <div class="vapt-test-tags">
                <span>External</span><span>Internal</span><span>AD</span><span>Lateral Movement</span>
              </div>
            </div>

            <!-- API -->
            <div class="vapt-test-card vapt-stagger">
              <div class="vapt-test-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M7 8h14M7 14h14M7 20h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="21" cy="8" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="21" cy="14" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="21" cy="20" r="2" stroke="currentColor" stroke-width="1.3"/></svg>
              </div>
              <h3 class="vapt-test-title">API Security Testing</h3>
              <p class="vapt-test-desc">REST and GraphQL testing, authentication flaws, authorization bypass, rate limiting, and data exposure in your endpoints.</p>
              <div class="vapt-test-tags">
                <span>REST</span><span>GraphQL</span><span>BOLA</span><span>Rate Limit</span>
              </div>
            </div>

            <!-- Mobile -->
            <div class="vapt-test-card vapt-stagger">
              <div class="vapt-test-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="8" y="3" width="12" height="22" rx="2.5" stroke="currentColor" stroke-width="1.5"/><path d="M14 21h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M12 7h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.5"/></svg>
              </div>
              <h3 class="vapt-test-title">Mobile Application Testing</h3>
              <p class="vapt-test-desc">iOS and Android security — local data storage, certificate pinning, reverse engineering protection, and backend API calls.</p>
              <div class="vapt-test-tags">
                <span>iOS</span><span>Android</span><span>SSL Pinning</span><span>Data Storage</span>
              </div>
            </div>

            <!-- Cloud -->
            <div class="vapt-test-card vapt-stagger">
              <div class="vapt-test-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M8 20a5 5 0 01-.5-9.96A7 7 0 0121 12h1a4 4 0 01.5 7.96" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 22v-4M16 22v-6M20 22v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <h3 class="vapt-test-title">Cloud Security Assessment</h3>
              <p class="vapt-test-desc">AWS, Azure, and GCP configuration review, IAM policy analysis, storage security, serverless testing, and infrastructure hardening.</p>
              <div class="vapt-test-tags">
                <span>AWS</span><span>Azure</span><span>GCP</span><span>IAM</span><span>S3</span>
              </div>
            </div>

            <!-- Wireless / Social Engineering -->
            <div class="vapt-test-card vapt-stagger">
              <div class="vapt-test-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M8 12a8.5 8.5 0 0112 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M11 15a4.5 4.5 0 016 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="19" r="1.5" fill="currentColor"/><path d="M5 9a12.5 12.5 0 0118 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/></svg>
              </div>
              <h3 class="vapt-test-title">Wireless & Social Engineering</h3>
              <p class="vapt-test-desc">Wi-Fi security audits, rogue AP detection, phishing simulations, physical security testing, and employee awareness validation.</p>
              <div class="vapt-test-tags">
                <span>Wi-Fi</span><span>Phishing</span><span>Vishing</span><span>Physical</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Methodology Section -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="section-wrapper-vertical">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <div class="label">
                  <div class="text-small color-grey">Our Approach</div>
                </div>
                <h2 class="heading">VAPT Methodology</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">We follow industry-standard methodologies (OWASP, PTES, NIST) combined with real-world attack techniques.</p>
              </div>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 3rem;">
            <div class="dashed-banner-card vapt-stagger">
              <div class="vapt-step-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M16 16l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">1.</span> Scoping & Reconnaissance</h3>
              <p class="text-medium color-grey">Define scope, gather intelligence, map attack surface, identify technologies and potential entry points.</p>
            </div>
            <div class="dashed-banner-card vapt-stagger">
              <div class="vapt-step-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L3 7l9 5 9-5-9-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 17l9 5 9-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 12l9 5 9-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">2.</span> Vulnerability Assessment</h3>
              <p class="text-medium color-grey">Automated scanning combined with manual analysis to identify security weaknesses and misconfigurations.</p>
            </div>
            <div class="dashed-banner-card vapt-stagger">
              <div class="vapt-step-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">3.</span> Exploitation & Validation</h3>
              <p class="text-medium color-grey">Safe exploitation of vulnerabilities to validate risk, demonstrate impact, and chain findings.</p>
            </div>
            <div class="dashed-banner-card vapt-stagger">
              <div class="vapt-step-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">4.</span> Reporting & Remediation</h3>
              <p class="text-medium color-grey">Detailed technical report with risk ratings, proof-of-concept, and prioritized remediation guidance.</p>
            </div>
          </div>

          <PentestDiagram />
        </div>
      </div>
    </section>

    <!-- Deliverables -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">What You Get</div>
          </div>
          <h2 class="heading heading-center">Comprehensive <span class="text-gradient-clip bg-color-green-gradient">Deliverables</span></h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.25rem; margin-top: 3rem; text-align: left;">
            <div class="vapt-deliverable vapt-stagger">
              <div class="vapt-deliverable-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="3" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M6 7h8M6 10h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Executive Summary</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">High-level findings for management and stakeholders</p>
              </div>
            </div>
            <div class="vapt-deliverable vapt-stagger">
              <div class="vapt-deliverable-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M11 2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5"/><path d="M11 2v6h6" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Technical Report</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Detailed vulnerability descriptions with proof-of-concept</p>
              </div>
            </div>
            <div class="vapt-deliverable vapt-stagger">
              <div class="vapt-deliverable-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2v16M2 10h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Risk Ratings</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">CVSS scores and business impact assessment</p>
              </div>
            </div>
            <div class="vapt-deliverable vapt-stagger">
              <div class="vapt-deliverable-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 18a8 8 0 100-16 8 8 0 000 16z" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Remediation Guidance</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Step-by-step fix recommendations prioritized by risk</p>
              </div>
            </div>
            <div class="vapt-deliverable vapt-stagger">
              <div class="vapt-deliverable-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M17 3l-10 10-4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 10v6a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Retest Verification</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Free retest to confirm vulnerabilities are fixed</p>
              </div>
            </div>
            <div class="vapt-deliverable vapt-stagger">
              <div class="vapt-deliverable-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M17 10c0 4-3.5 7-7 7s-7-3-7-7 3.5-7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 2v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Debrief Session</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Walkthrough call with your technical team</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Services -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Explore Other <span class="text-gradient-clip bg-color-green-gradient">Services</span></h2>
          <div class="svc-cross-grid">
            <a href="/services/iso-27001" class="svc-cross-card vapt-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7l3-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="svc-cross-title">ISO 27001 Implementation</h3>
              <p class="svc-cross-desc">End-to-end compliance — gap assessment to certification audit support.</p>
            </a>
            <a href="/services/training" class="svc-cross-card vapt-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 14l9-5-9-5-9 5 9 5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 14v7" stroke="currentColor" stroke-width="1.5"/><path d="M21 9v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M5.5 11.5v5c0 1.4 2.9 2.5 6.5 2.5s6.5-1.1 6.5-2.5v-5" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
              <h3 class="svc-cross-title">Security Training</h3>
              <p class="svc-cross-desc">Turn employees into your strongest defence with awareness programs.</p>
            </a>
            <a href="/software" class="svc-cross-card vapt-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <h3 class="svc-cross-title">Security Software</h3>
              <p class="svc-cross-desc">Enterprise tools — endpoint, SIEM, email & network security deployed right.</p>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="cta" class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
