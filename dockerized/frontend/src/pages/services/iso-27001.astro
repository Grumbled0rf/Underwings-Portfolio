---
// ===========================================
// ISO 27001 IMPLEMENTATION PAGE
// Underwings Technologies
// ===========================================

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterRedesigned from '../../components/FooterRedesigned.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "ISO 27001 Implementation & Certification",
  "provider": {
    "@type": "Organization",
    "name": "Underwings Technologies",
    "url": "https://underwings.org"
  },
  "description": "Complete ISO 27001 ISMS implementation services from gap assessment to certification support.",
  "areaServed": ["IN", "AE"],
  "serviceType": "ISO 27001 Compliance"
};
---

<Layout
  title="ISO 27001 Implementation & Certification | Underwings"
  description="End-to-end ISO 27001 implementation services in India & UAE. Gap assessment, policy development, control implementation, and audit preparation. Get certified faster."
  keywords="ISO 27001 UAE, ISO 27001 implementation Dubai, ISMS implementation, ISO certification UAE, information security management, compliance services UAE, ISO 27001 India"
  wfPage="iso27001-page"
  schema={schema}
  bodyClass="body"
>

  <Header currentPage="services" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">Compliance Services</div>
              </div>
              <h1 class="heading-large hero-heading-large">ISO 27001 <span class="text-gradient-clip bg-color-green-gradient">Implementation</span></h1>
              <p class="text text-center" style="max-width: 700px; margin: 1.5rem auto;">From gap assessment to certification — we guide you through the entire ISO 27001 journey. Build a robust Information Security Management System that protects your business.</p>
              <!-- Trust badge -->
              <div style="display: flex; justify-content: center; margin-top: 2rem;">
                <span style="padding: 0.5rem 1.25rem; border: 1px solid rgba(36,215,88,0.5); border-radius: 20px; font-size: 0.85rem; color: #fff; background: rgba(36,215,88,0.1); display: inline-flex; align-items: center; gap: 0.5rem;">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1l2 3h3.5L11 7l1 3.5L8 8.5 4 10.5 5 7 2.5 4H6L8 1z" stroke="#24d758" stroke-width="1.2" stroke-linejoin="round"/></svg>
                  ISO 27001 Lead Auditor Certified
                </span>
              </div>
              <div style="margin-top: 1.5rem;">
                <div class="button">
                  <a href="/#contact" class="button-hidden w-button">Start Your Journey</a>
                  <div class="button-wrapper">
                    <div class="button-text">Start Your Journey</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why ISO 27001 -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="section-wrapper-vertical">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <h2 class="heading">Why ISO 27001?</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">ISO 27001 is the international standard for information security. Certification demonstrates your commitment to protecting data.</p>
              </div>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 3rem;">
            <div class="dashed-banner-card iso-stagger">
              <div class="iso-benefit-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Win More Business</h3>
              <p class="text-medium color-grey">Many enterprises and government entities require ISO 27001 from their vendors. Open doors to larger contracts.</p>
            </div>
            <div class="dashed-banner-card iso-stagger">
              <div class="iso-benefit-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Reduce Risk</h3>
              <p class="text-medium color-grey">Systematic approach to identifying, assessing, and treating information security risks across your organization.</p>
            </div>
            <div class="dashed-banner-card iso-stagger">
              <div class="iso-benefit-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 3v18M3 9h18" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Regulatory Alignment</h3>
              <p class="text-medium color-grey">Satisfies requirements of GDPR, HIPAA, PCI DSS, and UAE data protection regulations with a single framework.</p>
            </div>
            <div class="dashed-banner-card iso-stagger">
              <div class="iso-benefit-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <h3 class="heading-small" style="margin-bottom: 0.75rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Build Trust</h3>
              <p class="text-medium color-grey">Third-party certified proof that you take information security seriously. Builds confidence with customers and partners.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Implementation Process -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="section-wrapper-vertical section-wrapper-vertical-large">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <div class="label">
                  <div class="text-small color-grey">Our Process</div>
                </div>
                <h2 class="heading">Implementation Roadmap</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">A structured approach to get you from current state to certified — efficiently and without the chaos.</p>
              </div>
            </div>
          </div>

          <div class="content-risks">
            <div class="content-risks-item iso-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">01</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Gap Assessment</h3>
                <p class="text-medium color-grey">Evaluate your current security posture against ISO 27001 requirements. Identify gaps, prioritize actions, and create a realistic implementation roadmap.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item iso-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">02</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">ISMS Design & Documentation</h3>
                <p class="text-medium color-grey">Develop your Information Security Management System — scope definition, risk assessment methodology, security policies, and procedures tailored to your business.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item iso-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">03</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Risk Assessment & Treatment</h3>
                <p class="text-medium color-grey">Comprehensive risk assessment covering all information assets. Develop risk treatment plans and select appropriate controls from Annex A.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item iso-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">04</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Control Implementation</h3>
                <p class="text-medium color-grey">Implement technical and organizational controls. Configure security tools, train staff, and establish operational processes.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item iso-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">05</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Internal Audit & Management Review</h3>
                <p class="text-medium color-grey">Conduct internal audits to verify compliance. Perform management review to ensure ISMS effectiveness and readiness for certification.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item iso-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">06</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Certification Audit Support</h3>
                <p class="text-medium color-grey">Prepare for and support you through Stage 1 and Stage 2 certification audits. Address any findings and achieve your ISO 27001 certificate.</p>
              </div></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Deliver -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Deliverables</div>
          </div>
          <h2 class="heading heading-center">Complete <span class="text-gradient-clip bg-color-green-gradient">Documentation Package</span></h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.25rem; margin-top: 3rem; text-align: left;">
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M14 2H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.3"/><path d="M7 6h4M7 9h4M7 12h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">ISMS Manual</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Core document defining your security management system</p>
              </div>
            </div>
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 3h12v12H3z" stroke="currentColor" stroke-width="1.3"/><path d="M3 7h12M7 7v8" stroke="currentColor" stroke-width="1.3"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Security Policies (20+)</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Access control, encryption, HR security, incident management & more</p>
              </div>
            </div>
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M9 5v4l3 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Risk Assessment Report</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Full inventory of threats, vulnerabilities & risk treatment decisions</p>
              </div>
            </div>
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4l2-4z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Statement of Applicability</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Annex A control selection justification & implementation status</p>
              </div>
            </div>
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M2 13l5-5 3 3 6-6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 5h4v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Risk Treatment Plan</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Prioritized action plan to address identified risks</p>
              </div>
            </div>
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 2v14h10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M7 10l3-3 4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Procedures & Work Instructions</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Step-by-step operational procedures for all key processes</p>
              </div>
            </div>
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 16a7 7 0 100-14 7 7 0 000 14z" stroke="currentColor" stroke-width="1.3"/><path d="M6 9l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Internal Audit Reports</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Pre-certification audit findings with corrective actions</p>
              </div>
            </div>
            <div class="iso-deliverable iso-stagger">
              <div class="iso-deliverable-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M15 11v4a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M12 2h4v4M8 10l8-8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Management Review Records</p>
                <p class="text-small color-grey" style="margin-top: 0.25rem;">Executive review documentation meeting audit requirements</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Services -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Explore Other <span class="text-gradient-clip bg-color-green-gradient">Services</span></h2>
          <div class="svc-cross-grid">
            <a href="/services/vapt" class="svc-cross-card iso-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="svc-cross-title">VAPT Services</h3>
              <p class="svc-cross-desc">Find vulnerabilities before attackers do — web, network, API & cloud testing.</p>
            </a>
            <a href="/services/training" class="svc-cross-card iso-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 14l9-5-9-5-9 5 9 5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 14v7" stroke="currentColor" stroke-width="1.5"/><path d="M21 9v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M5.5 11.5v5c0 1.4 2.9 2.5 6.5 2.5s6.5-1.1 6.5-2.5v-5" stroke="currentColor" stroke-width="1.5"/></svg>
              </div>
              <h3 class="svc-cross-title">Security Training</h3>
              <p class="svc-cross-desc">Turn employees into your strongest defence with awareness programs.</p>
            </a>
            <a href="/software" class="svc-cross-card iso-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <h3 class="svc-cross-title">Security Software</h3>
              <p class="svc-cross-desc">Enterprise tools — endpoint, SIEM, email & network security deployed right.</p>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="cta" class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top" style="text-align: center;">
          <h2 class="heading heading-center">Start Your ISO 27001 <span class="text-gradient-clip bg-color-green-gradient">Journey</span></h2>
          <p class="text-medium" style="max-width: 600px; margin: 1.25rem auto; color: rgba(255,255,255,0.5); text-align: center;">Get a free gap assessment to understand where you stand and what it takes to get certified.</p>
          <div style="margin-top: 2rem;">
            <div class="button" style="display: inline-block;">
              <a href="/#contact" class="button-hidden w-button">Get Started</a>
              <div class="button-wrapper">
                <div class="button-text">Request Gap Assessment</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterRedesigned />

</Layout>

<style is:inline>
  /* ---- Benefit icons ---- */
  .iso-benefit-icon {
    color: #24d758;
    margin-bottom: 1rem;
  }

  /* ---- Deliverables ---- */
  .iso-deliverable {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px dashed var(--colors--dashed-grey);
    border-radius: 8px;
    transition: border-color 0.3s ease;
  }
  .iso-deliverable:hover {
    border-color: rgba(36,215,88,0.35);
  }
  .iso-deliverable-icon {
    color: #24d758;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  /* ---- Cross-link service cards ---- */
  .svc-cross-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .svc-cross-card {
    padding: 1.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .svc-cross-card:hover {
    border-color: rgba(36,215,88,0.3);
    transform: translateY(-2px);
  }
  .svc-cross-icon {
    color: #24d758;
    margin-bottom: 1rem;
  }
  .svc-cross-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .svc-cross-desc {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .svc-cross-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  (function() {
    if (typeof IntersectionObserver === 'undefined') return;
    var items = document.querySelectorAll('.iso-stagger');
    items.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(16px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var parent = entry.target.parentElement;
          var siblings = parent ? Array.from(parent.children).filter(function(c) { return c.classList && c.classList.contains('iso-stagger') && c.style.opacity === '0'; }) : [];
          var idx = siblings.indexOf(entry.target);
          setTimeout(function() {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }, Math.max(0, idx) * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(el) { observer.observe(el); });
  })();
</script>
