---
// ===========================================
// ISO 27001 IMPLEMENTATION PAGE
// Underwings Technologies
// ===========================================

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterRedesigned from '../../components/FooterRedesigned.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "ISO 27001 Implementation & Certification",
  "provider": {
    "@type": "Organization",
    "name": "Underwings Technologies"
  },
  "description": "Complete ISO 27001 ISMS implementation services from gap assessment to certification support.",
  "areaServed": "United Arab Emirates"
};
---

<Layout
  title="ISO 27001 Implementation & Certification | Underwings"
  description="End-to-end ISO 27001 implementation services in UAE. Gap assessment, policy development, control implementation, and audit preparation. Get certified faster."
  keywords="ISO 27001 UAE, ISO 27001 implementation Dubai, ISMS implementation, ISO certification UAE, information security management, compliance services UAE, SOC 2 UAE"
  wfPage="iso27001-page"
  schema={schema}
  bodyClass="body"
>

  <Header currentPage="services" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">Compliance Services</div>
              </div>
              <h1 class="heading-large hero-heading-large">ISO 27001 <span class="text-gradient-clip bg-color-green-gradient">Implementation</span></h1>
              <p class="text text-center" style="max-width: 700px; margin: 1.5rem auto;">From gap assessment to certification — we guide you through the entire ISO 27001 journey. Build a robust Information Security Management System (ISMS) that protects your business.</p>
              <div style="margin-top: 2rem;">
                <div class="button">
                  <a href="/#contact" class="button-hidden w-button">Start Your Journey</a>
                  <div class="button-wrapper">
                    <div class="button-text">Start Your Journey</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why ISO 27001 -->
    <section class="section bg-color-dark">
      <div class="container">
        <div class="section-wrapper-vertical">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <h2 class="heading">Why ISO 27001?</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">ISO 27001 is the international standard for information security. Certification demonstrates your commitment to protecting data.</p>
              </div>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-top: 3rem;">
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Win More Business</h3>
              <p class="text-medium color-grey">Many enterprises and government entities require ISO 27001 certification from their vendors. Open doors to larger contracts.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Reduce Risk</h3>
              <p class="text-medium color-grey">Systematic approach to identifying, assessing, and treating information security risks across your organization.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Regulatory Alignment</h3>
              <p class="text-medium color-grey">Satisfies requirements of GDPR, HIPAA, PCI DSS, and UAE data protection regulations with a single framework.</p>
            </div>
            <div class="dashed-banner-card">
              <h3 class="heading-small" style="margin-bottom: 1rem;"><span class="text-gradient-clip bg-color-green-gradient">+</span> Build Trust</h3>
              <p class="text-medium color-grey">Third-party certified proof that you take information security seriously. Builds confidence with customers and partners.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Implementation Process -->
    <section class="section">
      <div class="container">
        <div class="section-wrapper-vertical section-wrapper-vertical-large">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <div class="label">
                  <div class="text-small color-grey">Our Process</div>
                </div>
                <h2 class="heading">Implementation Roadmap</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">A structured approach to get you from current state to certified — efficiently and without the chaos.</p>
              </div>
            </div>
          </div>

          <div class="content-risks">
            <!-- Phase 1 -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">01</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Gap Assessment</h3>
                    <p class="text-medium color-grey">Evaluate your current security posture against ISO 27001 requirements. Identify gaps, prioritize actions, and create a realistic implementation roadmap.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Phase 2 -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">02</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">ISMS Design & Documentation</h3>
                    <p class="text-medium color-grey">Develop your Information Security Management System — scope definition, risk assessment methodology, security policies, and procedures tailored to your business.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Phase 3 -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">03</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Risk Assessment & Treatment</h3>
                    <p class="text-medium color-grey">Comprehensive risk assessment covering all information assets. Develop risk treatment plans and select appropriate controls from Annex A.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Phase 4 -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">04</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Control Implementation</h3>
                    <p class="text-medium color-grey">Implement technical and organizational controls. Configure security tools, train staff, and establish operational processes.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Phase 5 -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">05</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Internal Audit & Management Review</h3>
                    <p class="text-medium color-grey">Conduct internal audits to verify compliance. Perform management review to ensure ISMS effectiveness and readiness for certification.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Phase 6 -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">06</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Certification Audit Support</h3>
                    <p class="text-medium color-grey">Prepare for and support you through Stage 1 and Stage 2 certification audits. Address any findings and achieve your ISO 27001 certificate.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Deliver -->
    <section class="section bg-color-dark">
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Deliverables</div>
          </div>
          <h2 class="heading heading-center">Complete <span class="text-gradient-clip bg-color-green-gradient">Documentation Package</span></h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-top: 3rem; text-align: left;">
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> ISMS Manual</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Security Policies (20+)</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Risk Assessment Report</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Statement of Applicability</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Risk Treatment Plan</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Procedures & Work Instructions</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Internal Audit Reports</p>
            </div>
            <div style="padding: 1.5rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Management Review Records</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Services -->
    <section class="section">
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Other <span class="text-gradient-clip bg-color-green-gradient">Services</span></h2>
          <div style="display: flex; gap: 2rem; margin-top: 3rem; flex-wrap: wrap; justify-content: center;">
            <a href="/services/vapt" class="button" style="text-decoration: none;">
              <div class="button-wrapper">
                <div class="button-text">VAPT Services</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </a>
            <a href="/services/training" class="button" style="text-decoration: none;">
              <div class="button-wrapper">
                <div class="button-text">Security Training</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </a>
            <a href="/software" class="button" style="text-decoration: none;">
              <div class="button-wrapper">
                <div class="button-text">Security Software</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="cta" class="section bg-color-dark">
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Start Your ISO 27001 <span class="text-gradient-clip bg-color-green-gradient">Journey</span></h2>
          <p class="text-medium vertical-heading-description" style="max-width: 600px; margin: 1.5rem auto;">Get a free gap assessment to understand where you stand and what it takes to get certified.</p>
          <div style="margin-top: 2rem;">
            <div class="button">
              <a href="/#contact" class="button-hidden w-button">Get Started</a>
              <div class="button-wrapper">
                <div class="button-text">Request Gap Assessment</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterRedesigned />

</Layout>
