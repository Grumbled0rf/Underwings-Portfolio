---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterRedesigned from '../../components/FooterRedesigned.astro';
---

<Layout
  title="Cybersecurity Awareness Training | Underwings"
  description="Transform your employees into your strongest security defense. Engaging security awareness training, phishing simulations, and compliance training programs in UAE."
  keywords="security awareness training UAE, phishing simulation Dubai, cybersecurity training, employee security training, compliance training UAE, social engineering training"
  wfPage="training-page"
  schema={null}
>
  <Header currentPage="services" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">Security Training</div>
              </div>
              <h1 class="heading-large hero-heading-large">Cybersecurity <span class="text-gradient-clip bg-color-green-gradient">Awareness Training</span></h1>
              <p class="text text-center" style="max-width: 700px; margin: 1.5rem auto;">Your employees are your first line of defense — or your biggest vulnerability. Transform your team into security-aware professionals who recognize and respond to threats.</p>
              <div style="margin-top: 2rem;">
                <div class="button">
                  <a href="/#contact" class="button-hidden w-button">Start Training Program</a>
                  <div class="button-wrapper">
                    <div class="button-text">Start Training Program</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Training Programs -->
    <section class="section bg-color-dark">
      <div class="container">
        <div class="section-wrapper-vertical section-wrapper-vertical-large">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <h2 class="heading">Training Programs</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">Comprehensive training solutions that engage employees and create lasting behavioral change.</p>
              </div>
            </div>
          </div>

          <div class="content-risks">
            <!-- Phishing Simulations -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">01</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Phishing Simulations</h3>
                    <p class="text-medium color-grey">Realistic phishing campaigns that test employee awareness. Track click rates, report rates, and improvement over time. Immediate training for those who fall for simulations.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Interactive Training -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">02</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Interactive E-Learning Modules</h3>
                    <p class="text-medium color-grey">Engaging online courses covering password security, social engineering, data handling, mobile security, and more. Short modules that fit into busy schedules.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Role-Based Training -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">03</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Role-Based Training</h3>
                    <p class="text-medium color-grey">Specialized training for executives, IT staff, developers, finance teams, and HR. Each role faces different threats — training should reflect that.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Compliance Training -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">04</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Compliance Training</h3>
                    <p class="text-medium color-grey">Meet regulatory requirements with training programs aligned to ISO 27001, GDPR, HIPAA, PCI DSS, and UAE data protection laws. Track completion and maintain audit trails.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Live Workshops -->
            <div class="content-risks-item">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper">
                  <div class="dashed-line"></div>
                  <div class="neon-line"></div>
                </div>
                <div class="text text-gradient-clip bg-color-green-gradient">05</div>
              </div>
              <div class="risk-item-inner">
                <div class="risk-item-inner-wrapper">
                  <div class="risk-description">
                    <h3 class="heading-small">Live Workshops & Presentations</h3>
                    <p class="text-medium color-grey">In-person or virtual sessions led by security experts. Live demonstrations, Q&A sessions, and hands-on exercises that create memorable learning experiences.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Topics Covered -->
    <section class="section">
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Curriculum</div>
          </div>
          <h2 class="heading heading-center">Topics <span class="text-gradient-clip bg-color-green-gradient">Covered</span></h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 3rem; text-align: left;">
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Phishing & Email Security</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Password Best Practices</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Social Engineering</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Data Protection</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Mobile Device Security</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Remote Work Security</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Physical Security</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Incident Reporting</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Safe Browsing</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Ransomware Awareness</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Business Email Compromise</p>
            </div>
            <div style="padding: 1rem; border: 1px dashed var(--colors--dashed-grey); border-radius: 8px;">
              <p class="text-medium"><span class="text-gradient-clip bg-color-green-gradient">+</span> Insider Threats</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="cta" class="section bg-color-dark">
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Build a <span class="text-gradient-clip bg-color-green-gradient">Security-First Culture</span></h2>
          <p class="text-medium vertical-heading-description" style="max-width: 600px; margin: 1.5rem auto;">Start with a pilot program to see the impact. We'll show you how to reduce your human risk factor.</p>
          <div style="margin-top: 2rem;">
            <div class="button">
              <a href="/#contact" class="button-hidden w-button">Get Started</a>
              <div class="button-wrapper">
                <div class="button-text">Request Demo</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterRedesigned />
</Layout>
