---
// ===========================================
// CYBERSECURITY TRAINING PAGE
// Underwings Technologies
// ===========================================

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FooterRedesigned from '../../components/FooterRedesigned.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Cybersecurity Awareness Training",
  "provider": {
    "@type": "Organization",
    "name": "Underwings Technologies",
    "url": "https://underwings.org"
  },
  "description": "Cybersecurity awareness training programs including phishing simulations, role-based training, compliance training, and live workshops.",
  "areaServed": ["IN", "AE"],
  "serviceType": "Security Training"
};
---

<Layout
  title="Cybersecurity Awareness Training | Underwings"
  description="Transform your employees into your strongest security defense. Engaging security awareness training, phishing simulations, and compliance training programs in India & UAE."
  keywords="security awareness training UAE, phishing simulation Dubai, cybersecurity training, employee security training, compliance training UAE, social engineering training, security training India"
  wfPage="training-page"
  schema={schema}
  bodyClass="body"
>
  <Header currentPage="services" />

  <main id="main" class="main">
    <!-- Hero Section -->
    <section class="section bottom-padding-clear top-padding-small">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container-medium">
        <div class="hero">
          <div class="hero-main-wrapper">
            <div class="hero-heading-wrapper">
              <div class="label">
                <div class="text-small color-grey">Security Training</div>
              </div>
              <h1 class="heading-large hero-heading-large">Cybersecurity <span class="text-gradient-clip bg-color-green-gradient">Awareness Training</span></h1>
              <p class="text text-center" style="max-width: 700px; margin: 1.5rem auto;">Your employees are your first line of defense — or your biggest vulnerability. Transform your team into security-aware professionals who recognize and respond to threats.</p>
              <!-- Delivery formats -->
              <div style="display: flex; justify-content: center; gap: 1rem; margin-top: 2rem; flex-wrap: wrap;">
                <span class="trn-format-badge">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="2" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M5 13h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                  Virtual
                </span>
                <span class="trn-format-badge">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/></svg>
                  On-Site
                </span>
                <span class="trn-format-badge">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 1h4v12H5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M7 10h0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Self-Paced
                </span>
              </div>
              <div style="margin-top: 1.5rem;">
                <div class="button">
                  <a href="/#contact" class="button-hidden w-button">Start Training Program</a>
                  <div class="button-wrapper">
                    <div class="button-text">Start Training Program</div>
                  </div>
                  <div class="button-accent-gradinet"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Training Programs -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="section-wrapper-vertical section-wrapper-vertical-large">
          <div class="heading-horizontal">
            <div class="heading-horizontal-inner">
              <div class="heading-horizontal-left-part">
                <h2 class="heading">Training Programs</h2>
              </div>
              <div class="heading-horizontal-right-part">
                <p class="text-medium">Comprehensive training solutions that engage employees and create lasting behavioral change.</p>
              </div>
            </div>
          </div>

          <div class="content-risks">
            <div class="content-risks-item trn-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">01</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Phishing Simulations</h3>
                <p class="text-medium color-grey">Realistic phishing campaigns that test employee awareness. Track click rates, report rates, and improvement over time. Immediate training for those who fall for simulations.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item trn-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">02</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Interactive E-Learning Modules</h3>
                <p class="text-medium color-grey">Engaging online courses covering password security, social engineering, data handling, mobile security, and more. Short modules that fit into busy schedules.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item trn-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">03</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Role-Based Training</h3>
                <p class="text-medium color-grey">Specialized training for executives, IT staff, developers, finance teams, and HR. Each role faces different threats — training should reflect that.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item trn-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">04</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Compliance Training</h3>
                <p class="text-medium color-grey">Meet regulatory requirements with training programs aligned to ISO 27001, GDPR, HIPAA, PCI DSS, and UAE data protection laws. Track completion and maintain audit trails.</p>
              </div></div></div>
            </div>

            <div class="content-risks-item trn-stagger">
              <div class="risk-item-top">
                <div class="dashed-line-wrapper"><div class="dashed-line"></div><div class="neon-line"></div></div>
                <div class="text text-gradient-clip bg-color-green-gradient">05</div>
              </div>
              <div class="risk-item-inner"><div class="risk-item-inner-wrapper"><div class="risk-description">
                <h3 class="heading-small">Live Workshops & Presentations</h3>
                <p class="text-medium color-grey">In-person or virtual sessions led by security experts. Live demonstrations, Q&A sessions, and hands-on exercises that create memorable learning experiences.</p>
              </div></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Topics Covered — grouped into categories -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Curriculum</div>
          </div>
          <h2 class="heading heading-center">Topics <span class="text-gradient-clip bg-color-green-gradient">Covered</span></h2>

          <div class="trn-topics-grid">
            <!-- Email & Social -->
            <div class="trn-topic-group trn-stagger">
              <div class="trn-topic-group-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M2 6l8 5 8-5" stroke="currentColor" stroke-width="1.3"/></svg>
                <span>Email & Social Engineering</span>
              </div>
              <ul class="trn-topic-list">
                <li>Phishing & Email Security</li>
                <li>Social Engineering</li>
                <li>Business Email Compromise</li>
              </ul>
            </div>
            <!-- Data & Device -->
            <div class="trn-topic-group trn-stagger">
              <div class="trn-topic-group-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 2l3 7h-6l3-7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><rect x="3" y="11" width="14" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/><circle cx="6" cy="14.5" r="1" fill="currentColor"/></svg>
              </div>
              <ul class="trn-topic-list">
                <li>Data Protection & Privacy</li>
                <li>Mobile Device Security</li>
                <li>Remote Work Security</li>
              </ul>
            </div>
            <!-- Threats -->
            <div class="trn-topic-group trn-stagger">
              <div class="trn-topic-group-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 2L3 14h9l-1 6 10-12h-9l1-6z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>Threat Awareness</span>
              </div>
              <ul class="trn-topic-list">
                <li>Ransomware Awareness</li>
                <li>Insider Threats</li>
                <li>Safe Browsing Habits</li>
              </ul>
            </div>
            <!-- Operational -->
            <div class="trn-topic-group trn-stagger">
              <div class="trn-topic-group-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2v16M2 10h16" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/></svg>
                <span>Operational Security</span>
              </div>
              <ul class="trn-topic-list">
                <li>Password Best Practices</li>
                <li>Physical Security</li>
                <li>Incident Reporting</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What You Get -->
    <section class="section bg-color-dark">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <div class="label">
            <div class="text-small color-grey">Outcomes</div>
          </div>
          <h2 class="heading heading-center">What You <span class="text-gradient-clip bg-color-green-gradient">Get</span></h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.25rem; margin-top: 3rem; text-align: left;">
            <div class="trn-outcome trn-stagger">
              <div class="trn-outcome-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M2 13l5-5 3 3 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 3h4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Measurable Results</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Track phishing click rates, completion rates & risk score improvement over time</p>
              </div>
            </div>
            <div class="trn-outcome trn-stagger">
              <div class="trn-outcome-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M14 2H6a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.5"/><path d="M7 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 12h6M7 15h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Compliance Documentation</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Completion certificates & audit-ready training records for ISO, GDPR, PCI</p>
              </div>
            </div>
            <div class="trn-outcome trn-stagger">
              <div class="trn-outcome-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Ongoing Campaigns</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Monthly phishing tests & quarterly refresher modules to maintain awareness</p>
              </div>
            </div>
            <div class="trn-outcome trn-stagger">
              <div class="trn-outcome-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="3" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M6 7h8M6 10h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-medium" style="color: #fff;">Executive Reports</p>
                <p class="text-small color-grey" style="margin-top: 0.35rem;">Management dashboards showing org-wide security posture & risk trends</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Services -->
    <section class="section">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top">
          <h2 class="heading heading-center">Explore Other <span class="text-gradient-clip bg-color-green-gradient">Services</span></h2>
          <div class="svc-cross-grid">
            <a href="/services/vapt" class="svc-cross-card trn-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="svc-cross-title">VAPT Services</h3>
              <p class="svc-cross-desc">Find vulnerabilities before attackers do — web, network, API & cloud testing.</p>
            </a>
            <a href="/services/iso-27001" class="svc-cross-card trn-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7l3-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="svc-cross-title">ISO 27001 Implementation</h3>
              <p class="svc-cross-desc">End-to-end compliance — gap assessment to certification audit support.</p>
            </a>
            <a href="/software" class="svc-cross-card trn-stagger">
              <div class="svc-cross-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <h3 class="svc-cross-title">Security Software</h3>
              <p class="svc-cross-desc">Enterprise tools — endpoint, SIEM, email & network security deployed right.</p>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="cta" class="section bg-color-grey-gradient">
      <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
        <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
      </div>
      <div class="container">
        <div class="vertical-heading-top" style="text-align: center;">
          <h2 class="heading heading-center">Build a <span class="text-gradient-clip bg-color-green-gradient">Security-First Culture</span></h2>
          <p class="text-medium" style="max-width: 600px; margin: 1.25rem auto; color: rgba(255,255,255,0.5); text-align: center;">Start with a pilot program to see the impact. We'll show you how to reduce your human risk factor.</p>
          <div style="margin-top: 2rem;">
            <div class="button" style="display: inline-block;">
              <a href="/#contact" class="button-hidden w-button">Get Started</a>
              <div class="button-wrapper">
                <div class="button-text">Request Demo</div>
              </div>
              <div class="button-accent-gradinet"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterRedesigned />
</Layout>

<style is:inline>
  /* ---- Format badges ---- */
  .trn-format-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border: 1px solid rgba(36,215,88,0.4);
    border-radius: 20px;
    font-size: 0.825rem;
    color: #fff;
    background: rgba(36,215,88,0.08);
  }
  .trn-format-badge svg { color: #24d758; }

  /* ---- Topics grid ---- */
  .trn-topics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .trn-topic-group {
    padding: 1.5rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    transition: border-color 0.3s ease;
  }
  .trn-topic-group:hover {
    border-color: rgba(36,215,88,0.25);
  }
  .trn-topic-group-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #24d758;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .trn-topic-group-header span { color: #fff; }
  .trn-topic-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .trn-topic-list li {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }
  .trn-topic-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #24d758;
    opacity: 0.6;
  }

  /* ---- Outcomes ---- */
  .trn-outcome {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px dashed var(--colors--dashed-grey);
    border-radius: 8px;
    transition: border-color 0.3s ease;
  }
  .trn-outcome:hover {
    border-color: rgba(36,215,88,0.35);
  }
  .trn-outcome-icon {
    color: #24d758;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  /* ---- Cross-link service cards ---- */
  .svc-cross-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .svc-cross-card {
    padding: 1.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .svc-cross-card:hover {
    border-color: rgba(36,215,88,0.3);
    transform: translateY(-2px);
  }
  .svc-cross-icon {
    color: #24d758;
    margin-bottom: 1rem;
  }
  .svc-cross-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .svc-cross-desc {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .trn-topics-grid { grid-template-columns: 1fr; }
    .svc-cross-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  (function() {
    if (typeof IntersectionObserver === 'undefined') return;
    var items = document.querySelectorAll('.trn-stagger');
    items.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(16px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var parent = entry.target.parentElement;
          var siblings = parent ? Array.from(parent.children).filter(function(c) { return c.classList && c.classList.contains('trn-stagger') && c.style.opacity === '0'; }) : [];
          var idx = siblings.indexOf(entry.target);
          setTimeout(function() {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }, Math.max(0, idx) * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(el) { observer.observe(el); });
  })();
</script>
