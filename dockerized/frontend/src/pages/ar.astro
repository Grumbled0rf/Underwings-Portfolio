  <link rel="dns-prefetch" href="//js-eu1.hs-scripts.com">
  <link rel="preconnect" href="https://d3e54v103j8qbb.cloudfront.net" crossorigin>

  <!-- Font Preloads -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-400.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-600.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/geist-mono-400.woff2" crossorigin>

  <!-- Styles -->
  <link href="/css/normalize.css" rel="stylesheet" type="text/css">
  <link href="/css/webflow.css" rel="stylesheet" type="text/css">
  <link href="/css/underwings-org.webflow.css" rel="stylesheet" type="text/css">

  <style is:inline>
    @font-face { font-family: 'Geist'; font-weight: 300; font-style: normal; font-display: swap; src: url('/fonts/geist-300.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/geist-400.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 500; font-style: normal; font-display: swap; src: url('/fonts/geist-500.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 600; font-style: normal; font-display: swap; src: url('/fonts/geist-600.woff2') format('woff2'); }
    @font-face { font-family: 'Geist'; font-weight: 700; font-style: normal; font-display: swap; src: url('/fonts/geist-700.woff2') format('woff2'); }
    @font-face { font-family: 'Geist Mono'; font-weight: 400; font-style: normal; font-display: swap; src: url('/fonts/geist-mono-400.woff2') format('woff2'); }
  </style>

  <style is:global>
    /* ========== RTL Base & Overrides ========== */
    html {
      scroll-behavior: smooth;
    }
    body {
      font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0a0a0a;
      color: #fff;
      margin: 0;
      padding: 0;
      font-size: 1.0625rem;
      line-height: 1.7;
      direction: rtl;
      text-align: right;
    }
    *, *::before, *::after {
      box-sizing: border-box;
    }
    a {
      color: #24d758;
      text-decoration: none;
      transition: color 0.2s ease;
    }
    a:hover {
      color: #1db84a;
    }

    /* ========== Container ========== */
    .ar-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* ========== Top Bar / Language Switcher ========== */
    .ar-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    .ar-topbar-logo img {
      height: 32px;
      width: auto;
    }
    .ar-lang-switch {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 0.5rem;
      color: #fff;
      font-size: 0.85rem;
      font-weight: 500;
      text-decoration: none;
      transition: border-color 0.25s ease, background 0.25s ease;
    }
    .ar-lang-switch:hover {
      border-color: #24d758;
      color: #24d758;
      background: rgba(36,215,88,0.05);
    }

    /* ========== Hero ========== */
    .ar-hero {
      padding: 6rem 0 5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .ar-hero::before {
      content: '';
      position: absolute;
      top: -50%;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(36,215,88,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .ar-hero h1 {
      font-size: 3.5rem;
      font-weight: 700;
      line-height: 1.2;
      margin: 0 0 1.5rem;
      background: linear-gradient(135deg, #fff, rgba(255,255,255,0.8));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .ar-hero-accent {
      -webkit-text-fill-color: #24d758;
      color: #24d758;
    }
    .ar-hero p {
      font-size: 1.25rem;
      color: rgba(255,255,255,0.7);
      max-width: 700px;
      margin: 0 auto 2.5rem;
      line-height: 1.8;
    }
    .ar-hero-btns {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* ========== Buttons ========== */
    .ar-btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 1rem 2rem;
      background: #24d758;
      color: #000;
      font-size: 1rem;
      font-weight: 600;
      font-family: inherit;
      border: none;
      border-radius: 0.5rem;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.25s ease, transform 0.15s ease;
    }
    .ar-btn-primary:hover {
      background: #1db84a;
      color: #000;
      transform: translateY(-1px);
    }
    .ar-btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 1rem 2rem;
      background: transparent;
      color: #fff;
      font-size: 1rem;
      font-weight: 500;
      font-family: inherit;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 0.5rem;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
    }
    .ar-btn-secondary:hover {
      border-color: #24d758;
      color: #24d758;
      background: rgba(36,215,88,0.05);
    }

    /* ========== Section Common ========== */
    .ar-section {
      padding: 5rem 0;
    }
    .ar-section-title {
      font-size: 2.5rem;
      font-weight: 700;
      text-align: center;
      margin: 0 0 1rem;
      line-height: 1.3;
    }
    .ar-section-subtitle {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.6);
      text-align: center;
      max-width: 600px;
      margin: 0 auto 3.5rem;
      line-height: 1.7;
    }

    /* ========== Services Grid ========== */
    .ar-services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
    }
    .ar-service-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 2rem;
      transition: border-color 0.3s ease, transform 0.2s ease, background 0.3s ease;
    }
    .ar-service-card:hover {
      border-color: rgba(36,215,88,0.3);
      background: rgba(255,255,255,0.05);
      transform: translateY(-3px);
    }
    .ar-service-icon {
      width: 48px;
      height: 48px;
      background: rgba(36,215,88,0.1);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
      color: #24d758;
    }
    .ar-service-card h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin: 0 0 0.75rem;
      color: #fff;
    }
    .ar-service-card p {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.7;
      margin: 0;
    }

    /* ========== Why Choose Us ========== */
    .ar-why-section {
      background: rgba(255,255,255,0.02);
      border-top: 1px solid rgba(255,255,255,0.06);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .ar-why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }
    .ar-why-item {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }
    .ar-why-icon {
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      background: rgba(36,215,88,0.1);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #24d758;
    }
    .ar-why-item h4 {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 0 0 0.4rem;
      color: #fff;
    }
    .ar-why-item p {
      font-size: 0.9rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.6;
      margin: 0;
    }

    /* ========== Contact / CTA ========== */
    .ar-cta-section {
      text-align: center;
    }
    .ar-cta-section .ar-section-title {
      margin-bottom: 1.5rem;
    }
    .ar-contact-methods {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .ar-contact-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: rgba(255,255,255,0.8);
      font-size: 0.95rem;
      text-decoration: none;
      transition: color 0.2s;
    }
    .ar-contact-item:hover {
      color: #24d758;
    }
    .ar-contact-item svg {
      color: #24d758;
      flex-shrink: 0;
    }

    /* ========== Footer ========== */
    .ar-footer {
      padding: 2.5rem 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      text-align: center;
    }
    .ar-footer p {
      color: rgba(255,255,255,0.4);
      font-size: 0.85rem;
      margin: 0 0 0.5rem;
    }
    .ar-footer a {
      color: rgba(255,255,255,0.5);
      font-size: 0.85rem;
      text-decoration: none;
      transition: color 0.2s;
    }
    .ar-footer a:hover {
      color: #24d758;
    }

    /* ========== Divider ========== */
    .ar-divider {
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, #24d758, transparent);
      margin: 0 auto 2rem;
      border-radius: 2px;
    }

    /* ========== Responsive ========== */
    @media (max-width: 768px) {
      .ar-hero h1 {
        font-size: 2.25rem;
      }
      .ar-hero p {
        font-size: 1.05rem;
      }
      .ar-section-title {
        font-size: 1.85rem;
      }
      .ar-section {
        padding: 3.5rem 0;
      }
      .ar-hero {
        padding: 4rem 0 3.5rem;
      }
      .ar-container {
        padding: 0 1.25rem;
      }
    }

    /* ========== Focus Visible ========== */
    :focus-visible {
      outline: 2px solid #24d758;
      outline-offset: 2px;
    }

    /* ========== Reduced Motion ========== */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>

  <link href="/images/favicon.png" rel="shortcut icon" type="image/x-icon">
  <link href="/images/webclip.png" rel="apple-touch-icon">

  <!-- HubSpot Tracking -->
  <script type="text/javascript" id="hs-script-loader" async defer src="//js-eu1.hs-scripts.com/147940148.js"></script>
</head>
<body>

  <!-- ========== Top Bar ========== -->
  <header class="ar-topbar">
    <a href="/ar" class="ar-topbar-logo" aria-label="أندروينغز - الصفحة الرئيسية">
      <img src="/images/logowhiteUW.png" alt="أندروينغز" width="120" height="32" loading="eager">
    </a>
    <a href="/" class="ar-lang-switch" aria-label="Switch to English">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      English
    </a>
  </header>

  <!-- ========== Hero Section ========== -->
  <section class="ar-hero">
    <div class="ar-container">
      <h1>
        <span class="ar-hero-accent">أندروينغز</span> — حلول الأمن السيبراني
      </h1>
      <p>
        نحمي أعمالكم في الإمارات والهند من التهديدات السيبرانية. فريق معتمد من خبراء الأمن السيبراني يقدم حلولاً شاملة لحماية بياناتكم وأنظمتكم.
      </p>
      <div class="ar-hero-btns">
        <a href="#contact" class="ar-btn-primary">
          احجز استشارة مجانية
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M19 12l-7-7M19 12l-7 7"/></svg>
        </a>
        <a href="/" class="ar-btn-secondary">
          زيارة الموقع الإنجليزي
        </a>
      </div>
    </div>
  </section>

  <!-- ========== Services Section ========== -->
  <section class="ar-section" id="services">
    <div class="ar-container">
      <h2 class="ar-section-title">خدماتنا</h2>
      <div class="ar-divider"></div>
      <p class="ar-section-subtitle">
        نقدم مجموعة شاملة من خدمات الأمن السيبراني المصممة لحماية مؤسستكم
      </p>

      <div class="ar-services-grid">
        <!-- VAPT -->
        <div class="ar-service-card">
          <div class="ar-service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>اختبار الاختراق (VAPT)</h3>
          <p>تقييم شامل للثغرات الأمنية واختبار الاختراق لتطبيقات الويب والشبكات والبنية التحتية السحابية. نكشف نقاط الضعف قبل المهاجمين.</p>
        </div>

        <!-- ISO 27001 -->
        <div class="ar-service-card">
          <div class="ar-service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3>الامتثال لمعيار ISO 27001</h3>
          <p>نساعدكم في تطبيق نظام إدارة أمن المعلومات والحصول على شهادة ISO 27001. من تحليل الفجوات إلى الاعتماد النهائي.</p>
        </div>

        <!-- Training -->
        <div class="ar-service-card">
          <div class="ar-service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
          </div>
          <h3>التدريب الأمني</h3>
          <p>برامج تدريبية متخصصة في الوعي الأمني السيبراني لموظفيكم. تدريبات محاكاة التصيد الاحتيالي وورش عمل عملية.</p>
        </div>

        <!-- Consultation -->
        <div class="ar-service-card">
          <div class="ar-service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>الاستشارات الأمنية</h3>
          <p>استشارات متخصصة لتقييم الوضع الأمني لمؤسستكم ووضع استراتيجية أمنية شاملة تتوافق مع معايير الصناعة.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== Why Choose Us ========== -->
  <section class="ar-section ar-why-section" id="why-us">
    <div class="ar-container">
      <h2 class="ar-section-title">لماذا تختار أندروينغز؟</h2>
      <div class="ar-divider"></div>
      <p class="ar-section-subtitle">
        نجمع بين الخبرة التقنية العالية والتسعير المناسب للشركات الناشئة
      </p>

      <div class="ar-why-grid">
        <!-- Certified Team -->
        <div class="ar-why-item">
          <div class="ar-why-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <h4>فريق معتمد OSCP و CPTS</h4>
            <p>خبراء معتمدون دولياً في اختبار الاختراق مع سنوات من الخبرة في حماية المؤسسات من التهديدات المتقدمة.</p>
          </div>
        </div>

        <!-- UAE & India Presence -->
