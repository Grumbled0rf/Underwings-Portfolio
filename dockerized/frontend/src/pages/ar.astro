---
// ===========================================
// ARABIC LANDING PAGE
// Underwings Cybersecurity Solutions — UAE Market SEO
// ===========================================
export const prerender = false;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://underwings.org";

const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "أندروينغز لحلول الأمن السيبراني",
  "url": siteUrl,
  "logo": `${siteUrl}/images/logowhiteUW.png`,
  "description": "شركة ناشئة في مجال الأمن السيبراني تقدم خدمات اختبار الاختراق، تطبيق معيار ISO 27001، التدريب على الوعي الأمني، وبيع البرمجيات الأمنية في الإمارات والهند.",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "AE",
    "addressRegion": "دبي"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+971-547078203",
    "email": "contact@underwings.org",
    "contactType": "sales",
    "availableLanguage": ["Arabic", "English", "Hindi"]
  },
  "sameAs": [
    "https://www.linkedin.com/company/underwings-technologies"
  ]
};
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <title>أندروينغز - حلول الأمن السيبراني | الإمارات والهند</title>
  <meta name="description" content="أندروينغز - شركة رائدة في الأمن السيبراني تقدم خدمات اختبار الاختراق (VAPT)، تطبيق معيار ISO 27001، التدريب الأمني، وبيع البرمجيات الأمنية في الإمارات والهند. فريق معتمد OSCP و CPTS.">
  <meta property="og:title" content="أندروينغز - حلول الأمن السيبراني | الإمارات والهند">
  <meta property="og:description" content="شركة ناشئة في الأمن السيبراني تقدم خدمات اختبار الاختراق، ISO 27001، التدريب الأمني، وبيع البرمجيات الأمنية في الإمارات والهند.">
  <meta property="og:type" content="website">
  <meta property="og:url" content={`${siteUrl}/ar`}>
  <meta property="og:image" content={`${siteUrl}/images/og-image.png`}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="ar_AE">
  <meta property="og:locale:alternate" content="en_AE">
  <meta content="summary_large_image" name="twitter:card">
  <meta property="twitter:title" content="أندروينغز - حلول الأمن السيبراني | الإمارات والهند">
  <meta property="twitter:description" content="شركة ناشئة في الأمن السيبراني تقدم خدمات اختبار الاختراق، ISO 27001، التدريب الأمني في الإمارات والهند.">
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <meta name="robots" content="index, follow">
  <meta name="author" content="Underwings Cybersecurity Solutions">
  <meta name="geo.region" content="AE">
  <meta name="geo.placename" content="Dubai, UAE">
  <meta name="keywords" content="أمن سيبراني الإمارات, اختبار اختراق دبي, ISO 27001 الإمارات, خدمات أمن المعلومات, تدريب الأمن السيبراني, حماية البيانات الإمارات, فحص الثغرات, استشارات أمنية, VAPT دبي, الامتثال الأمني">
  <link rel="canonical" href={`${siteUrl}/ar`}>
  <link rel="alternate" hreflang="en" href={siteUrl}>
  <link rel="alternate" hreflang="ar" href={`${siteUrl}/ar`}>

  <!-- Structured Data -->
