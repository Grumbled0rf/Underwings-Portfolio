---
// ===========================================
// HEADER COMPONENT
// Underwings Technologies
// ===========================================

export interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;
---

<a href="#main" class="skip-to-content">Skip to content</a>
<header id="header" class="header">
  <div data-w-id="293a7602-a449-8edb-a1a4-0201d537e62c" class="header-offset"></div>
  <div data-w-id="c0f57989-f5a9-9c1a-60c9-2841a4ab0ea2" data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navbar w-nav">
    <div class="container-medium header-container-medium w-container">
      <div class="navbar-inner">
        <a href="/" aria-current={currentPage === 'home' ? 'page' : undefined} class={`logo w-nav-brand ${currentPage === 'home' ? 'w--current' : ''}`}>
          <img src="/images/logowhiteUW.png" loading="lazy" alt="Underwings Technologies - Cybersecurity Solutions" srcset="/images/logowhiteUW-p-500.png 500w, /images/logowhiteUW.png 639w" sizes="150px" class="logo-image">
        </a>
        <div class="nav-menu-box">
          <nav role="navigation" aria-label="Main navigation" class="nav-menu w-nav-menu">
            <div class="nav-menu-inner">
              <!-- Services Mega Dropdown -->
              <div class="nav-dropdown nav-mega-dropdown">
                <a data-name="scramble" href="#" aria-expanded="false" aria-haspopup="true" class={`nav-link nav-link-gradient w-nav-link ${currentPage === 'services' ? 'w--current' : ''}`}>
                  Services
                  <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <div class="nav-mega-content" role="menu" aria-label="Services submenu">
                  <a href="/services/vapt" class="nav-mega-item" role="menuitem">
                    <div class="nav-mega-icon" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 18s6.5-3 6.5-8V5L10 2 3.5 5v5c0 5 6.5 8 6.5 8z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                    </div>
                    <div>
                      <span class="nav-mega-title">VAPT</span>
                      <span class="nav-mega-desc">Penetration testing & vulnerability assessment</span>
                    </div>
                  </a>
                  <a href="/services/iso-27001" class="nav-mega-item" role="menuitem">
                    <div class="nav-mega-icon" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2.5 5h5.5l-4.5 3.5 1.5 5.5L10 13l-5 3 1.5-5.5L2 7h5.5L10 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                    </div>
                    <div>
                      <span class="nav-mega-title">ISO 27001</span>
                      <span class="nav-mega-desc">Compliance implementation & certification</span>
                    </div>
                  </a>
                  <a href="/services/training" class="nav-mega-item" role="menuitem">
                    <div class="nav-mega-icon" aria-hidden="true">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 12l7-4-7-4-7 4 7 4z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M17 8v5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M5 10v4c0 1.1 2.2 2 5 2s5-.9 5-2v-4" stroke="currentColor" stroke-width="1.3"/></svg>
                    </div>
                    <div>
                      <span class="nav-mega-title">Training</span>
                      <span class="nav-mega-desc">Security awareness & phishing simulations</span>
                    </div>
                  </a>
                </div>
              </div>

              <a data-name="scramble" href="/software" class={`nav-link nav-link-gradient w-nav-link ${currentPage === 'software' ? 'w--current' : ''}`}>Software</a>
              <a data-name="scramble" href="/updates" class={`nav-link nav-link-gradient w-nav-link ${currentPage === 'updates' ? 'w--current' : ''}`}>Updates</a>
              <a data-name="scramble" href="/about" class={`nav-link nav-link-gradient w-nav-link ${currentPage === 'about' ? 'w--current' : ''}`}>About</a>
              <a data-name="scramble" href="/blog" class={`nav-link nav-link-gradient w-nav-link ${currentPage === 'blog' ? 'w--current' : ''}`}>Blog</a>
            </div>
          </nav>
        </div>
        <div class="header-cta-button">
          <div class="button">
            <a href="/#contact" class="button-hidden w-button">Contact Us</a>
            <div class="button-wrapper">
              <div class="button-text">Contact Us</div>
            </div>
            <div class="button-accent-gradinet"></div>
          </div>
        </div>
        <div class="menu-button w-nav-button" aria-label="Toggle navigation menu" aria-expanded="false" role="button" tabindex="0">
          <div class="menu-button-lines">
            <div class="menu-button-line menu-button-line-top"></div>
            <div class="menu-button-line menu-button-line-bottom"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<div data-wf--noise--variant="base" class="noise-wrapper">
  <div data-w-id="71d94dcc-6696-ef8a-8008-1058c6cb48e2" class="noise"></div>
</div>
