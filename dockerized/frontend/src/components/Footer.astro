const nonce = Astro.locals.nonce || "";
---

<footer id="footer" data-wf--footer--variant="black" class="footer w-variant-2d3c46da-753e-dab6-6d26-4f15379a30dd">
  <div class="container-large">
    <div class="footer-inner">
      <div class="footer-top-content">
        <nav class="footer-nav" aria-label="Footer navigation">
          <div class="footer-top-content-grid">
            <!-- Logo & Tagline -->
            <div id="w-node-f2b4380d-560d-1d13-931c-82460eddde1d-0eddde17" class="footer-top-part footer-top-part-between">
              <a href="/" class="logo w-nav-brand">
                <img src="/images/logowhiteUW.png" loading="lazy" alt="Underwings Cybersecurity Solutions Logo" srcset="/images/logowhiteUW-p-500.png 500w, /images/logowhiteUW.png 639w" sizes="150px" class="logo-image">
              </a>
              <p style="font-size: 0.8rem; color: rgba(255,255,255,0.5); line-height: 1.7; margin-top: 1rem; max-width: 260px;">A cybersecurity startup making real security accessible to growing businesses. Software, pentesting, compliance, and training — without the enterprise price tag.</p>
            </div>

            <!-- 3-Column Nav Grid -->
            <div id="w-node-f2b4380d-560d-1d13-931c-82460eddde22-0eddde17" class="footer-top-part footer-top-part-grid w-variant-2d3c46da-753e-dab6-6d26-4f15379a30dd" style="grid-template-columns: repeat(3, 1fr);">

              <!-- Services Column -->
              <ul role="list" class="footer-nav-list w-list-unstyled">
                <li class="footer-nav-list-item" style="margin-bottom: 0.5rem;">
                  <span style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.3); font-weight: 600;">Services</span>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/services/vapt" class="footer-nav-link nav-link-gradient w-inline-block"><div>VAPT</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/services/iso-27001" class="footer-nav-link nav-link-gradient w-inline-block"><div>ISO 27001</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/services/training" class="footer-nav-link nav-link-gradient w-inline-block"><div>Training</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/services/consultation" class="footer-nav-link nav-link-gradient w-inline-block"><div>Consultation</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/software" class="footer-nav-link nav-link-gradient w-inline-block"><div>Software</div></a>
                </li>
              </ul>

              <!-- Company Column -->
              <ul role="list" class="footer-nav-list w-list-unstyled">
                <li class="footer-nav-list-item" style="margin-bottom: 0.5rem;">
                  <span style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.3); font-weight: 600;">Company</span>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/about" class="footer-nav-link nav-link-gradient w-inline-block"><div>About</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/blog" class="footer-nav-link nav-link-gradient w-inline-block"><div>Blog</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/updates" class="footer-nav-link nav-link-gradient w-inline-block"><div>Updates</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/careers" class="footer-nav-link nav-link-gradient w-inline-block"><div>Careers</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/brand" class="footer-nav-link nav-link-gradient w-inline-block"><div>Brand</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/privacy-policy" class="footer-nav-link nav-link-gradient w-inline-block"><div>Privacy Policy</div></a>
                </li>
              </ul>

              <!-- Connect Column -->
              <ul role="list" class="footer-nav-list w-list-unstyled">
                <li class="footer-nav-list-item" style="margin-bottom: 0.5rem;">
                  <span style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.3); font-weight: 600;">Connect</span>
                </li>
                <li class="footer-nav-list-item">
                  <a href="mailto:contact@underwings.org" class="footer-nav-link nav-link-gradient w-inline-block" style="text-decoration: none;"><div>contact@underwings.org</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a href="tel:+971547078203" class="footer-nav-link nav-link-gradient w-inline-block" style="text-decoration: none;"><div>+971 547078203</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="https://www.linkedin.com/company/underwings-technologies" target="_blank" rel="noopener noreferrer" class="footer-nav-link nav-link-gradient w-inline-block"><div>LinkedIn</div></a>
                </li>
                <li class="footer-nav-list-item">
                  <a data-name="scramble" href="/#contact" class="footer-nav-link nav-link-gradient w-inline-block"><div>Contact Form</div></a>
                </li>
              </ul>
            </div>

            <!-- Back to top -->
            <div class="footer-top-part footer-top-part-between footer-top-part-right">
              <div class="link-to-top-desktop">
                <a href="#main" class="link-to-top w-inline-block" aria-label="Back to top">
                  <div class="embeded-icon w-embed">
                    <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M6.53033 0.96967C6.23744 0.676777 5.76256 0.676777 5.46967 0.96967L0.696699 5.74264C0.403806 6.03553 0.403806 6.51041 0.696699 6.8033C0.989592 7.09619 1.46447 7.09619 1.75736 6.8033L6 2.56066L10.2426 6.8033C10.5355 7.09619 11.0104 7.09619 11.3033 6.8033C11.5962 6.51041 11.5962 6.03553 11.3033 5.74264L6.53033 0.96967ZM6 2.5L6.75 2.5L6.75 1.5L6 1.5L5.25 1.5L5.25 2.5L6 2.5Z" fill="white"></path>
                    </svg>
                  </div>
                </a>
              </div>
            </div>
          </div>
        </nav>
      </div>
      <!-- Newsletter -->
      <div class="footer-newsletter">
        <div class="footer-newsletter-inner">
          <div class="footer-newsletter-text">
            <h3 class="footer-newsletter-heading">Monthly Threat Briefing for CISOs & CTOs</h3>
            <p class="footer-newsletter-desc">Get curated vulnerability alerts, zero-day analysis, compliance updates, and practical security tips — delivered once a month. No fluff.</p>
            <div class="nl-what-you-get">
              <span>Zero-Day Alerts</span>
              <span>Compliance Updates</span>
              <span>Attack Trend Analysis</span>
              <span>Tool Reviews</span>
            </div>
          </div>
          <form id="newsletter-form" class="footer-newsletter-form">
            <div class="footer-newsletter-input-wrap">
              <input type="email" id="nl-email" placeholder="your@email.com" required autocomplete="email">
              <button type="submit" class="footer-newsletter-btn">
                <span class="nl-btn-text">Subscribe Free</span>
                <span class="nl-btn-loading" style="display:none;">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="30 15" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" from="0 8 8" to="360 8 8" dur="0.8s" repeatCount="indefinite"/></circle></svg>
                </span>
              </button>
            </div>
            <div class="nl-msg nl-success" style="display:none;">You're in! Check your inbox for the welcome briefing.</div>
            <div class="nl-msg nl-error" style="display:none;">Something went wrong. Try again or email us.</div>
            <p class="nl-privacy-note">Join 500+ security professionals. Unsubscribe anytime.</p>
          </form>
        </div>
      </div>

      <div class="footer-bottom-content">
        <div class="footer-bottom-lines-grid">
          <div id="w-node-f2b4380d-560d-1d13-931c-82460eddde42-0eddde17" class="footer-bottom-part">
            <div class="neon-line"></div>
          </div>
          <div class="footer-bottom-part footer-bottom-part-tablet-hidden">
            <div class="neon-line"></div>
          </div>
          <div id="w-node-f2b4380d-560d-1d13-931c-82460eddde46-0eddde17" class="footer-bottom-part footer-bottom-part-tablet-hidden">
            <div class="neon-line dashed-end"></div>
          </div>
        </div>
        <div class="link-to-top-mobile">
          <a href="#main" class="link-to-top w-inline-block" aria-label="Back to top">
            <div class="embeded-icon w-embed">
              <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6.53033 0.96967C6.23744 0.676777 5.76256 0.676777 5.46967 0.96967L0.696699 5.74264C0.403806 6.03553 0.403806 6.51041 0.696699 6.8033C0.989592 7.09619 1.46447 7.09619 1.75736 6.8033L6 2.56066L10.2426 6.8033C10.5355 7.09619 11.0104 7.09619 11.3033 6.8033C11.5962 6.51041 11.5962 6.03553 11.3033 5.74264L6.53033 0.96967ZM6 2.5L6.75 2.5L6.75 1.5L6 1.5L5.25 1.5L5.25 2.5L6 2.5Z" fill="white"></path>
              </svg>
            </div>
          </a>
        </div>
        <div class="footer-bottom-content-grid">
          <div id="w-node-f2b4380d-560d-1d13-931c-82460eddde49-0eddde17" class="footer-bottom-part">
            <p class="copy-text">&copy; {new Date().getFullYear()} Underwings Cybersecurity Solutions. All rights reserved.</p>
          </div>
          <div class="footer-bottom-part">
            <p class="copy-text">India & UAE</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div data-wf--noise--variant="absolute" class="noise-wrapper w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab">
    <div class="noise w-variant-4c0280f5-2522-b840-9cb4-de0542cf64ab"></div>
  </div>
</footer>

<style is:inline>
  .footer-newsletter {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 2.5rem 0;
  }
  .footer-newsletter-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: 100%;
  }
  .footer-newsletter-text { flex: 1; min-width: 0; }
  .footer-newsletter-heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 0.3rem;
  }
  .footer-newsletter-desc {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
    line-height: 1.5;
  }
  .footer-newsletter-form { flex: 1; min-width: 0; max-width: 420px; }
  .footer-newsletter-input-wrap {
    display: flex;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .footer-newsletter-input-wrap:focus-within {
    border-color: #24d758;
  }
  .footer-newsletter-input-wrap input {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: none;
    padding: 0.7rem 1rem;
    color: #fff;
    font-size: 0.85rem;
    font-family: inherit;
    outline: none;
    min-width: 0;
  }
  .footer-newsletter-input-wrap input::placeholder {
    color: rgba(255,255,255,0.3);
  }
  .footer-newsletter-btn {
    background: #24d758;
    border: none;
    padding: 0.7rem 1.2rem;
    color: #000;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .footer-newsletter-btn:hover { background: #1db84a; }
  .footer-newsletter-btn:disabled { opacity: 0.7; cursor: not-allowed; }
  .nl-msg {
    font-size: 0.75rem;
    margin-top: 0.5rem;
    line-height: 1.4;
  }
  .nl-success { color: #24d758; }
  .nl-error { color: #ff4444; }
  .nl-what-you-get {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }
  .nl-what-you-get span {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    background: rgba(36,215,88,0.08);
    border: 1px solid rgba(36,215,88,0.2);
    border-radius: 4px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.3px;
  }
  .nl-privacy-note {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    margin: 0.4rem 0 0;
    line-height: 1.4;
  }
  @media (max-width: 768px) {
    .footer-newsletter-inner {
      flex-direction: column;
      text-align: center;
    }
    .footer-newsletter-form { max-width: 100%; width: 100%; }
    .nl-msg { text-align: center; }
  }
</style>

<script is:inline nonce={nonce}>
(function() {
  var form = document.getElementById('newsletter-form');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var email = form.querySelector('#nl-email').value.trim();
    if (!email) return;

    var btn = form.querySelector('.footer-newsletter-btn');
    var textEl = btn.querySelector('.nl-btn-text');
    var loadEl = btn.querySelector('.nl-btn-loading');
    textEl.style.display = 'none';
    loadEl.style.display = 'inline-flex';
    btn.disabled = true;

    var successEl = form.querySelector('.nl-success');
    var errorEl = form.querySelector('.nl-error');
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    fetch('/api/newsletter', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email })
    })
    .then(function(res) {
      if (res.ok) {
        successEl.style.display = 'block';
        form.querySelector('#nl-email').value = '';
      } else {
        throw new Error('Failed');
      }
    })
    .catch(function() {
      errorEl.style.display = 'block';
    })
    .finally(function() {
      textEl.style.display = '';
      loadEl.style.display = 'none';
      btn.disabled = false;
    });
  });
})();
</script>
