---
// ===========================================
// CONTACT FORM COMPONENT
// Integrates with Supabase
// ===========================================

export interface Props {
  formType?: 'contact' | 'quote' | 'consultation';
  showServices?: boolean;
}

const { formType = 'contact', showServices = true } = Astro.props;
---

<div class="contact-form-container" data-form-type={formType}>
  <form id="contact-form" class="contact-form">
    <div class="form-grid">
      <div class="form-field">
        <label for="name">Full Name *</label>
        <input type="text" id="name" name="name" required placeholder="Your name">
      </div>
      <div class="form-field">
        <label for="email">Email Address *</label>
        <input type="email" id="email" name="email" required placeholder="your@email.com">
      </div>
      <div class="form-field">
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone" placeholder="+971 XXX XXX XXX">
      </div>
      <div class="form-field">
        <label for="company">Company</label>
        <input type="text" id="company" name="company" placeholder="Your company name">
      </div>
    </div>

    {showServices && (
      <div class="form-field">
        <label for="service">Service Interest</label>
        <select id="service" name="service">
          <option value="">Select a service...</option>
          <option value="vapt">Vulnerability Assessment & Penetration Testing</option>
          <option value="iso27001">ISO 27001 Implementation</option>
          <option value="training">Security Awareness Training</option>
          <option value="software">Security Software Sales</option>
          <option value="consultation">General Consultation</option>
        </select>
      </div>
    )}

    <div class="form-field">
      <label for="message">Message *</label>
      <textarea id="message" name="message" required rows="5" placeholder="Tell us about your security needs..."></textarea>
    </div>

    <!-- Honeypot field for spam protection -->
    <div style="position: absolute; left: -9999px;">
      <input type="text" name="website" tabindex="-1" autocomplete="off">
    </div>

    <button type="submit" class="submit-button">
      <span class="button-text">Send Message</span>
      <span class="button-loading" style="display: none;">Sending...</span>
    </button>

    <div id="form-status" class="form-status" style="display: none;"></div>
  </form>
</div>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLElement;
  const submitBtn = form?.querySelector('.submit-button') as HTMLButtonElement;
  const buttonText = submitBtn?.querySelector('.button-text') as HTMLElement;
  const buttonLoading = submitBtn?.querySelector('.button-loading') as HTMLElement;
  const formContainer = form?.closest('.contact-form-container') as HTMLElement;
  const formType = formContainer?.dataset.formType || 'contact';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Check honeypot
    const honeypot = form.querySelector('input[name="website"]') as HTMLInputElement;
    if (honeypot?.value) {
      return; // Bot detected
    }

    // Show loading state
    submitBtn.disabled = true;
    buttonText.style.display = 'none';
    buttonLoading.style.display = 'inline';
    statusEl.style.display = 'none';

    const formData = new FormData(form);

    try {
      const { data, error } = await supabase
        .from('form_submissions')
        .insert([{
          form_type: formType,
          name: formData.get('name'),
          email: formData.get('email'),
          phone: formData.get('phone') || null,
          company: formData.get('company') || null,
          message: formData.get('message'),
          service_interest: formData.get('service') || null,
          metadata: {
            page: window.location.pathname,
            timestamp: new Date().toISOString(),
            userAgent: navigator.userAgent
          }
        }]);

      if (error) throw error;

      // Success
      statusEl.className = 'form-status success';
      statusEl.innerHTML = '✓ Thank you! Your message has been sent. We\'ll get back to you shortly.';
      statusEl.style.display = 'block';
      form.reset();

    } catch (error) {
      console.error('Form submission error:', error);
      statusEl.className = 'form-status error';
      statusEl.innerHTML = 'Something went wrong. Please try again or email us at <a href="mailto:contact@underwings.org">contact@underwings.org</a>';
      statusEl.style.display = 'block';
    } finally {
      // Reset button
      submitBtn.disabled = false;
      buttonText.style.display = 'inline';
      buttonLoading.style.display = 'none';
    }
  });
</script>

<style>
  .contact-form-container {
    width: 100%;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-field label {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #fff;
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: #24d758;
    box-shadow: 0 0 0 3px rgba(36, 215, 88, 0.1);
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .form-field select {
    cursor: pointer;
  }

  .form-field select option {
    background: #111;
    color: #fff;
  }

  .submit-button {
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #24d758, #27dab4);
    color: #000;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    width: fit-content;
  }

  .submit-button:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(36, 215, 88, 0.3);
  }

  .submit-button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .form-status {
    padding: 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
  }

  .form-status.success {
    background: rgba(36, 215, 88, 0.1);
    border: 1px solid rgba(36, 215, 88, 0.3);
    color: #24d758;
  }

  .form-status.error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #ef4444;
  }

  .form-status a {
    color: inherit;
    text-decoration: underline;
  }
</style>
