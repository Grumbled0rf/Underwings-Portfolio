---
// ===========================================
// PARTNER LOGOS GRID
// Underwings Cybersecurity Solutions
// Fetches from Supabase, falls back to hardcoded
// ===========================================

export interface Props {
  size?: 'small' | 'large';
  linkTo?: string;
}

const { size = 'small', linkTo = '#' } = Astro.props;
const logoHeight = size === 'large' ? 36 : 30;

interface Partner {
  id: string;
  name: string;
  logo_url: string;
  website_url?: string;
  display_order: number;
  invert_logo: boolean;
}

// Hardcoded fallback
const fallbackPartners: Partner[] = [
  { id: '1', name: 'Sophos', logo_url: '/images/partners/sophos.svg', website_url: 'https://www.sophos.com', display_order: 1, invert_logo: true },
  { id: '2', name: 'ManageEngine', logo_url: '/images/partners/manageengine.webp', website_url: 'https://www.manageengine.com', display_order: 2, invert_logo: false },
  { id: '3', name: 'Teramind', logo_url: '/images/partners/teramind.png', website_url: 'https://www.teramind.co', display_order: 3, invert_logo: false },
  { id: '4', name: 'Securonix', logo_url: 'https://cdn.brandfetch.io/idtcaX4QNF/theme/light/logo.svg?c=1dxbfHSJFAPEGdCLU4o5B', website_url: 'https://www.securonix.com', display_order: 4, invert_logo: true },
  { id: '5', name: 'Qualys', logo_url: 'https://cdn.brandfetch.io/id9QAR2zL7/theme/light/logo.svg?c=1dxbfHSJFAPEGdCLU4o5B', website_url: 'https://www.qualys.com', display_order: 5, invert_logo: true },
  { id: '6', name: 'ISMS.online', logo_url: '/images/partners/isms-online.svg', website_url: 'https://www.isms.online', display_order: 6, invert_logo: false },
  { id: '7', name: 'Fortinet', logo_url: '/images/partners/fortinet.webp', website_url: 'https://www.fortinet.com', display_order: 7, invert_logo: false },
  { id: '8', name: 'Tenable', logo_url: 'https://cdn.brandfetch.io/idonBVesbb/theme/light/logo.svg?c=1dxbfHSJFAPEGdCLU4o5B', website_url: 'https://www.tenable.com', display_order: 8, invert_logo: true },
  { id: '9', name: 'Rapid7', logo_url: 'https://cdn.brandfetch.io/id4wVB7jg_/theme/light/logo.svg?c=1dxbfHSJFAPEGdCLU4o5B', website_url: 'https://www.rapid7.com', display_order: 9, invert_logo: true },
  { id: '10', name: 'Wazuh', logo_url: '/images/partners/wazuh.svg', website_url: 'https://wazuh.com', display_order: 10, invert_logo: false },
];

let partners: Partner[] = fallbackPartners;

try {
  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || 'http://kong:8000';
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (supabaseKey) {
    const res = await fetch(
      `${supabaseUrl}/rest/v1/partners?select=id,name,logo_url,website_url,display_order,invert_logo&is_visible=eq.true&order=display_order.asc`,
      {
        headers: {
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`,
        },
      }
    );
    if (res.ok) {
      const data = await res.json();
      if (data.length > 0) partners = data;
    }
  }
} catch {
  // Use fallback
}
---

{partners.map((p) => (
  <a href={linkTo} class={`partner-logo ${p.invert_logo ? 'partner-logo--invert' : ''}`} title={p.name}>
    <img src={p.logo_url} alt={p.name} loading="lazy" style={`height: ${logoHeight}px; width: auto;`}>
  </a>
))}

<style is:inline>
  .partner-logo {
    opacity: 0.7;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .partner-logo--invert {
    filter: brightness(0) invert(1);
  }
  .partner-logo:hover {
    opacity: 1;
    filter: drop-shadow(0 0 12px rgba(36,215,88,0.6));
  }
  .partner-logo--invert:hover {
    opacity: 1;
    filter: brightness(0) invert(1) drop-shadow(0 0 12px rgba(36,215,88,0.6));
  }
</style>
